    "@astrojs/sitemap": "^3.7.0",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@tailwindcss/vite": "^4.1.18",
    "@types/alpinejs": "^3.13.11",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "alpinejs": "^3.15.3",
