{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@utils/*": [
        "src/utils/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@mdx/*": [
        "src/components/mdx/*"
      ],
      "@layouts/*": [
        "src/layouts/*"
      ],
      "@types": [
        "src/types/index.ts"
      ],
      "@types/*": [
        "src/types/*"
      ],
      "@assets/*": [
        "src/assets/*"
      ],
      "@styles/*": [
        "src/styles/*"
      ],
      "@reusable/*": [
        "src/components/reusable/*"
      ],
      "@layout/*": [
        "src/components/layout/*"
      ],
      "@landing/*": [
        "src/components/landing/*"
      ],
      "@posts-catalog/*": [
        "src/components/posts-catalog/*"
      ],
      "@post/*": [
        "src/components/post/*"
      ]
    },
    "types": ["vitest/globals"],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}