---
// MetadataCard.astro - Metadata display for detail page sidebar
interface Props {
  category: string;
  date: Date;
  isCompleted?: boolean;
  headOfProject?: string;
  type: 'event' | 'project';
}

const { category, date, isCompleted, headOfProject, type } = Astro.props;

// Format category for display
const formatCategory = (cat: string) => {
  return cat
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};

// Format date
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const backHref = type === 'event' ? '/events' : '/projects';
const backLabel = type === 'event' ? 'Back to Events' : 'Back to Projects';
---

<aside class="metadata-card">
  <a href={backHref} class="back-link">
    <span aria-hidden="true">&larr;</span> {backLabel}
  </a>

  <div class="metadata-section">
    <h3 class="metadata-label">Category</h3>
    <div class="category-badge">
      {formatCategory(category)}
    </div>
  </div>

  {headOfProject && (
    <div class="metadata-section">
      <h3 class="metadata-label">Project Lead</h3>
      <p class="metadata-value">{headOfProject}</p>
    </div>
  )}

  <div class="metadata-section">
    <h3 class="metadata-label">Date</h3>
    <p class="metadata-value">{formattedDate}</p>
  </div>

  {type === 'event' && (
    <div class="metadata-section" x-data={`{ isUpcoming: new Date().setHours(0,0,0,0) <= ${date.getTime()} }`}>
      <h3 class="metadata-label">Status</h3>
      <div x-bind:class="isUpcoming ? 'status-indicator in-progress' : 'status-indicator past'">
        <div class="status-dot"></div>
        <span class="status-text" x-text="isUpcoming ? 'Upcoming' : 'Past'"></span>
      </div>
    </div>
  )}

  {type === 'project' && isCompleted !== undefined && (
    <div class="metadata-section">
      <h3 class="metadata-label">Status</h3>
      <div class={`status-indicator ${isCompleted ? 'completed' : 'in-progress'}`}>
        <div class="status-dot"></div>
        <span class="status-text">
          {isCompleted ? 'Completed' : 'Ongoing'}
        </span>
      </div>
    </div>
  )}
</aside>

<style>
  .metadata-card {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  /* Desktop: Sticky positioning */
  @media (min-width: 1024px) {
    .metadata-card {
      position: sticky;
      top: 6.5rem;
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-bears-text-onDark);
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .back-link:hover {
    opacity: 1;
  }

  .metadata-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metadata-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-bears-text-onDark);
    opacity: 0.6;
    margin: 0;
  }

  .metadata-value {
    font-size: 0.9375rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    margin: 0;
    line-height: 1.6;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: linear-gradient(
      135deg,
      rgba(197, 14, 31, 0.15),
      rgba(197, 14, 31, 0.08)
    );
    border: 1px solid rgba(197, 14, 31, 0.3);
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-bears-accent);
    width: fit-content;
    letter-spacing: 0.01em;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    width: fit-content;
  }

  .status-indicator.completed {
    background-color: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .status-indicator.in-progress {
    background-color: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .status-indicator.past {
    background-color: rgba(160, 160, 160, 0.1);
    border: 1px solid rgba(160, 160, 160, 0.25);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-indicator.completed .status-dot {
    background-color: rgb(34, 197, 94);
  }

  .status-indicator.in-progress .status-dot {
    background-color: rgb(59, 130, 246);
  }

  .status-indicator.past .status-dot {
    background-color: rgb(160, 160, 160);
  }

  .status-text {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .status-indicator.completed .status-text {
    color: rgb(34, 197, 94);
  }

  .status-indicator.in-progress .status-text {
    color: rgb(59, 130, 246);
  }

  .status-indicator.past .status-text {
    color: rgb(160, 160, 160);
  }

  /* Mobile: Horizontal compact layout */
  @media (max-width: 1023px) {
    .metadata-card {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem 1.5rem;
    }

    .back-link {
      flex-basis: 100%;
    }

    .metadata-section {
      flex: 1 1 auto;
      min-width: 120px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-link {
      transition: none;
    }
  }
</style>
