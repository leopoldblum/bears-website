---
// MetadataCard.astro - Refined metadata display for sidebar
interface Props {
  category: string;
  tags?: string[];
  date: Date;
  isCompleted?: boolean;
  type: 'event' | 'project';
}

const { category, tags = [], date, isCompleted, type } = Astro.props;

// Format category for display
const formatCategory = (cat: string) => {
  return cat
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};

// Format date
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<aside class="metadata-card">
  <div class="metadata-section">
    <h3 class="metadata-label">Category</h3>
    <div class="category-badge">
      {formatCategory(category)}
    </div>
  </div>

  {tags.length > 0 && (
    <div class="metadata-section">
      <h3 class="metadata-label">Tags</h3>
      <div class="tags-container">
        {tags.map((tag) => (
          <span class="tag-badge">{tag}</span>
        ))}
      </div>
    </div>
  )}

  <div class="metadata-section">
    <h3 class="metadata-label">Date</h3>
    <p class="metadata-value">{formattedDate}</p>
  </div>

  {type === 'project' && isCompleted !== undefined && (
    <div class="metadata-section">
      <h3 class="metadata-label">Status</h3>
      <div class={`status-indicator ${isCompleted ? 'completed' : 'in-progress'}`}>
        <div class="status-dot"></div>
        <span class="status-text">
          {isCompleted ? 'Completed' : 'Ongoing'}
        </span>
      </div>
    </div>
  )}
</aside>

<style>
  .metadata-card {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .metadata-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metadata-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-bears-text-onDark);
    opacity: 0.6;
    margin: 0;
  }

  .metadata-value {
    font-size: 0.9375rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    margin: 0;
    line-height: 1.6;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: linear-gradient(
      135deg,
      rgba(197, 14, 31, 0.15),
      rgba(197, 14, 31, 0.08)
    );
    border: 1px solid rgba(197, 14, 31, 0.3);
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-bears-accent);
    width: fit-content;
    letter-spacing: 0.01em;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    font-size: 0.8125rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.85;
    transition: all 0.2s ease;
  }

  .tag-badge:hover {
    background-color: rgba(255, 255, 255, 0.08);
    opacity: 1;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    width: fit-content;
  }

  .status-indicator.completed {
    background-color: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .status-indicator.in-progress {
    background-color: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-indicator.completed .status-dot {
    background-color: rgb(34, 197, 94);
  }

  .status-indicator.in-progress .status-dot {
    background-color: rgb(59, 130, 246);
  }

  .status-text {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .status-indicator.completed .status-text {
    color: rgb(34, 197, 94);
  }

  .status-indicator.in-progress .status-text {
    color: rgb(59, 130, 246);
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-badge {
      transition: none;
    }
  }
</style>
