---
// LatestNews component - Shows latest news from BEARS
import NewsGridElement from "./NewsGridElement.astro";
import { getImage } from "astro:assets";

// Import images
const eventImages = import.meta.glob<{ default: ImageMetadata }>("/src/assets/events/*.{jpg,jpeg,png,webp}");
const projectImages = import.meta.glob<{ default: ImageMetadata }>("/src/assets/projects/*.{jpg,jpeg,png,webp}");

// Helper to get optimized image
async function getOptimizedImage(path: string, type: 'events' | 'projects') {
  const images = type === 'events' ? eventImages : projectImages;
  const fullPath = `/src/assets/${type}/${path}`;
  if (images[fullPath]) {
    const imageModule = await images[fullPath]();
    const optimized = await getImage({ src: imageModule.default, format: "webp" });
    return optimized.src;
  }
  return "";
}

// Define news items with image filenames
const newsItemsData = [
  {
    imageFile: "event-1.jpg",
    imageType: "events" as const,
    imageAlt: "Event 1",
    date: "January 12, 2026",
    title: "Jessie has joined the Matrix-Channel!",
    description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.",
  },
  {
    imageFile: "project-1.jpg",
    imageType: "projects" as const,
    imageAlt: "Project 1",
    date: "January 10, 2026",
    title: "2nd Great Update",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
  },
  {
    imageFile: "event-2.jpg",
    imageType: "events" as const,
    imageAlt: "Event 2",
    date: "January 10, 2026",
    title: "3rd Great Update",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
  },
  {
    imageFile: "project-2.jpg",
    imageType: "projects" as const,
    imageAlt: "Project 2",
    date: "January 10, 2026",
    title: "4th Great Update",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
  },
  {
    imageFile: "event-3.jpg",
    imageType: "events" as const,
    imageAlt: "Event 3",
    date: "January 10, 2026",
    title: "5th Great Update",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
  },
];

// Get optimized images
const newsItems = await Promise.all(
  newsItemsData.map(async (item) => ({
    imageUrl: await getOptimizedImage(item.imageFile, item.imageType),
    imageAlt: item.imageAlt,
    date: item.date,
    title: item.title,
    description: item.description,
  }))
);
---

<section class="container mx-auto px-4 sm:px-8 md:px-12 lg:px-16 py-16 sm:py-20 md:py-24">
  <!-- Header - left aligned -->
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-bears-text-onDark mb-6 sm:mb-8 md:mb-12">
    Latest News from BEARS
  </h2>

  <!-- Placeholder text -->
  <p class="text-base sm:text-lg text-bears-text-onDark leading-relaxed max-w-3xl mb-8 sm:mb-12">
    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.
  </p>

  <!-- Learn More Button -->
  <div>
    <button class="px-4 py-2.5 sm:px-6 sm:py-2 bg-bears-accent text-bears-text-onDark rounded-full hover:bg-bears-accent-muted transition-colors font-medium cursor-pointer">
      Learn More
    </button>
  </div>

    <!-- News Preview Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 my-8 sm:my-12">
    {newsItems.map((news) => (
      <NewsGridElement
        imageUrl={news.imageUrl}
        imageAlt={news.imageAlt}
        date={news.date}
        title={news.title}
        description={news.description}
      />
    ))}
  </div>
</section>
