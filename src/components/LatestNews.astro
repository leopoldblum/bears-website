---

<section class="container mx-auto px-4 sm:px-8 md:px-12 lg:px-16 py-16 sm:py-20 md:py-24">
  <!-- Header - left aligned -->
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-bears-text mb-6 sm:mb-8">
    Latest News from BEARS
  </h2>

  <!-- Placeholder text -->
  <p class="text-base sm:text-lg text-bears-text leading-relaxed max-w-3xl mb-8 sm:mb-12">
    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.
  </p>

  <!-- Learn More Button -->
  <div>
    <button class="px-4 py-2.5 sm:px-6 sm:py-2 bg-bears-accent text-bears-text rounded-full hover:bg-bears-accent-muted transition-colors font-medium cursor-pointer">
      Learn More
    </button>
  </div>

    <!-- News Preview Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 my-8 sm:my-12">
    {newsItems.map((news) => (
      <NewsGridElement
        imageUrl={news.imageUrl}
        imageAlt={news.imageAlt}
        date={news.date}
        title={news.title}
        description={news.description}
      />
    ))}
  </div>
</section>
