    title: "2nd Great Update",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
  },
  {
    imageUrl: "https://via.placeholder.com/600x400/C50E1F/E1E1E1?text=News+3",
    imageAlt: "News Image 3",
    date: "January 10, 2026",
    title: "3rd Great Update",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
  },
  {
    imageUrl: "https://via.placeholder.com/600x400/C50E1F/E1E1E1?text=News+4",
