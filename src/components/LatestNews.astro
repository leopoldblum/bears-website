---
// LatestNews component - Shows latest news from BEARS
import PostShowcase from "./PostShowcase.astro";
import { getCollection } from "astro:content";
import type { ImageMetadata } from 'astro';
import type { PostType } from '../types';

// Import images
const eventImages = import.meta.glob<{ default: ImageMetadata }>("/src/assets/events/*.{jpg,jpeg,png,webp}");
const projectImages = import.meta.glob<{ default: ImageMetadata }>("/src/assets/projects/*.{jpg,jpeg,png,webp}");

// Fetch all posts (events and projects)
const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.DEV || !data.isDraft;
});

// Sort by date (newest first) and limit to 4 items
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

// Process posts with images and hrefs
const newsItems = await Promise.all(
  latestPosts.map(async (post) => {

    // Determine post type (event or project)
    const postType: PostType = post.slug.startsWith('events/') ? 'events' : 'projects';

    // Load cover image based on coverImageType
    let coverImage: ImageMetadata | null = null;
    let coverImageLoadFailed = false;

    if (post.data.coverImageType === "CUSTOM" && post.data.coverImage) {
      const imagePath = `/src/assets/${postType}/${post.data.coverImage}`;
      const images = postType === 'events' ? eventImages : projectImages;

      if (images[imagePath]) {
        try {
          const imageModule = await images[imagePath]();
          coverImage = imageModule.default;
        } catch (error) {
          coverImageLoadFailed = true;
          // coverImage remains null, PostShowcase will use default
        }
      } else {
        coverImageLoadFailed = true;
        // coverImage remains null, PostShowcase will use default
      }
    }

    // Development warnings
    if (import.meta.env.DEV) {
      if (post.data.coverImageType === "DEFAULT") {
        console.warn(
          `🔹 Post "${post.data.title}" (${post.slug}) is using DEFAULT cover image`
        );
      } else if (coverImageLoadFailed) {
        console.warn(
          `🔹 Post "${post.data.title}" (${post.slug}) - image "${post.data.coverImage}" failed to load, using default`
        );
      }
    }

    // Build href for the post
    const href = `/${postType}/${post.slug.replace(`${postType}/`, '')}`;

    return {
      imageData: coverImage,  // May be null, PostShowcase will use default
      imageAlt: post.data.title,
      date: post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
      title: post.data.title,
      description: post.data.description,
      href: href,
      postType: postType,
    };
  })
);
---

<section class="container mx-auto px-4 sm:px-8 md:px-12 lg:px-16 py-16 sm:py-20 md:py-24">
  <!-- Header - left aligned -->
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-bears-text-onDark mb-6 sm:mb-8 md:mb-12">
    Latest News from BEARS
  </h2>

  <!-- Placeholder text -->
  <p class="text-base sm:text-lg text-bears-text-onDark leading-relaxed max-w-3xl mb-8 sm:mb-12">
    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.
  </p>

  <!-- Learn More Button -->
  <div>
    <button class="px-4 py-2.5 sm:px-6 sm:py-2 bg-bears-accent text-bears-text-onDark rounded-full hover:bg-bears-accent-muted transition-colors font-medium cursor-pointer">
      Learn More
    </button>
  </div>

    <!-- News Preview Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 my-8 sm:my-12">
    {newsItems.map((news) => (
      <PostShowcase
        coverImage={news.imageData}
        imageAlt={news.imageAlt}
        date={news.date}
        title={news.title}
        description={news.description}
        href={news.href}
        postType={news.postType}
      />
    ))}
  </div>
</section>
