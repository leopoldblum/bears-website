---

<section class="bg-[#F5F5F5] py-16 sm:py-20 md:py-24">
  <div class="container mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
    <!-- Headline -->
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-center text-[#2B2B2B] mb-12 sm:mb-16 md:mb-20">
      Become a Sponsor
    </h2>

    <!-- Premium Sponsors Row -->
    {premiumSponsors.length > 0 && (
      <div class="flex flex-wrap justify-center items-center gap-8 sm:gap-10 md:gap-12 mb-6 sm:mb-8">
        {premiumSponsors.map((sponsor) => (
          <a href={sponsor.url} class="inline-block hover:scale-110 hover:opacity-80 transition-all duration-300">
            <img
              src={sponsor.logo}
              alt={sponsor.name}
              class="h-24 w-24 sm:h-32 sm:w-32 md:h-40 md:w-40"
            />
          </a>
        ))}
      </div>
    )}

    <!-- Divider between sponsor tiers -->
    <hr class="w-full max-w-3xl mx-auto border-t border-[#2B2B2B] opacity-20 my-8 sm:my-10 md:my-12" />

    <!-- Other Sponsors Row -->
    {otherSponsors.length > 0 && (
      <div class="flex flex-wrap justify-center items-center gap-6 sm:gap-8 md:gap-10 mb-10 sm:mb-12 md:mb-16">
        {otherSponsors.map((sponsor) => (
          <a href={sponsor.url} class="inline-block hover:scale-110 hover:opacity-80 transition-all duration-300">
            <img
              src={sponsor.logo}
              alt={sponsor.name}
              class="h-20 w-20 sm:h-24 sm:w-24 md:h-28 md:w-28"
            />
          </a>
        ))}
      </div>
    )}

    <!-- Placeholder text below logos -->
    <p class="text-sm sm:text-base text-[#2B2B2B] text-center opacity-70 max-w-2xl mx-auto mb-6 sm:mb-8">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Interested in becoming a sponsor? Contact us to learn more about partnership opportunities.
    </p>

    <!-- Learn more button -->
    <div class="flex justify-center">
      <button class="px-6 sm:px-8 py-2.5 sm:py-3 bg-[#2B2B2B] text-bears-text rounded-full hover:opacity-80 transition-all font-medium cursor-pointer">
        Learn More
      </button>
    </div>
  </div>
</section>
