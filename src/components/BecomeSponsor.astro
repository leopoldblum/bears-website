  },
  {
    name: "Sponsor 10",
    logo: "https://placehold.co/80x80/DDDDDD/2B2B2B?text=Logo+10",
    url: "#"
  },
  {
    name: "Sponsor 11",
    logo: "https://placehold.co/80x80/CCCCCC/2B2B2B?text=Logo+11",
