---
// BecomeSponsor component - Displays sponsor showcase with tier-based system
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import SponsorTier from "./SponsorTier.astro";

// Fetch all sponsors
const allSponsors = await getCollection("sponsors");

// Import all logo images
const logos = import.meta.glob<{ default: ImageMetadata }>("/src/assets/sponsors/*.{jpg,jpeg,png}");

// Process sponsors with optimized images
const sponsorsWithImages = await Promise.all(
  allSponsors.map(async (sponsor: any) => {
    const logoPath = `/src/assets/sponsors/${sponsor.data.logo}`;
    let optimizedLogo;

    if (logos[logoPath]) {
      const logoModule = await logos[logoPath]();
      const optimized = await getImage({
        src: logoModule.default,
        format: "webp",
        width: 200
      });
      optimizedLogo = optimized.src;
    }

    return {
      ...sponsor.data,
      logo: optimizedLogo,
      slug: sponsor.slug,
    };
  })
);

// Group sponsors by tier and sort alphabetically within each tier
const goldSponsors = sponsorsWithImages
  .filter(s => s.tier === 'gold')
  .sort((a, b) => a.slug.localeCompare(b.slug));

const silverSponsors = sponsorsWithImages
  .filter(s => s.tier === 'silver')
  .sort((a, b) => a.slug.localeCompare(b.slug));

const bronzeSponsors = sponsorsWithImages
  .filter(s => s.tier === 'bronze')
  .sort((a, b) => a.slug.localeCompare(b.slug));
---

<section class="bg-bears-bg-light py-16 sm:py-20 md:py-24">
  <div class="container mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
    <!-- Headline -->
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-center text-bears-text-onLight mb-12 sm:mb-16 md:mb-20">
      Become a Sponsor
    </h2>

    <!-- Gold Sponsors Tier -->
    <SponsorTier sponsors={goldSponsors} tier="gold" />

    <!-- Divider 1: Only show if gold sponsors exist AND (silver OR bronze exist) -->
    {goldSponsors.length > 0 && (silverSponsors.length > 0 || bronzeSponsors.length > 0) && (
      <hr class="w-full max-w-3xl mx-auto border-t border-bears-text-onLight opacity-20 my-8 sm:my-10 md:my-12" />
    )}

    <!-- Silver Sponsors Tier -->
    <SponsorTier sponsors={silverSponsors} tier="silver" />

    <!-- Divider 2: Only show if silver sponsors exist AND bronze exist -->
    {silverSponsors.length > 0 && bronzeSponsors.length > 0 && (
      <hr class="w-full max-w-3xl mx-auto border-t border-bears-text-onLight opacity-20 my-8 sm:my-10 md:my-12" />
    )}

    <!-- Bronze Sponsors Tier -->
    <SponsorTier sponsors={bronzeSponsors} tier="bronze" />

    <!-- Placeholder text below logos -->
    <p class="text-sm sm:text-base text-bears-text-onLight text-center opacity-70 max-w-2xl mx-auto mb-6 sm:mb-8">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Interested in becoming a sponsor? Contact us to learn more about partnership opportunities.
    </p>

    <!-- Learn more button -->
    <div class="flex justify-center">
      <button class="px-6 sm:px-8 py-2.5 sm:py-3 bg-bears-text-onLight text-bears-text-onDark rounded-full hover:opacity-80 transition-all font-medium cursor-pointer">
        Learn More
      </button>
    </div>
  </div>
</section>
