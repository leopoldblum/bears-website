---
// BecomeSponsor component - Displays sponsor showcase with light background
// Data-driven sponsor management with premium and other sponsor tiers

// Define sponsor data
const premiumSponsors = [
  {
    name: "Sponsor 1",
    logo: "https://placehold.co/160x160/CCCCCC/2B2B2B?text=Logo+1",
    url: "#"
  },
  {
    name: "Sponsor 2",
    logo: "https://placehold.co/160x160/DDDDDD/2B2B2B?text=Logo+2",
    url: "#"
  },
  {
    name: "Sponsor 3",
    logo: "https://placehold.co/160x160/CCCCCC/2B2B2B?text=Logo+3",
    url: "#"
  },
  {
    name: "Sponsor 4",
    logo: "https://placehold.co/160x160/DDDDDD/2B2B2B?text=Logo+4",
    url: "#"
  },
  {
    name: "Sponsor 5",
    logo: "https://placehold.co/160x160/CCCCCC/2B2B2B?text=Logo+5",
    url: "#"
  }
];

const otherSponsors = [
  {
    name: "Sponsor 6",
    logo: "https://placehold.co/80x80/DDDDDD/2B2B2B?text=Logo+6",
    url: "#"
  },
  {
    name: "Sponsor 7",
    logo: "https://placehold.co/80x80/CCCCCC/2B2B2B?text=Logo+7",
    url: "#"
  },
  {
    name: "Sponsor 8",
    logo: "https://placehold.co/80x80/DDDDDD/2B2B2B?text=Logo+8",
    url: "#"
  },
  {
    name: "Sponsor 9",
    logo: "https://placehold.co/80x80/CCCCCC/2B2B2B?text=Logo+9",
