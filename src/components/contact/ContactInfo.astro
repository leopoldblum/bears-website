---
import { getPageContent } from "@utils/contentQueries";
import { socialIcons } from "@utils/socialIcons";
import { type Locale } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const content = await getPageContent("contact/contact-info", locale);
const socialContent = await getPageContent("site/social-links", locale);

const email = content?.data.items?.[0] ?? "info@bears-space.de";
const addressLines = content?.data.items?.slice(1) ?? [];
const socialLinks = socialContent?.data.socialLinks ?? [];
---

<section id="contact-info" class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24 scroll-mt-20">
  {/* Description */}
  {content?.data.description && (
    <p class="text-sm sm:text-base lg:text-lg text-bears-text-onDark/60 leading-relaxed max-w-2xl mb-10 sm:mb-12 lg:mb-16">
      {content.data.description}
    </p>
  )}

  {/* Cards grid */}
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
    {/* Email card */}
    <div
      class="contact-card flex flex-col rounded-2xl overflow-hidden bg-white/[0.03] border border-white/10"
      style="animation-delay: 0ms"
    >
      <div class="h-[2px] bg-gradient-to-r from-bears-accent via-bears-accent/60 to-transparent"></div>
      <div class="flex flex-col flex-1 p-6 sm:p-8">
        <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-6">
          <div class="w-10 h-10 shrink-0 rounded-full bg-bears-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-bears-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 id="contact-email" class="text-lg sm:text-xl font-semibold text-bears-text-onDark scroll-mt-20">Email</h3>
        </div>
        <div class="flex-1 flex items-center">
          <a
            href={`mailto:${email}`}
            class="text-sm sm:text-base text-bears-accent hover:underline break-all select-all"
          >
            {email}
          </a>
        </div>
      </div>
    </div>

    {/* Social media card */}
    <div
      class="contact-card flex flex-col rounded-2xl overflow-hidden bg-white/[0.03] border border-white/10"
      style="animation-delay: 80ms"
    >
      <div class="h-[2px] bg-gradient-to-r from-bears-accent via-bears-accent/60 to-transparent"></div>
      <div class="flex flex-col flex-1 p-6 sm:p-8">
        <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-6">
          <div class="w-10 h-10 shrink-0 rounded-full bg-bears-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-bears-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9 9 0 0 1 3 12c0-1.47.353-2.856.978-4.082" />
            </svg>
          </div>
          <h3 id="contact-social" class="text-lg sm:text-xl font-semibold text-bears-text-onDark scroll-mt-20">Follow Us</h3>
        </div>
        <div class="flex-1 flex items-center">
          <div class="flex gap-4">
            {socialLinks.map((link) => {
              const icon = socialIcons[link.platform];
              if (!icon) return null;
              return (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  x-data="{ hovered: false }"
                  x-on:mouseenter="hovered = true"
                  x-on:mouseleave="hovered = false"
                  class:list={[
                    "group/social flex flex-col items-center gap-2",
                    !link.hoverColor && "[&:hover_.social-icon]:bg-bears-accent",
                  ]}
                  aria-label={icon.label}
                >
                  <div
                    x-bind:style={link.hoverColor ? `hovered ? 'background-color: ${link.hoverColor}' : ''` : undefined}
                    class:list={[
                      "social-icon w-11 h-11 rounded-full bg-white/10 flex items-center justify-center hover:scale-110 transition-all duration-200",
                    ]}
                  >
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      class="fill-bears-text-onDark group-hover/social:fill-white transition-colors duration-200"
                    >
                      <path d={icon.path} />
                    </svg>
                  </div>
                  <span class="text-[11px] text-bears-text-onDark/40 group-hover/social:text-bears-text-onDark/70 transition-colors duration-200">
                    {icon.label}
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </div>

    {/* Address card */}
    <div
      class="contact-card flex flex-col rounded-2xl overflow-hidden bg-white/[0.03] border border-white/10"
      style="animation-delay: 160ms"
    >
      <div class="h-[2px] bg-gradient-to-r from-bears-accent via-bears-accent/60 to-transparent"></div>
      <div class="flex flex-col flex-1 p-6 sm:p-8">
        <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-6">
          <div class="w-10 h-10 shrink-0 rounded-full bg-bears-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-bears-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <h3 id="contact-address" class="text-lg sm:text-xl font-semibold text-bears-text-onDark scroll-mt-20">{locale === 'de' ? 'Adresse' : 'Address'}</h3>
        </div>
        <div class="flex-1 flex items-center">
          <div>
            <address class="not-italic text-sm sm:text-base text-bears-text-onDark/60 leading-relaxed">
              {addressLines.map((line, i) => (
                <Fragment>
                  {line}
                  {i < addressLines.length - 1 && <br />}
                </Fragment>
              ))}
            </address>
            <a
              href="/about-us#find-us-section"
              class="inline-flex items-center gap-1.5 mt-4 text-sm text-bears-accent hover:text-bears-accent transition-colors duration-200"
            >
              {locale === 'de' ? 'Auf Karte ansehen' : 'View on map'}
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
