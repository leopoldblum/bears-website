---
import { getPageContent } from "@utils/contentQueries";

const content = await getPageContent("contact/contact-info");

const email = content?.data.items?.[0] ?? "info@bears-space.de";
const addressLines = content?.data.items?.slice(1) ?? [];
const socialLinks = content?.data.socialLinks ?? [];

const socialIcons: Record<string, { label: string; path: string }> = {
  instagram: {
    label: "Instagram",
    path: "M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z",
  },
  linkedin: {
    label: "LinkedIn",
    path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
  youtube: {
    label: "YouTube",
    path: "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
};
---

<section id="contact-info" class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24 scroll-mt-20">
  {/* Description */}
  {content?.data.description && (
    <p class="text-sm sm:text-base lg:text-lg text-bears-text-onDark/60 leading-relaxed max-w-2xl mb-10 sm:mb-12 lg:mb-16">
      {content.data.description}
    </p>
  )}

  {/* Cards grid */}
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
    {/* Email card */}
    <div
      class="contact-card flex flex-col rounded-2xl overflow-hidden bg-white/[0.03] border border-white/10"
      style="animation-delay: 0ms"
    >
      <div class="h-[2px] bg-gradient-to-r from-bears-accent via-bears-accent/60 to-transparent"></div>
      <div class="flex flex-col flex-1 p-6 sm:p-8">
        <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-6">
          <div class="w-10 h-10 shrink-0 rounded-full bg-bears-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-bears-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 id="contact-email" class="text-lg sm:text-xl font-semibold text-bears-text-onDark scroll-mt-20">Email</h3>
        </div>
        <div class="flex-1 flex items-center">
          <a
            href={`mailto:${email}`}
            class="text-sm sm:text-base text-bears-accent hover:underline break-all select-all"
          >
            {email}
          </a>
        </div>
      </div>
    </div>

    {/* Social media card */}
    <div
      class="contact-card flex flex-col rounded-2xl overflow-hidden bg-white/[0.03] border border-white/10"
      style="animation-delay: 80ms"
    >
      <div class="h-[2px] bg-gradient-to-r from-bears-accent via-bears-accent/60 to-transparent"></div>
      <div class="flex flex-col flex-1 p-6 sm:p-8">
        <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-6">
          <div class="w-10 h-10 shrink-0 rounded-full bg-bears-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-bears-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9 9 0 0 1 3 12c0-1.47.353-2.856.978-4.082" />
            </svg>
          </div>
          <h3 id="contact-social" class="text-lg sm:text-xl font-semibold text-bears-text-onDark scroll-mt-20">Follow Us</h3>
        </div>
        <div class="flex-1 flex items-center">
          <div class="flex gap-4">
            {socialLinks.map((link) => {
              const icon = socialIcons[link.platform];
              if (!icon) return null;
              return (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  x-data="{ hovered: false }"
                  x-on:mouseenter="hovered = true"
                  x-on:mouseleave="hovered = false"
                  class:list={[
                    "group/social flex flex-col items-center gap-2",
                    !link.hoverColor && "[&:hover_.social-icon]:bg-bears-accent",
                  ]}
                  aria-label={icon.label}
                >
                  <div
                    x-bind:style={link.hoverColor ? `hovered ? 'background-color: ${link.hoverColor}' : ''` : undefined}
                    class:list={[
                      "social-icon w-11 h-11 rounded-full bg-white/10 flex items-center justify-center hover:scale-110 transition-all duration-200",
                    ]}
                  >
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      class="fill-bears-text-onDark group-hover/social:fill-white transition-colors duration-200"
                    >
                      <path d={icon.path} />
                    </svg>
                  </div>
                  <span class="text-[11px] text-bears-text-onDark/40 group-hover/social:text-bears-text-onDark/70 transition-colors duration-200">
                    {icon.label}
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </div>

    {/* Address card */}
    <div
      class="contact-card flex flex-col rounded-2xl overflow-hidden bg-white/[0.03] border border-white/10"
      style="animation-delay: 160ms"
    >
      <div class="h-[2px] bg-gradient-to-r from-bears-accent via-bears-accent/60 to-transparent"></div>
      <div class="flex flex-col flex-1 p-6 sm:p-8">
        <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-6">
          <div class="w-10 h-10 shrink-0 rounded-full bg-bears-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-bears-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <h3 id="contact-address" class="text-lg sm:text-xl font-semibold text-bears-text-onDark scroll-mt-20">Address</h3>
        </div>
        <div class="flex-1 flex items-center">
          <div>
            <address class="not-italic text-sm sm:text-base text-bears-text-onDark/60 leading-relaxed">
              {addressLines.map((line, i) => (
                <Fragment>
                  {line}
                  {i < addressLines.length - 1 && <br />}
                </Fragment>
              ))}
            </address>
            <a
              href="/about-us#find-us-section"
              class="inline-flex items-center gap-1.5 mt-4 text-sm text-bears-accent/70 hover:text-bears-accent transition-colors duration-200"
            >
              View on map
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
