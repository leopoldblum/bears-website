---
import Img from "@mdx/Img.astro";
import Button from "@mdx/Button.astro";
import { getPageContent } from "@utils/contentQueries";
import { ourMissionImages } from "@utils/imageGlobs";
import { loadAllImagesFromDirectory } from "@utils/imageLoader";

const content = await getPageContent("about-us/our-mission");
const listContent = await getPageContent("about-us/whats-in-it");

const loadedImages = await loadAllImagesFromDirectory(ourMissionImages);
const missionImage = loadedImages[0];
---

<section
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24"
>
  <div
    class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-stretch min-h-[500px] lg:min-h-[60vh]"
  >
    <!-- Image -->
    <div
      class="relative w-full h-80 sm:h-96 lg:h-full rounded-2xl overflow-hidden border border-white/10 shadow-[0_4px_12px_rgba(0,0,0,0.4)]"
    >
      <Img
        src={missionImage}
        alt="BEARS team working on aerospace projects"
        class="rounded-2xl"
        enableClickToEnlarge={false}
        fill={true}
        loading="eager"
        sizes="(min-width: 1024px) 50vw, 100vw"
      />
    </div>

    <!-- Text: side-by-side on mobile, stacked column on desktop -->
    <div
      class="grid grid-cols-2 lg:grid-cols-1 lg:flex lg:flex-col lg:min-h-[60vh] gap-2 sm:gap-6 lg:gap-0"
    >
      <!-- Title + subtitle -->
      <div
        class="pr-2 sm:pr-0 lg:w-fit lg:ml-auto col-span-1 order-2 lg:order-1"
      >
        {
          content?.data.subtitle && (
            <p class="text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-bears-accent text-right mb-2 sm:mb-3">
              {content.data.subtitle}
            </p>
          )
        }
        <h2
          class="text-2xl sm:text-3xl lg:text-5xl font-bold text-bears-text-onDark text-right pl-12 sm:pl-12 lg:pl-24"
        >
          {content?.data.title}
        </h2>
        <div
          class="h-[2px] bg-gradient-to-l from-white/30 from-30% via-white/15 via-70% to-transparent my-3 sm:my-4 lg:my-6 rounded-full"
        >
        </div>
        {
          content?.data.description && (
            <p class="text-sm sm:text-base text-bears-text-onDark/60 text-right leading-relaxed">
              {content.data.description}
            </p>
          )
        }
      </div>

      <!-- Numbered list -->
      {
        listContent?.data.items && (
          <div class="col-span-1 order-1 lg:order-2 pt-8 sm:pt-10 lg:pt-0 lg:mt-auto lg:flex lg:justify-center lg:mx-[16%]">
            <div class="w-fit bg-white/[0.03] border border-white/10 rounded-xl px-7 py-4 sm:px-9 sm:py-5 lg:px-10 lg:py-6">
              <h3 class="text-sm sm:text-base lg:text-lg font-semibold text-bears-text-onDark mb-3 sm:mb-4 lg:mb-6">
                {listContent.data.title}
              </h3>
              <ul class="space-y-2 sm:space-y-3 lg:space-y-4">
                {listContent.data.items.map((item, i) => (
                  <li class="accordion-item text-sm sm:text-base lg:text-lg text-bears-text-onDark/80" style={`animation-delay: ${i * 60}ms`}>
                    <span class="text-bears-accent font-bold mr-1 sm:mr-2 lg:mr-3">
                      /{String(i + 1).padStart(2, "0")}
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
              <div class="mt-6 sm:mt-8 lg:mt-10 flex justify-center">
                <Button variant="primary" size="large" href="#find-us">
                  Join us!
                </Button>
              </div>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
