---
import Img from "@mdx/Img.astro";
import Button from "@mdx/Button.astro";
import GradientDivider from "@reusable/GradientDivider.astro";
import { getPageContent } from "@utils/contentQueries";
import { ourMissionImages } from "@utils/imageGlobs";
import { loadAllImagesFromDirectory } from "@utils/imageLoader";
import { type Locale } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const content = await getPageContent("about-us/our-mission", locale);
const listContent = await getPageContent("about-us/whats-in-it", locale);

const loadedImages = await loadAllImagesFromDirectory(ourMissionImages);
const missionImage = loadedImages[0];

const parsedItems = listContent?.data.titledItems ?? [];
---

<section
  id="our-mission-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24 scroll-mt-20"
>
  <!-- Part 1: Mission Statement -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
    <!-- Image -->
    <div
      class="relative w-full h-72 sm:h-80 lg:h-[480px] rounded-2xl overflow-hidden border border-white/10 shadow-[0_4px_12px_rgba(0,0,0,0.4)]"
    >
      <Img
        src={missionImage}
        alt="BEARS team working on aerospace projects"
        class="rounded-2xl"
        enableClickToEnlarge={false}
        fill={true}
        loading="eager"
        sizes="(min-width: 1024px) 50vw, 100vw"
      />
    </div>

    <!-- Text -->
    <div>
      {
        content?.data.subtitle && (
          <p class="text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-bears-accent mb-2 sm:mb-3">
            {content.data.subtitle}
          </p>
        )
      }
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark"
      >
        {content?.data.title}
      </h2>
      <GradientDivider class="mt-4 sm:mt-6" />
      {
        content?.data.description && (
          <p class="text-sm sm:text-base lg:text-lg text-bears-text-onDark/60 leading-relaxed mt-4 sm:mt-6 max-w-xl">
            {content.data.description}
          </p>
        )
      }
    </div>
  </div>

  <!-- Part 2: Benefits Grid -->
  {
    parsedItems.length > 0 && (
      <div class="mt-16 sm:mt-20 lg:mt-24">
        <h3 id="whats-in-it" class="text-xl sm:text-2xl lg:text-3xl font-bold text-bears-text-onDark mb-8 sm:mb-10 lg:mb-14 scroll-mt-20">
          {listContent?.data.title}
        </h3>

        <div class="flex flex-wrap justify-center gap-4 sm:gap-5 lg:gap-6">
          {parsedItems.map((item, i) => (
            <div
              class="accordion-item bg-white/[0.03] border border-white/10 rounded-xl p-5 sm:p-6 transition-colors duration-300 hover:bg-white/[0.06] w-full sm:w-[calc(50%-0.625rem)] lg:w-[calc(33.333%-1rem)]"
              style={`animation-delay: ${i * 60}ms`}
            >
              <h4 class="text-base sm:text-lg font-semibold text-bears-text-onDark">
                <span class="text-bears-accent font-bold text-sm sm:text-base mr-2">
                  /{String(i + 1).padStart(2, "0")}
                </span>
                {item.title}
              </h4>
              {item.description && (
                <p class="text-sm text-bears-text-onDark/50 leading-relaxed mt-2">
                  {item.description}
                </p>
              )}
            </div>
          ))}
        </div>

        <div class="mt-8 sm:mt-10 lg:mt-12 flex justify-center">
          <Button variant="primary" size="large" href="#find-us-section">
            {locale === 'de' ? 'Mach mit!' : 'Join us!'}
          </Button>
        </div>
      </div>
    )
  }
</section>
