---
import Accordion from "@mdx/Accordion.astro";
import CrosslinkBanner from "@reusable/CrosslinkBanner.astro";
import GradientDivider from "@reusable/GradientDivider.astro";
import { getPageContent } from "@utils/contentQueries";
import { type Locale, localizeUrl } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const content = await getPageContent("faq", locale);
const crosslink = await getPageContent("about-us/faq-crosslink", locale);

const accordionItems = (content?.data.faqs ?? []).map((faq) => ({
  title: faq.question,
  content: faq.answer,
}));
---

{accordionItems.length > 0 && (
  <section class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24">
    {/* Subtitle */}
    {content?.data.subtitle && (
      <p class="text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-bears-accent mb-3 sm:mb-4">
        {content.data.subtitle}
      </p>
    )}

    {/* Heading */}
    <h2 id="faq-title" data-pagefind-index-attrs="id" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-8 sm:mb-10 lg:mb-14 scroll-mt-20">
      {content?.data.title}
    </h2>
    <span class="sr-only" data-pagefind-weight="8">FAQ</span>

    {/* Gradient divider */}
    <GradientDivider class="mb-6 sm:mb-8 lg:mb-10" />

    {/* Description */}
    {content?.data.description && (
      <p class="text-sm sm:text-base lg:text-lg text-bears-text-onDark/60 leading-relaxed max-w-2xl mb-8 sm:mb-10 lg:mb-12">
        {content.data.description}
      </p>
    )}

    {/* Accordion in glass card */}
    <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8">
      <Accordion
        items={accordionItems}
        allowMultiple={true}
      />
    </div>

    <CrosslinkBanner
      text={crosslink?.data.title ?? "Still have questions?"}
      linkText={crosslink?.data.buttonText ?? "Get in touch"}
      href={localizeUrl(crosslink?.data.buttonHref ?? "/contact", locale)}
    />
  </section>
)}
