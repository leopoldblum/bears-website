---
interface Props {
  /**
   * Array of category values to display as filter options
   */
  categories: string[];

  /**
   * Mapping of category values to human-readable labels
   */
  categoryLabels: Record<string, string>;

  /**
   * Alpine.js state variable name to use for tracking the active filter
   * @default 'activeCategory'
   */
  stateVariable?: string;
}

const { categories, categoryLabels, stateVariable = 'activeCategory' } = Astro.props;
---

<div class="flex flex-wrap justify-end gap-2 sm:gap-3">
  <!-- "All" button -->
  <button
    type="button"
    class="px-3 py-1.5 sm:px-4 sm:py-2 rounded-full text-sm sm:text-base font-medium transition-all duration-200 cursor-pointer"
    :class={`${stateVariable} === 'all' ? 'bg-bears-accent text-bears-text-onDark' : 'bg-bears-bg border border-bears-accent-muted text-bears-text-onDark hover:bg-bears-accent hover:border-bears-accent'`}
    @click={`${stateVariable} = 'all'`}
  >
    All
  </button>

  <!-- Category buttons -->
  {categories.map((category) => (
    <button
      type="button"
      class="px-3 py-1.5 sm:px-4 sm:py-2 rounded-full text-sm sm:text-base font-medium transition-all duration-200 cursor-pointer"
      :class={`${stateVariable} === '${category}' ? 'bg-bears-accent text-bears-text-onDark' : 'bg-bears-bg border border-bears-accent-muted text-bears-text-onDark hover:bg-bears-accent hover:border-bears-accent'`}
      @click={`${stateVariable} = '${category}'`}
    >
      {categoryLabels[category] || category}
    </button>
  ))}
</div>
