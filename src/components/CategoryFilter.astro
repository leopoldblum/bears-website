---
interface Props {
  /**
   * Array of category values to display as filter options
   */
  categories: string[];

  /**
   * Mapping of category values to human-readable labels
   */
  categoryLabels: Record<string, string>;

  /**
   * Alpine.js state variable name to use for tracking the active filter (should be an array)
   * @default 'activeCategory'
   */
  stateVariable?: string;
}

const { categories, categoryLabels, stateVariable = 'activeCategory' } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {categories.map((category, index) => (
    <button
      type="button"
      @click={`toggleFilter(${stateVariable}, '${category}')`}
      :class={`${stateVariable}.includes('${category}')
        ? 'bg-bears-accent text-white border-bears-accent shadow-[0_0_12px_rgba(197,14,31,0.35)]'
        : 'bg-transparent text-bears-text-onDark/80 border-white/15 hover:border-bears-accent/50 hover:text-bears-text-onDark'`}
      class="filter-chip px-3.5 py-1.5 text-sm font-medium rounded-md border transition-all duration-200 cursor-pointer select-none"
      style={`animation-delay: ${index * 40}ms`}
    >
      {categoryLabels[category] || category}
    </button>
  ))}
</div>
