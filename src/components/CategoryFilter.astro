---
interface Props {
  /**
   * Array of category values to display as filter options
   */
  categories: string[];

  /**
   * Mapping of category values to human-readable labels
   */
  categoryLabels: Record<string, string>;

  /**
   * Alpine.js state variable name to use for tracking the active filter (should be an array)
   * @default 'activeCategory'
   */
  stateVariable?: string;
}

const { categories, categoryLabels, stateVariable = 'activeCategory' } = Astro.props;
---

<div class="flex flex-col gap-2">
  {categories.map((category) => (
    <label
      class="flex items-center gap-3 w-full px-4 py-2.5 rounded-lg text-sm font-medium text-bears-text-onDark bg-bears-bg/90 border border-bears-bg-light/60 hover:bg-bears-accent/20 hover:border-bears-accent transition-all duration-200 cursor-pointer select-none"
    >
      <input
        type="checkbox"
        :checked={`${stateVariable}.includes('${category}')`}
        @change={`toggleFilter(${stateVariable}, '${category}')`}
        class="w-4 h-4 rounded border-bears-accent-muted bg-bears-bg text-bears-accent focus:ring-bears-accent focus:ring-offset-bears-bg accent-bears-accent cursor-pointer"
      />
      <span>{categoryLabels[category] || category}</span>
    </label>
  ))}
</div>
