---
interface Props {
  /**
   * Alpine.js state variable name for sort order
   * @default 'sortOrder'
   */
  stateVariable?: string;
}

const { stateVariable = 'sortOrder' } = Astro.props;
---

<div class="relative inline-block">
  <!-- Sort Trigger Button -->
  <button
    type="button"
    @click="sortMenuOpen = !sortMenuOpen"
    class="relative flex items-center gap-2 px-3 py-2 rounded-lg border border-white/20 hover:border-bears-accent/50 text-bears-text-onDark transition-all duration-200 cursor-pointer group"
    aria-label="Toggle sort options"
    :aria-expanded="sortMenuOpen"
  >
    <!-- Sort Icon with animated arrows -->
    <div class="relative w-5 h-5">
      <!-- Down arrow (newest) -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="absolute inset-0 w-5 h-5 transition-all duration-200"
        :class={`${stateVariable} === 'newest' ? 'opacity-100 text-bears-text-onDark' : 'opacity-0'`}
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h13M3 10h9m-9 5h6m4 0l4 4m0 0l4-4m-4 4V5" />
      </svg>
      <!-- Up arrow (oldest) -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="absolute inset-0 w-5 h-5 transition-all duration-200"
        :class={`${stateVariable} === 'oldest' ? 'opacity-100 text-bears-accent' : 'opacity-0'`}
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h13M3 10h9m-9 5h9m5-10v14m0 0l-4-4m4 4l4-4" />
      </svg>
      <!-- Default icon when neither active (fallback) -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="absolute inset-0 w-5 h-5 transition-all duration-200 text-bears-text-onDark group-hover:text-bears-accent"
        :class={`(${stateVariable} !== 'newest' && ${stateVariable} !== 'oldest') ? 'opacity-100' : 'opacity-0'`}
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h13M3 10h9m-9 5h6m4 0l4 4m0 0l4-4m-4 4V5" />
      </svg>
    </div>
    <span class="text-sm font-medium hidden sm:inline">Sort</span>
  </button>

  <!-- Dropdown Panel -->
  <div
    x-cloak
    x-show="sortMenuOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-3 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 -translate-y-3 scale-95"
    @click.away="sortMenuOpen = false"
    @keydown.escape.window="sortMenuOpen = false"
    class="absolute right-0 top-full mt-3 z-30 w-52 bg-black/70 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_8px_32px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.05)] overflow-hidden"
  >
    <!-- Accent Bar -->
    <div class="h-0.5 bg-gradient-to-r from-bears-accent via-bears-accent/80 to-transparent"></div>

    <!-- Panel Content -->
    <div class="p-2">
      <!-- Newest First Option -->
      <button
        type="button"
        @click={`${stateVariable} = 'newest'; sortMenuOpen = false; currentPage = 1`}
        :class={`${stateVariable} === 'newest' ? 'bg-white/10 text-bears-text-onDark' : 'text-bears-text-onDark/80 hover:bg-white/5 hover:text-bears-text-onDark'`}
        class="sort-option w-full flex items-center justify-between gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-all duration-150 cursor-pointer"
        style="animation-delay: 0ms"
      >
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4 4m0 0l4-4m-4 4V4" />
          </svg>
          <span>Newest First</span>
        </div>
        <svg
          x-show={`${stateVariable} === 'newest'`}
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="scale-0 opacity-0"
          x-transition:enter-end="scale-100 opacity-100"
          class="w-4 h-4 text-bears-accent"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </button>

      <!-- Oldest First Option -->
      <button
        type="button"
        @click={`${stateVariable} = 'oldest'; sortMenuOpen = false; currentPage = 1`}
        :class={`${stateVariable} === 'oldest' ? 'bg-white/10 text-bears-text-onDark' : 'text-bears-text-onDark/80 hover:bg-white/5 hover:text-bears-text-onDark'`}
        class="sort-option w-full flex items-center justify-between gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-all duration-150 cursor-pointer"
        style="animation-delay: 40ms"
      >
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h9m5-4v12m0 0l-4-4m4 4l4-4" />
          </svg>
          <span>Oldest First</span>
        </div>
        <svg
          x-show={`${stateVariable} === 'oldest'`}
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="scale-0 opacity-0"
          x-transition:enter-end="scale-100 opacity-100"
          class="w-4 h-4 text-bears-accent"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </button>
    </div>
  </div>
</div>
