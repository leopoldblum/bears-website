---
// Pagination component - Reusable pagination controls for filtered lists
interface Props {
  /**
   * Name of the Alpine.js method to call when changing pages
   * @default 'goToPage'
   */
  onPageChange?: string;
}

const { onPageChange = 'goToPage' } = Astro.props;
---

<!-- Only show pagination when there are multiple pages -->
<nav
  x-show="totalPages > 1"
  x-transition
  class="mt-8 sm:mt-10 lg:mt-12"
  aria-label="Pagination"
  role="navigation"
>
  <div class="flex items-center justify-center gap-2">
    <!-- Previous Button -->
    <button
      type="button"
      @click={`${onPageChange}(currentPage - 1)`}
      :disabled="currentPage === 1"
      :class="currentPage === 1 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-bears-accent hover:border-bears-accent'"
      class="px-3 py-2 sm:px-4 sm:py-2.5 rounded-lg text-sm sm:text-base font-medium transition-all duration-200 bg-bears-bg border border-bears-accent-muted text-bears-text-onDark disabled:hover:bg-bears-bg disabled:hover:border-bears-accent-muted"
      aria-label="Previous page"
    >
      <span class="hidden sm:inline">Previous</span>
      <span class="sm:hidden" aria-hidden="true">&larr;</span>
    </button>

    <!-- Page Numbers -->
    <div class="flex items-center gap-1 sm:gap-2">
      <!-- Always show first page -->
      <button
        type="button"
        @click={`${onPageChange}(1)`}
        :class="currentPage === 1 ? 'bg-bears-accent text-bears-text-onDark' : 'bg-bears-bg border border-bears-accent-muted text-bears-text-onDark hover:bg-bears-accent hover:border-bears-accent'"
        class="min-w-10 sm:min-w-11 h-10 sm:h-11 rounded-lg text-sm sm:text-base font-medium transition-all duration-200"
        :aria-current="currentPage === 1 ? 'page' : undefined"
        :aria-label="currentPage === 1 ? 'Page 1, current page' : 'Go to page 1'"
      >
        1
      </button>

      <!-- Left ellipsis -->
      <span
        x-show="currentPage > 3"
        class="px-1 text-bears-text-onDark/50"
        aria-hidden="true"
      >
        ...
      </span>

      <!-- Previous page (if not adjacent to first page) -->
      <button
        type="button"
        x-show="currentPage > 2 && currentPage !== totalPages"
        @click={`${onPageChange}(currentPage - 1)`}
        class="min-w-10 sm:min-w-11 h-10 sm:h-11 rounded-lg text-sm sm:text-base font-medium transition-all duration-200 bg-bears-bg border border-bears-accent-muted text-bears-text-onDark hover:bg-bears-accent hover:border-bears-accent"
        :aria-label="`Go to page ${currentPage - 1}`"
        x-text="currentPage - 1"
      >
      </button>

      <!-- Current page (if not first or last) -->
      <button
        type="button"
        x-show="currentPage !== 1 && currentPage !== totalPages"
        class="min-w-10 sm:min-w-11 h-10 sm:h-11 rounded-lg text-sm sm:text-base font-medium transition-all duration-200 bg-bears-accent text-bears-text-onDark"
        aria-current="page"
        :aria-label="`Page ${currentPage}, current page`"
        x-text="currentPage"
        disabled
      >
      </button>

      <!-- Next page (if not adjacent to last page) -->
      <button
        type="button"
        x-show="currentPage < totalPages - 1 && currentPage !== 1"
        @click={`${onPageChange}(currentPage + 1)`}
        class="min-w-10 sm:min-w-11 h-10 sm:h-11 rounded-lg text-sm sm:text-base font-medium transition-all duration-200 bg-bears-bg border border-bears-accent-muted text-bears-text-onDark hover:bg-bears-accent hover:border-bears-accent"
        :aria-label="`Go to page ${currentPage + 1}`"
        x-text="currentPage + 1"
      >
      </button>

      <!-- Right ellipsis -->
      <span
        x-show="currentPage < totalPages - 2"
        class="px-1 text-bears-text-onDark/50"
        aria-hidden="true"
      >
        ...
      </span>

      <!-- Always show last page (if there are multiple pages) -->
      <button
        type="button"
        x-show="totalPages > 1"
        @click={`${onPageChange}(totalPages)`}
        :class="currentPage === totalPages ? 'bg-bears-accent text-bears-text-onDark' : 'bg-bears-bg border border-bears-accent-muted text-bears-text-onDark hover:bg-bears-accent hover:border-bears-accent'"
        class="min-w-10 sm:min-w-11 h-10 sm:h-11 rounded-lg text-sm sm:text-base font-medium transition-all duration-200"
        :aria-current="currentPage === totalPages ? 'page' : undefined"
        :aria-label="currentPage === totalPages ? `Page ${totalPages}, current page` : `Go to page ${totalPages}`"
        x-text="totalPages"
      >
      </button>
    </div>

    <!-- Next Button -->
    <button
      type="button"
      @click={`${onPageChange}(currentPage + 1)`}
      :disabled="currentPage === totalPages"
      :class="currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : 'hover:bg-bears-accent hover:border-bears-accent'"
      class="px-3 py-2 sm:px-4 sm:py-2.5 rounded-lg text-sm sm:text-base font-medium transition-all duration-200 bg-bears-bg border border-bears-accent-muted text-bears-text-onDark disabled:hover:bg-bears-bg disabled:hover:border-bears-accent-muted"
      aria-label="Next page"
    >
      <span class="hidden sm:inline">Next</span>
      <span class="sm:hidden" aria-hidden="true">&rarr;</span>
    </button>
  </div>

  <!-- Page info (optional, shows on smaller screens) -->
  <div class="mt-3 text-center text-sm text-bears-text-onDark/70">
    <span x-text="`Page ${currentPage} of ${totalPages}`"></span>
  </div>
</nav>
