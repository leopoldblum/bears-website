---
// Pagination component - Reusable pagination controls for filtered lists
interface Props {
  /**
   * Name of the Alpine.js method to call when changing pages
   * @default 'goToPage'
   */
  onPageChange?: string;
}

const { onPageChange = 'goToPage' } = Astro.props;
---

<!-- Only show pagination when there are multiple pages -->
<nav
  x-show="totalPages > 1"
  x-transition
  class="w-full mt-8 sm:mt-10 lg:mt-12 flex justify-center"
  aria-label="Pagination"
  role="navigation"
>
  <div class="flex items-center gap-2">
    <!-- Previous Button -->
    <button
      type="button"
      @click={`${onPageChange}(currentPage - 1)`}
      :disabled="currentPage === 1"
      :class="currentPage === 1 ? 'opacity-40 cursor-not-allowed' : 'hover:border-bears-accent/50 hover:text-bears-text-onDark hover:cursor-pointer'"
      class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-sm font-medium transition-all duration-200 bg-transparent border border-white/15 text-bears-text-onDark/80 flex items-center justify-center"
      aria-label="Previous page"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <!-- Page Numbers -->
    <div class="flex items-center gap-1.5 sm:gap-2">
      <!-- Always show first page -->
      <button
        type="button"
        @click={`${onPageChange}(1)`}
        :class="currentPage === 1 ? 'bg-bears-accent text-white border-bears-accent shadow-[0_0_12px_rgba(197,14,31,0.35)]' : 'bg-transparent text-bears-text-onDark/80 border-white/15 hover:border-bears-accent/50 hover:text-bears-text-onDark hover:cursor-pointer'"
        class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-sm font-medium transition-all duration-200 border"
        :aria-current="currentPage === 1 ? 'page' : undefined"
        :aria-label="currentPage === 1 ? 'Page 1, current page' : 'Go to page 1'"
      >
        1
      </button>

      <!-- Left ellipsis -->
      <span
        x-show="currentPage > 3"
        class="px-0.5 text-bears-text-onDark/40 text-sm"
        aria-hidden="true"
      >
        ···
      </span>

      <!-- Previous page (if not adjacent to first page) -->
      <button
        type="button"
        x-show="currentPage > 2 && currentPage !== totalPages"
        @click={`${onPageChange}(currentPage - 1)`}
        class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-sm font-medium transition-all duration-200 bg-transparent border border-white/15 text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark hover:cursor-pointer"
        :aria-label="`Go to page ${currentPage - 1}`"
        x-text="currentPage - 1"
      >
      </button>

      <!-- Current page (if not first or last) -->
      <button
        type="button"
        x-show="currentPage !== 1 && currentPage !== totalPages"
        class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-sm font-medium transition-all duration-200 bg-bears-accent text-white border border-bears-accent shadow-[0_0_12px_rgba(197,14,31,0.35)]"
        aria-current="page"
        :aria-label="`Page ${currentPage}, current page`"
        x-text="currentPage"
        disabled
      >
      </button>

      <!-- Next page (if not adjacent to last page) -->
      <button
        type="button"
        x-show="currentPage < totalPages - 1 && currentPage !== 1"
        @click={`${onPageChange}(currentPage + 1)`}
        class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-sm font-medium transition-all duration-200 bg-transparent border border-white/15 text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark hover:cursor-pointer"
        :aria-label="`Go to page ${currentPage + 1}`"
        x-text="currentPage + 1"
      >
      </button>

      <!-- Right ellipsis -->
      <span
        x-show="currentPage < totalPages - 2"
        class="px-0.5 text-bears-text-onDark/40 text-sm"
        aria-hidden="true"
      >
        ···
      </span>

      <!-- Always show last page (if there are multiple pages) -->
      <button
        type="button"
        x-show="totalPages > 1"
        @click={`${onPageChange}(totalPages)`}
        :class="currentPage === totalPages ? 'bg-bears-accent text-white border-bears-accent shadow-[0_0_12px_rgba(197,14,31,0.35)]' : 'bg-transparent text-bears-text-onDark/80 border-white/15 hover:border-bears-accent/50 hover:text-bears-text-onDark hover:cursor-pointer'"
        class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-sm font-medium transition-all duration-200 border"
        :aria-current="currentPage === totalPages ? 'page' : undefined"
        :aria-label="currentPage === totalPages ? `Page ${totalPages}, current page` : `Go to page ${totalPages}`"
        x-text="totalPages"
      >
      </button>
    </div>

    <!-- Next Button -->
    <button
      type="button"
      @click={`${onPageChange}(currentPage + 1)`}
      :disabled="currentPage === totalPages"
      :class="currentPage === totalPages ? 'opacity-40 cursor-not-allowed' : 'hover:border-bears-accent/50 hover:text-bears-text-onDark hover:cursor-pointer'"
      class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-sm font-medium transition-all duration-200 bg-transparent border border-white/15 text-bears-text-onDark/80 flex items-center justify-center"
      aria-label="Next page"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>
</nav>
