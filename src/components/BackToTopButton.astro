---
// Back to Top Button Component
// Appears after scrolling 300px down the page
// Uses Alpine.js for scroll detection and smooth scrolling
---

<button
  x-data="{ show: false, scrolling: false }"
  @scroll.window="if (!scrolling) { show = window.scrollY > 300; } else if (window.scrollY <= 300) { scrolling = false; }"
  @click="scrolling = true; window.scrollTo({ top: 0, behavior: 'smooth' })"
  x-show="show || scrolling"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 transform translate-y-4"
  x-transition:enter-end="opacity-100 transform translate-y-0"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed bottom-4 right-4 sm:bottom-8 sm:right-8 z-30 w-12 h-12 sm:w-14 sm:h-14 bg-bears-accent hover:bg-bears-accent-muted hover:scale-110 text-white rounded-full shadow-lg transition-all duration-300 flex items-center justify-center cursor-pointer"
  aria-label="Back to top"
  type="button"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-6 h-6 sm:w-7 sm:h-7"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2.5"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M5 10l7-7m0 0l7 7m-7-7v18"
    />
  </svg>
</button>
