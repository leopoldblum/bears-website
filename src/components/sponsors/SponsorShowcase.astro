---
// SponsorShowcase - Light-bg section with all sponsor tiers as accordions (open by default)
import SponsorTier from "@landing/SponsorTier.astro";
import GradientDivider from "@reusable/GradientDivider.astro";
import type { ImageMetadata } from "astro";
import type { SponsorTier as SponsorTierType } from "@types";

interface SponsorData {
  name: string;
  logo: ImageMetadata;
  url?: string;
  tier: SponsorTierType;
  slug: string;
}

interface TierGroup {
  name: string;
  key: SponsorTierType;
  sponsors: SponsorData[];
  description?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  tiers: TierGroup[];
}

const { title, subtitle, description, tiers } = Astro.props;
const hasHeader = title || subtitle || description;

// Filter to tiers that have sponsors
const activeTiers = tiers.filter(t => t.sponsors.length > 0);

// Build Alpine.js initial state: all tiers open by default
const allTierKeys = JSON.stringify(activeTiers.map(t => t.key));
---

<section class="bg-bears-bg-light py-20 sm:py-28 lg:py-36">
  <div class="container mx-auto px-4 sm:px-8 lg:px-16">
    <!-- Section header -->
    {hasHeader && (
      <div class={`max-w-3xl mx-auto text-center ${title ? 'mb-14 sm:mb-18 lg:mb-22' : 'mb-10 sm:mb-14 lg:mb-18'}`}>
        {subtitle && (
          <p class="text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-bears-accent mb-3 sm:mb-4">
            {subtitle}
          </p>
        )}

        {title && (
          <h2 id="sponsor-tiers" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onLight mb-8 sm:mb-10 lg:mb-14">
            {title}
          </h2>
        )}

        {title && (
          <GradientDivider variant="light" class="max-w-md mx-auto mb-4 sm:mb-6" />
        )}

        {description && (
          <p class="text-sm sm:text-base lg:text-lg text-bears-text-onLight/60 leading-relaxed" data-pagefind-weight="3">
            {description}
          </p>
        )}

        {description && (
          <p class="text-sm text-bears-text-onLight/40 mt-3">
            {activeTiers.reduce((sum, t) => sum + t.sponsors.length, 0)} partners across {activeTiers.length} tiers
          </p>
        )}
      </div>
    )}

    <!-- Tier accordions -->
    <div
      class="max-w-6xl mx-auto"
      x-data={`{
        openTiers: ${allTierKeys},
        _reducedMotion: window.matchMedia('(prefers-reduced-motion: reduce)').matches,
        isOpen(key) { return this.openTiers.includes(key); },
        init() {
          this.$nextTick(() => {
            ${allTierKeys}.forEach(key => {
              const p = this.$refs['tierPanel_' + key];
              if (p) p.style.height = 'auto';
            });
          });
        },
        toggleTier(key) {
          const wasOpen = this.isOpen(key);
          this.openTiers = wasOpen
            ? this.openTiers.filter(t => t !== key)
            : [...this.openTiers, key];
          if (wasOpen) { this._closePanel(key); } else { this._openPanel(key); }
        },
        _openPanel(key) {
          const panel = this.$refs['tierPanel_' + key];
          if (!panel) return;
          if (this._reducedMotion) { panel.style.height = 'auto'; return; }
          const target = panel.scrollHeight;
          panel.style.transition = 'none';
          panel.style.height = panel.offsetHeight + 'px';
          panel.offsetHeight;
          panel.style.transition = 'height 250ms ease-out';
          panel.style.height = target + 'px';
          setTimeout(() => {
            if (this.isOpen(key)) { panel.style.transition = ''; panel.style.height = 'auto'; }
          }, 260);
        },
        _closePanel(key) {
          const panel = this.$refs['tierPanel_' + key];
          if (!panel) return;
          if (this._reducedMotion) { panel.style.height = '0px'; return; }
          panel.style.transition = 'none';
          panel.style.height = panel.offsetHeight + 'px';
          panel.offsetHeight;
          panel.style.transition = 'height 200ms ease-in';
          panel.style.height = '0px';
        }
      }`}
    >
      {activeTiers.map((tier, index) => {
        const isLast = index === activeTiers.length - 1;

        return (
          <div id={tier.key} class="scroll-mt-20">
            {/* Accordion item */}
            <div class="accordion-item" style={`animation-delay: ${index * 60}ms`}>
              {/* Accordion header */}
              <button
                type="button"
                class="flex items-center justify-between w-full text-left py-4 sm:py-5 text-lg sm:text-xl font-bold text-bears-text-onLight hover:bg-black/[0.03] transition-colors duration-200 cursor-pointer group px-2 rounded-lg"
                x-on:click={`toggleTier('${tier.key}')`}
                x-bind:aria-expanded={`isOpen('${tier.key}') ? 'true' : 'false'`}
              >
                <span>
                  <span class="text-bears-accent font-bold text-sm sm:text-base mr-2">/{String(index + 1).padStart(2, '0')}</span>
                  <span class="capitalize">{tier.name}</span>
                </span>
                <svg
                  class="w-5 h-5 flex-shrink-0 ml-3 transition-[transform,color] duration-200"
                  x-bind:class={`isOpen('${tier.key}') ? 'rotate-180 text-bears-accent' : 'rotate-0 text-bears-text-onLight/40 group-hover:text-bears-accent'`}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>

              {/* Accordion body */}
              <div
                x-ref={`tierPanel_${tier.key}`}
                class="overflow-hidden"
              >
                <div class="px-2 pb-6 sm:pb-8">
                  {/* Tier description */}
                  {tier.description && (
                    <p class="text-sm sm:text-base text-bears-text-onLight/60 leading-relaxed mb-6 sm:mb-8">
                      {tier.description}
                    </p>
                  )}

                  {/* Sponsor logos */}
                  <SponsorTier sponsors={tier.sponsors} tier={tier.key} />
                </div>
              </div>
            </div>

            {/* Divider between tiers */}
            {!isLast && (
              <GradientDivider variant="light" class="max-w-3xl mx-auto my-6 sm:my-8" />
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
