---
// Testimonials - Testimonial Carousel Component
// Sources entries from the `testimonials` collection, each of which references
// a person from the `people` collection. The query projects locale-correct
// role + quote and keeps the people-entry shape so loadCollectionImages can
// consume the result directly.
import Carousel from "@mdx/Carousel.astro";
import TestimonialCard from "./TestimonialCard.astro";
import { loadCollectionImages } from "@utils/imageLoader";
import { getTestimonials, getPageContent } from "@utils/contentQueries";
import { type Locale } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const sortedPeople = await getTestimonials(locale);

const peopleWithLoadedImages = await loadCollectionImages(
  sortedPeople,
  "person",
);

const testimonials = peopleWithLoadedImages.map((person) => ({
  quote: person.data.quote ?? "",
  name: person.data.name,
  role: person.data.role,
  image: person.loadedImage,
}));

const content = await getPageContent('landing/testimonials', locale);
---

<section
  id="testimonials-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 pt-12 sm:pt-14 lg:pt-20 pb-20 sm:pb-24 lg:pb-32 scroll-mt-20"
>
  <!-- Heading -->
  <h2
    class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-8 sm:mb-10 lg:mb-14"
  >
    {content?.data.title}
  </h2>

  <!-- Testimonial Carousel -->
  <Carousel autoScroll={true} autoScrollInterval={5000} height="auto">
    {
      testimonials.map((testimonial) => (
        <TestimonialCard
          quote={testimonial.quote}
          name={testimonial.name}
          role={testimonial.role}
          image={testimonial.image}
        />
      ))
    }
  </Carousel>
</section>
