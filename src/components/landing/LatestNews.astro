---
// LatestNews component - Shows latest news from BEARS
import PostShowcase from "@posts-catalog/PostShowcase.astro";
import Button from "@mdx/Button.astro";
import type { PostType } from '@types';
import { loadCollectionImages } from '@utils/imageLoader';
import { getLatestPosts, sortByDateDesc, getPageContent, getLatestInstagramPosts, stripLocaleFromSlug } from '@utils/contentQueries';
import { type Locale, localizeUrl } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const content = await getPageContent('landing/latest-news', locale);
const instagramPosts = await getLatestInstagramPosts(3);

// Derive Instagram URL from footer social links (single source of truth)
const socialContent = await getPageContent('site/social-links', locale);
const instagramUrl = socialContent?.data.socialLinks?.find((l: { platform: string }) => l.platform === 'instagram')?.url;

// Get latest 4 posts (filtered and sorted)
const latestPosts = await getLatestPosts(4, locale);

// Separate events and projects for batch image loading
const events = latestPosts.filter(post => post._collectionType === 'events');
const projects = latestPosts.filter(post => post._collectionType === 'projects');

// Load images for events and projects
const eventsWithImages = await loadCollectionImages(events, 'event');
const projectsWithImages = await loadCollectionImages(projects, 'project');

// Merge and sort by date again
const allPostsWithImages = sortByDateDesc([...eventsWithImages, ...projectsWithImages]);

// Build news items for PostShowcase
const newsItems = allPostsWithImages.map((post) => {
  const postType: PostType = post._collectionType;
  const href = localizeUrl(`/${postType}/${stripLocaleFromSlug(post.slug)}`, locale);

  return {
    imageData: post.loadedImage,
    imageAlt: post.data.title,
    date: post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
    title: post.data.title,
    description: post.data.description,
    href: href,
    postType: postType,
  };
});
---

<section
  id="latest-news-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-20 sm:py-24 lg:py-32 scroll-mt-20"
  x-data="{
    showAll: false,
    hideAndScroll() {
      this.showAll = false;
      const section = document.getElementById('latest-news-section');
      if (section) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }"
>
  <!-- Header - left aligned -->
  <h2 id="latest-news" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-8 sm:mb-10 lg:mb-14 scroll-mt-20">
    {content?.data.title}
  </h2>

  <div data-pagefind-ignore>
    <!-- Description text -->
    {content?.data.description && (
      <p class="text-base sm:text-lg text-bears-text-onDark leading-relaxed max-w-3xl mb-10 sm:mb-14">
        {content.data.description}
      </p>
    )}

    <!-- Learn More Button -->
    {content?.data.buttonText && content?.data.buttonHref && (
      <div>
        <Button variant="primary" href={localizeUrl(content.data.buttonHref, locale)}>{content.data.buttonText}</Button>
      </div>
    )}
  </div>

  <!-- News Preview Grid -->
  <div data-pagefind-ignore class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 my-10 sm:my-14 px-4 sm:px-0">
    {newsItems.map((news, index) => (
      index < 2 ? (
        <PostShowcase
          coverImage={news.imageData}
          imageAlt={news.imageAlt}
          date={news.date}
          title={news.title}
          description={news.description}
          href={news.href}
        />
      ) : (
        <div x-show="showAll" x-transition.duration.300ms class="lg:block!">
          <PostShowcase
            coverImage={news.imageData}
            imageAlt={news.imageAlt}
            date={news.date}
            title={news.title}
            description={news.description}
            href={news.href}
          />
        </div>
      )
    ))}
  </div>

  <!-- Show All / Show Less Button - Only visible on mobile -->
  <div data-pagefind-ignore class="flex justify-center mt-8 lg:hidden">
    <button
      x-show="!showAll"
      @click="showAll = true"
      type="button"
      class="group flex items-center justify-center gap-2.5 px-6 py-3 rounded-lg border border-white/15 text-sm text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark transition-all duration-200 cursor-pointer"
    >
      <span>Show more</span>
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
    <button
      x-show="showAll"
      x-cloak
      @click="hideAndScroll()"
      type="button"
      class="group flex items-center justify-center gap-2.5 px-6 py-3 rounded-lg border border-white/15 text-sm text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark transition-all duration-200 cursor-pointer"
    >
      <span>Show less</span>
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-y-0.5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
  </div>

  <!-- Instagram Posts - newest post on mobile, 2 on lg, 3 on xl -->
  {instagramPosts.length > 0 && (
    <div data-pagefind-ignore class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 items-center gap-6 lg:gap-8 mt-10 lg:mt-14">
      {instagramPosts.map((post, index) => (
        <div class:list={["instagram-feed-card rounded-xl border border-white/10 bg-white/[0.03] backdrop-blur-sm shadow-[0_4px_12px_rgba(0,0,0,0.4)] overflow-hidden transition-all duration-300 lg:hover:border-bears-accent/30 lg:hover:shadow-[0_8px_24px_rgba(0,0,0,0.5),0_0_20px_rgba(197,14,31,0.15)] lg:hover:scale-[1.02]", { "hidden lg:block": index === 1 }, { "hidden xl:block": index === 2 }]}>
          <blockquote
            class="instagram-media"
            data-instgrm-permalink={post.data.url.endsWith('/') ? post.data.url : `${post.data.url}/`}
            data-instgrm-version="14"
            style="margin: 0; padding: 0; width: 100%;"
          >
            <div style="padding: 16px;">
              <a
                href={post.data.url}
                target="_blank"
                rel="noopener noreferrer"
                style="color: #3897f0; text-decoration: none;"
              >
                View on Instagram
              </a>
            </div>
          </blockquote>
        </div>
      ))}
    </div>
  )}

  <!-- Instagram CTA Crosslink -->
  {instagramUrl && (
    <div data-pagefind-ignore class="flex justify-center mt-10 lg:mt-14">
      <a
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 px-6 py-3 rounded-full border border-white/15 text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark transition-all duration-200"
      >
        <svg class="w-5 h-5 fill-current transition-colors duration-200 group-hover:text-bears-accent" viewBox="0 0 24 24">
          <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z" />
        </svg>
        <span class="text-sm sm:text-base font-medium">{content.data.instagramButtonText}</span>
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  )}

</section>

<style is:global>
  .instagram-feed-card iframe {
    margin: 0 !important;
    display: block;
    min-width: 0 !important;
    max-width: 100% !important;
    filter: brightness(0.96) saturate(0.95);
  }
</style>

<script>
  if (!document.querySelector('script[src*="instagram.com/embed.js"]')) {
    const script = document.createElement('script');
    script.src = 'https://www.instagram.com/embed.js';
    script.async = true;
    document.body.appendChild(script);
  } else if (window.instgrm) {
    window.instgrm.Embeds.process();
  }
</script>
