---
// LatestNews component - Shows latest news from BEARS
import PostShowcase from "@posts-catalog/PostShowcase.astro";
import Button from "@mdx/Button.astro";
import type { PostType } from '@types';
import { loadCollectionImages } from '@utils/imageLoader';
import { getLatestPosts, sortByDateDesc, getPageContent, getLatestInstagramPosts } from '@utils/contentQueries';

const content = await getPageContent('landing/latest-news');
const instagramPosts = await getLatestInstagramPosts(3);

// Get latest 4 posts (filtered and sorted)
const latestPosts = await getLatestPosts(4);

// Separate events and projects for batch image loading
const events = latestPosts.filter(post => post._collectionType === 'events');
const projects = latestPosts.filter(post => post._collectionType === 'projects');

// Load images for events and projects
const eventsWithImages = await loadCollectionImages(events, 'event');
const projectsWithImages = await loadCollectionImages(projects, 'project');

// Merge and sort by date again
const allPostsWithImages = sortByDateDesc([...eventsWithImages, ...projectsWithImages]);

// Build news items for PostShowcase
const newsItems = allPostsWithImages.map((post) => {
  const postType: PostType = post._collectionType;
  const href = `/${postType}/${post.slug}`;

  return {
    imageData: post.loadedImage,
    imageAlt: post.data.title,
    date: post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
    title: post.data.title,
    description: post.data.description,
    href: href,
    postType: postType,
  };
});
---

<section
  id="latest-news-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-20 sm:py-24 lg:py-32 scroll-mt-20"
  x-data="{
    showAll: false,
    hideAndScroll() {
      this.showAll = false;
      const section = document.getElementById('latest-news-section');
      if (section) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }"
>
  <!-- Header - left aligned -->
  <h2 id="latest-news" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-8 sm:mb-10 lg:mb-14 scroll-mt-20">
    {content?.data.title}
  </h2>

  <!-- Description text -->
  {content?.data.description && (
    <p class="text-base sm:text-lg text-bears-text-onDark leading-relaxed max-w-3xl mb-10 sm:mb-14">
      {content.data.description}
    </p>
  )}

  <!-- Learn More Button -->
  {content?.data.buttonText && content?.data.buttonHref && (
    <div>
      <Button variant="primary" href={content.data.buttonHref}>{content.data.buttonText}</Button>
    </div>
  )}

  <!-- News Preview Grid -->
  <div data-pagefind-ignore class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 my-10 sm:my-14 px-4 sm:px-0">
    {newsItems.map((news, index) => (
      index < 2 ? (
        <PostShowcase
          coverImage={news.imageData}
          imageAlt={news.imageAlt}
          date={news.date}
          title={news.title}
          description={news.description}
          href={news.href}
        />
      ) : (
        <div x-show="showAll" x-transition.duration.300ms class="lg:block!">
          <PostShowcase
            coverImage={news.imageData}
            imageAlt={news.imageAlt}
            date={news.date}
            title={news.title}
            description={news.description}
            href={news.href}
          />
        </div>
      )
    ))}
  </div>

  <!-- Instagram Posts - Only visible on lg+ screens -->
  {instagramPosts.length > 0 && (
    <div class="hidden lg:grid lg:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8 mt-10 lg:mt-14">
      {instagramPosts.map((post, index) => (
        <div class:list={["instagram-feed-card rounded-xl border border-white/10 bg-white/[0.03] backdrop-blur-sm shadow-[0_4px_12px_rgba(0,0,0,0.4)] overflow-hidden px-6 pt-6 pb-3 transition-all duration-300 lg:hover:border-bears-accent/30 lg:hover:shadow-[0_8px_24px_rgba(0,0,0,0.5),0_0_20px_rgba(197,14,31,0.15)] lg:hover:scale-[1.02]", { "hidden xl:block": index === 2 }]}>
          <blockquote
            class="instagram-media"
            data-instgrm-permalink={post.data.url.endsWith('/') ? post.data.url : `${post.data.url}/`}
            data-instgrm-version="14"
            style="margin: 0; padding: 0; width: 100%;"
          >
            <div style="padding: 16px;">
              <a
                href={post.data.url}
                target="_blank"
                rel="noopener noreferrer"
                style="color: #3897f0; text-decoration: none;"
              >
                View on Instagram
              </a>
            </div>
          </blockquote>
        </div>
      ))}
    </div>
  )}

  <!-- Show All / Show Less Button - Only visible on mobile -->
  <div class="flex justify-center mt-8 lg:hidden">
    <button
      x-show="!showAll"
      @click="showAll = true"
      type="button"
      class="group flex items-center justify-center gap-2.5 px-6 py-3 rounded-lg border border-white/15 text-sm text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark transition-all duration-200 cursor-pointer"
    >
      <span>Show more</span>
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
    <button
      x-show="showAll"
      x-cloak
      @click="hideAndScroll()"
      type="button"
      class="group flex items-center justify-center gap-2.5 px-6 py-3 rounded-lg border border-white/15 text-sm text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark transition-all duration-200 cursor-pointer"
    >
      <span>Show less</span>
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-y-0.5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
  </div>
</section>

<style>
  .instagram-feed-card iframe {
    margin: 0 !important;
    display: block;
    min-width: 0 !important;
    max-width: 100% !important;
  }
</style>

<script>
  if (!document.querySelector('script[src*="instagram.com/embed.js"]')) {
    const script = document.createElement('script');
    script.src = 'https://www.instagram.com/embed.js';
    script.async = true;
    document.body.appendChild(script);
  } else if (window.instgrm) {
    window.instgrm.Embeds.process();
  }
</script>
