---
// LatestNews component - Shows latest news from BEARS
import PostShowcase from "@posts-catalog/PostShowcase.astro";
import Button from "@mdx/Button.astro";
import type { PostType } from '@types';
import { loadCollectionImages } from '@utils/imageLoader';
import { getLatestPosts, sortByDateDesc, getPageContent } from '@utils/contentQueries';

const content = await getPageContent('landing/latest-news');

// Get latest 4 posts (filtered and sorted)
const latestPosts = await getLatestPosts(4);

// Separate events and projects for batch image loading
const events = latestPosts.filter(post => post._collectionType === 'events');
const projects = latestPosts.filter(post => post._collectionType === 'projects');

// Load images for events and projects
const eventsWithImages = await loadCollectionImages(events, 'event');
const projectsWithImages = await loadCollectionImages(projects, 'project');

// Merge and sort by date again
const allPostsWithImages = sortByDateDesc([...eventsWithImages, ...projectsWithImages]);

// Build news items for PostShowcase
const newsItems = allPostsWithImages.map((post) => {
  const postType: PostType = post._collectionType;
  const href = `/${postType}/${post.slug}`;

  return {
    imageData: post.loadedImage,
    imageAlt: post.data.title,
    date: post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
    title: post.data.title,
    description: post.data.description,
    href: href,
    postType: postType,
  };
});
---

<section
  id="latest-news-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24"
  x-data="{
    showAll: false,
    hideAndScroll() {
      this.showAll = false;
      const section = document.getElementById('latest-news-section');
      if (section) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }"
>
  <!-- Header - left aligned -->
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-6 sm:mb-8 lg:mb-12">
    {content?.data.title}
  </h2>

  <!-- Description text -->
  {content?.data.description && (
    <p class="text-base sm:text-lg text-bears-text-onDark leading-relaxed max-w-3xl mb-8 sm:mb-12">
      {content.data.description}
    </p>
  )}

  <!-- Learn More Button -->
  {content?.data.buttonText && content?.data.buttonHref && (
    <div>
      <Button variant="primary" href={content.data.buttonHref}>{content.data.buttonText}</Button>
    </div>
  )}

  <!-- News Preview Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 my-8 sm:my-12 px-4 sm:px-0">
    {newsItems.map((news, index) => (
      index < 2 ? (
        <PostShowcase
          coverImage={news.imageData}
          imageAlt={news.imageAlt}
          date={news.date}
          title={news.title}
          description={news.description}
          href={news.href}
        />
      ) : (
        <div x-show="showAll" x-transition.duration.300ms class="lg:block!">
          <PostShowcase
            coverImage={news.imageData}
            imageAlt={news.imageAlt}
            date={news.date}
            title={news.title}
            description={news.description}
            href={news.href}
          />
        </div>
      )
    ))}
  </div>

  <!-- Show All Button - Only visible on mobile when not all posts are shown -->
  <div x-show="!showAll" class="flex justify-center mt-8 lg:hidden">
    <Button variant="primary" size="large" onClick="showAll = true">
      Show More
    </Button>
  </div>

  <!-- Show Less Button - Only visible on mobile when all posts are shown -->
  <div x-show="showAll" class="flex justify-center mt-8 lg:hidden">
    <Button variant="primary" size="large" onClick="hideAndScroll()">
      Show Less
    </Button>
  </div>
</section>
