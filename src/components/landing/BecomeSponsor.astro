---
// BecomeSponsor component - Displays sponsor showcase with tier-based system
import SponsorTier from "./SponsorTier.astro";
import Button from "@mdx/Button.astro";
import { sponsorLogos } from "@utils/imageGlobs";
import { loadImage, defaultSponsorImage } from "@utils/imageLoader";
import { getPageContent, getSponsorsByTier } from "@utils/contentQueries";

const content = await getPageContent("landing/become-sponsor");

// Use the shared utility for grouping + sorting
const { diamond, platinum, gold, silver, bronze } = await getSponsorsByTier();

// Load images for a tier's sponsors
async function loadTierImages(sponsors: typeof diamond) {
  return Promise.all(
    sponsors.map(async (sponsor) => {
      const tier = sponsor.id.split("/")[0];
      const logoData =
        (await loadImage({
          glob: sponsorLogos,
          imagePath: `/src/assets/sponsors/${tier}/${sponsor.data.logo}`,
          fallbackImage: defaultSponsorImage,
          context: {
            itemTitle: sponsor.data.name,
            itemSlug: sponsor.slug,
          },
        })) || defaultSponsorImage;

      return {
        ...sponsor.data,
        logo: logoData,
        slug: sponsor.slug,
        tier: tier as "bronze" | "silver" | "gold" | "platinum" | "diamond",
      };
    }),
  );
}

const [
  diamondSponsors,
  platinumSponsors,
  goldSponsors,
  silverSponsors,
  bronzeSponsors,
] = await Promise.all([
  loadTierImages(diamond),
  loadTierImages(platinum),
  loadTierImages(gold),
  loadTierImages(silver),
  loadTierImages(bronze),
]);
---

<section class="bg-bears-bg-light py-20 sm:py-24 lg:py-32">
  <div class="container mx-auto px-4 sm:px-8 lg:px-16">
    <!-- Headline -->
    <h2
      class="text-3xl sm:text-4xl lg:text-5xl font-bold text-center text-bears-text-onLight mb-14 sm:mb-18 lg:mb-22"
    >
      {content?.data.title}
    </h2>

    <!-- Diamond Sponsors Tier -->
    <SponsorTier sponsors={diamondSponsors} tier="diamond" />

    <!-- Divider: Diamond to other tiers -->
    {
      diamondSponsors.length > 0 &&
        (platinumSponsors.length > 0 || goldSponsors.length > 0) && (
          <hr class="w-full max-w-3xl mx-auto border-t border-bears-text-onLight opacity-20 my-10 sm:my-12 lg:my-16" />
        )
    }

    <!-- Platinum Sponsors Tier -->
    <SponsorTier sponsors={platinumSponsors} tier="platinum" />

    <!-- Divider: Platinum to other tiers -->
    {
      platinumSponsors.length > 0 && goldSponsors.length > 0 && (
        <hr class="w-full max-w-3xl mx-auto border-t border-bears-text-onLight opacity-20 my-10 sm:my-12 lg:my-16" />
      )
    }

    <!-- Gold Sponsors Tier -->
    <SponsorTier sponsors={goldSponsors} tier="gold" />

    <!-- Description text below logos -->
    {
      content?.data.description && (
        <p class="text-sm sm:text-base text-bears-text-onLight text-center opacity-70 max-w-2xl mx-auto mt-14 sm:mt-18 lg:mt-22 mb-6 sm:mb-8">
          {content.data.description}
        </p>
      )
    }

    <!-- Learn more button -->
    {
      content?.data.buttonText && content?.data.buttonHref && (
        <div class="flex justify-center">
          <Button variant="inverse" size="large" href={content.data.buttonHref}>
            {content.data.buttonText}
          </Button>
        </div>
      )
    }
  </div>
</section>
