---
// BecomeSponsor component - Displays sponsor showcase with tier-based system
import SponsorTier from "./SponsorTier.astro";
import Button from "@mdx/Button.astro";
import { sponsorLogos } from "@utils/imageGlobs";
import { loadImage, resolveImagePath, defaultSponsorImage } from "@utils/imageLoader";
import { getPageContent, getSponsorsByTier } from "@utils/contentQueries";
import { type Locale } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const content = await getPageContent("landing/become-sponsor", locale);

// Use the shared utility for grouping + sorting
const allTiers = await getSponsorsByTier();

// Show the top 3 non-empty tiers, sorted from most important to least
const tierOrder = ['diamond', 'platinum', 'gold', 'silver', 'bronze'] as const;
const activeTierNames = tierOrder
  .filter(t => allTiers[t].length > 0)
  .slice(0, 3);

// Load images for a tier's sponsors
async function loadTierImages(sponsors: typeof allTiers.diamond) {
  return Promise.all(
    sponsors.map(async (sponsor) => {
      const tier = sponsor.id.split("/")[0];
      const logoData =
        (await loadImage({
          glob: sponsorLogos,
          imagePath: resolveImagePath(`/src/assets/sponsors/${tier}`, sponsor.data.logo),
          fallbackImage: defaultSponsorImage,
          context: {
            itemTitle: sponsor.data.name,
            itemSlug: sponsor.slug,
          },
        })) || defaultSponsorImage;

      return {
        ...sponsor.data,
        logo: logoData,
        slug: sponsor.slug,
        tier: tier as "bronze" | "silver" | "gold" | "platinum" | "diamond",
      };
    }),
  );
}

const displayTiers = await Promise.all(
  activeTierNames.map(async (tierName) => ({
    name: tierName,
    sponsors: await loadTierImages(allTiers[tierName]),
  })),
);
---

<section id="our-sponsors-section" class="bg-bears-bg-light py-20 sm:py-24 lg:py-32 scroll-mt-20">
  <div class="container mx-auto px-4 sm:px-8 lg:px-16">
    <!-- Headline -->
    <h2
      class="text-3xl sm:text-4xl lg:text-5xl font-bold text-center text-bears-text-onLight mb-14 sm:mb-18 lg:mb-22"
    >
      {content?.data.title}
    </h2>

    <!-- Sponsor logos — ignored by search to avoid duplicating sponsors page -->
    <div data-pagefind-ignore>
    {displayTiers.map((tier, i) => (
      <>
        {i > 0 && (
          <hr class="w-full max-w-3xl mx-auto border-t border-bears-text-onLight opacity-20 my-10 sm:my-12 lg:my-16" />
        )}
        <SponsorTier sponsors={tier.sponsors} tier={tier.name} />
      </>
    ))}
    </div>

    <div data-pagefind-ignore>
      <!-- Description text below logos -->
      {
        content?.data.description && (
          <p class="text-sm sm:text-base text-bears-text-onLight text-center opacity-70 max-w-2xl mx-auto mt-14 sm:mt-18 lg:mt-22 mb-6 sm:mb-8">
            {content.data.description}
          </p>
        )
      }

      <!-- Learn more button -->
      {
        content?.data.buttonText && content?.data.buttonHref && (
          <div class="flex justify-center">
            <Button variant="inverse" size="large" href={content.data.buttonHref}>
              {content.data.buttonText}
            </Button>
          </div>
        )
      }
    </div>
  </div>
</section>
