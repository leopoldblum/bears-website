---
// Testimonial Card Component
import Img from "@mdx/Img.astro";
import type { ImageMetadata } from "astro";

interface Props {
  quote: string;
  name: string;
  role: string;
  image: ImageMetadata;
}

const { quote, name, role, image } = Astro.props;
---

<div
  class="w-full bg-[rgba(255,255,255,0.03)] rounded-2xl border border-white/10 shadow-[0_4px_12px_rgba(0,0,0,0.4)] py-16 sm:py-20 lg:py-24 px-6 sm:px-8 lg:px-10"
>
  <div
    class="flex flex-col lg:flex-row gap-8 lg:gap-10 xl:gap-12 lg:items-center"
  >
    <!-- Left: Image (1/3 width on desktop) -->
    <div
      class="testimonial-image-wrapper shrink-0 mx-auto lg:mx-0 w-40 sm:w-48 lg:w-1/3 aspect-square overflow-hidden rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.3)] bg-white"
    >
      <Img
        src={image}
        alt={name}
        fill={true}
        loading="lazy"
        sizes="(min-width: 1024px) 16vw, 192px"
        enableClickToEnlarge={false}
      />
    </div>

<style>
  .testimonial-image-wrapper :global(img) {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
  }
</style>

    <!-- Right: Content (2/3 width on desktop) -->
    <div
      class="flex-1 lg:w-2/3 flex flex-col justify-center text-center lg:text-left"
    >
      <!-- Name -->
      <h3
        class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-bears-text-onDark mb-2"
      >
        {name}
      </h3>

      <!-- Role -->
      <p
        class="text-sm sm:text-base lg:text-lg text-bears-text-onDark/60 mb-4 lg:mb-6"
      >
        {role}
      </p>

      <!-- Quote -->
      <p
        class="text-base sm:text-lg lg:text-xl text-bears-text-onDark leading-relaxed italic"
      >
        "{quote}"
      </p>
    </div>
  </div>
</div>
