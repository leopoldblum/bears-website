---
import Button from "@mdx/Button.astro";
import { getLatestInstagramPosts, getPageContent } from "@utils/contentQueries";

const content = await getPageContent('landing-page/instagram-feed');
const instagramPosts = await getLatestInstagramPosts(3);
---

<section
  id="instagram-feed-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24"
>
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-6 sm:mb-8 lg:mb-12">
    {content?.data.title}
  </h2>

  {content?.data.description && (
    <p class="text-base sm:text-lg text-bears-text-onDark leading-relaxed max-w-3xl mb-8 sm:mb-12">
      {content.data.description}
    </p>
  )}

  {instagramPosts.length > 0 && (
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 max-w-[85%] mx-auto">
      {instagramPosts.map((post) => (
        <div class="rounded-xl border border-white/10 bg-white/[0.03] backdrop-blur-sm shadow-[0_4px_12px_rgba(0,0,0,0.4)] overflow-hidden p-5 sm:p-6 transition-all duration-300 lg:hover:border-bears-accent/30 lg:hover:shadow-[0_8px_24px_rgba(0,0,0,0.5),0_0_20px_rgba(197,14,31,0.15)] lg:hover:scale-[1.02]">
          <blockquote
            class="instagram-media"
            data-instgrm-permalink={post.data.url.endsWith('/') ? post.data.url : `${post.data.url}/`}
            data-instgrm-version="14"
            style="margin: 0; padding: 0; width: 100%;"
          >
            <div style="padding: 16px;">
              <a
                href={post.data.url}
                target="_blank"
                rel="noopener noreferrer"
                style="color: #3897f0; text-decoration: none;"
              >
                View on Instagram
              </a>
            </div>
          </blockquote>
        </div>
      ))}
    </div>
  )}

  {content?.data.buttonText && content?.data.buttonHref && (
    <div class="flex justify-center mt-8 sm:mt-12">
      <Button variant="primary" size="large" href={content.data.buttonHref}>
        {content.data.buttonText}
      </Button>
    </div>
  )}
</section>

<script>
  if (!document.querySelector('script[src*="instagram.com/embed.js"]')) {
    const script = document.createElement('script');
    script.src = 'https://www.instagram.com/embed.js';
    script.async = true;
    document.body.appendChild(script);
  } else if (window.instgrm) {
    window.instgrm.Embeds.process();
  }
</script>
