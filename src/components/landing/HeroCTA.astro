---
interface HeroCTAItem {
  title: string;
  description: string;
  href: string;
}

interface Props {
  ctas: HeroCTAItem[];
}

const { ctas } = Astro.props;

if (ctas.length === 0) return;

const gridColsClass: Record<number, string> = {
  1: 'lg:grid-cols-1',
  2: 'lg:grid-cols-2',
  3: 'lg:grid-cols-3',
  4: 'lg:grid-cols-4',
};
const gridCols = gridColsClass[ctas.length] || 'lg:grid-cols-3';
const mobileGridCols = ctas.length === 1 ? 'grid-cols-1' : 'grid-cols-2';

function getBorderClasses(index: number): string {
  if (ctas.length === 1) return '';

  const classes: string[] = ['border-white/[0.06]'];
  const total = ctas.length;
  const isLeftCol = index % 2 === 0;
  const row = Math.floor(index / 2);
  const totalRows = Math.ceil(total / 2);
  const hasRightNeighbor = isLeftCol && index + 1 < total;
  const isLastRow = row === totalRows - 1;
  const isLast = index === total - 1;

  if (hasRightNeighbor) classes.push('border-r');
  if (!isLastRow) classes.push('border-b');

  classes.push('lg:border-b-0');
  if (!hasRightNeighbor && !isLast) classes.push('lg:border-r');

  return classes.join(' ');
}
---

<div class="relative mt-auto pb-3 sm:pb-5 lg:pb-12">
  <div
    class:list={[
      'grid',
      mobileGridCols,
      gridCols,
      'group/grid rounded-xl overflow-hidden bg-black/20 backdrop-blur-md border border-white/[0.06] max-w-6xl mx-auto',
    ]}
  >
    {ctas.map((cta, index) => (
      <a
        href={cta.href}
        class:list={[
          'group/card block px-3 py-2.5 sm:p-4 lg:p-5',
          'transition-all duration-300 ease-out',
          'lg:group-hover/grid:opacity-50 lg:hover:!opacity-100',
          'lg:hover:bg-white/[0.05]',
          getBorderClasses(index),
        ]}
      >
        <div class="flex items-baseline justify-between gap-2">
          <p class="text-sm sm:text-base lg:text-xl font-semibold transition-colors duration-300 text-bears-accent lg:group-hover/card:text-white">
            {cta.title}
          </p>
          <span
            class="text-white/40 text-xs flex-shrink-0 transition-all duration-300 lg:opacity-0 lg:-translate-x-1 lg:group-hover/card:opacity-100 lg:group-hover/card:translate-x-0"
            aria-hidden="true"
          >
            &rarr;
          </span>
        </div>
        <p class="hidden sm:block mt-1.5 text-sm leading-relaxed transition-colors duration-300 text-white/45 lg:group-hover/card:text-white/70">
          {cta.description}
        </p>
      </a>
    ))}
  </div>
</div>
