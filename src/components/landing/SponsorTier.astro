---
// SponsorTier component - Renders a tier of sponsors with tier-specific styling
import Img from "@mdx/Img.astro";
import type { ImageMetadata } from "astro";
import type { SponsorTier } from "@types";

interface Props {
  sponsors: Array<{
    name: string;
    logo: ImageMetadata;
    url?: string;
    tier: SponsorTier;
    slug: string;
  }>;
  tier: SponsorTier;
}

const { sponsors, tier } = Astro.props;

// Define tier-specific styling configuration
const tierConfig = {
  diamond: {
    sizeClasses: "h-20 sm:h-24 lg:h-28 w-auto",
    gapClasses: "gap-10 sm:gap-14 lg:gap-20",
    marginClasses: "mb-6 sm:mb-8",
    hoverClasses: "hover:scale-110 hover:drop-shadow-[0_0_12px_rgba(197,14,31,0.25)]",
    sizes: "(min-width: 1024px) 720px, (min-width: 640px) 580px, 440px",
  },
  platinum: {
    sizeClasses: "h-16 sm:h-20 lg:h-24 w-auto",
    gapClasses: "gap-9 sm:gap-12 lg:gap-18",
    marginClasses: "mb-6 sm:mb-8",
    sizes: "(min-width: 1024px) 600px, (min-width: 640px) 480px, 360px",
  },
  gold: {
    sizeClasses: "h-14 sm:h-16 lg:h-20 w-auto",
    gapClasses: "gap-8 sm:gap-10 lg:gap-12",
    marginClasses: "mb-6 sm:mb-8",
    sizes: "(min-width: 1024px) 520px, (min-width: 640px) 400px, 300px",
  },
  silver: {
    sizeClasses: "h-12 sm:h-14 lg:h-16 w-auto",
    gapClasses: "gap-6 sm:gap-8 lg:gap-10",
    marginClasses: "mb-6 sm:mb-8",
    sizes: "(min-width: 1024px) 420px, (min-width: 640px) 340px, 260px",
  },
  bronze: {
    sizeClasses: "h-10 sm:h-12 lg:h-14 w-auto",
    gapClasses: "gap-4 sm:gap-6 lg:gap-8",
    marginClasses: "mb-10 sm:mb-12 lg:mb-16",
    sizes: "(min-width: 1024px) 360px, (min-width: 640px) 280px, 200px",
  },
};

const config = tierConfig[tier] || tierConfig.bronze;
const hoverClasses = config.hoverClasses ?? "hover:scale-110 hover:opacity-80";
---

{
  sponsors.length > 0 && (
    <div
      class={`flex flex-wrap justify-center items-center ${config.gapClasses} ${config.marginClasses}`}
    >
      {sponsors.map((sponsor, sponsorIndex) => {
        const content = (
          <Img
            src={sponsor.logo}
            alt={sponsor.name}
            class={`${config.sizeClasses} rounded-none`}
            loading="lazy"
            sizes={config.sizes}
            enableClickToEnlarge={false}
          />
        );

        return sponsor.url ? (
          <a
            href={sponsor.url}
            class={`sponsor-card inline-block ${hoverClasses} transition-all duration-300`}
            style={`animation-delay: ${sponsorIndex * 60}ms`}
            target="_blank"
            rel="noopener noreferrer"
          >
            {content}
          </a>
        ) : (
          <div
            class="sponsor-card inline-block"
            style={`animation-delay: ${sponsorIndex * 60}ms`}
          >
            {content}
          </div>
        );
      })}
    </div>
  )
}
