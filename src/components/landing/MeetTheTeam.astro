---
// MeetTheTeam component
import type { ImageMetadata } from "astro";
import Img from "@mdx/Img.astro";
import { loadImage, getDefaultFaceImage, resolveImagePath } from "@utils/imageLoader";
import { peopleImages } from "@utils/imageGlobs";
import { getMeetTheTeamProjectsWithPeople, getPageContent } from "@utils/contentQueries";
import { type Locale } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// Each entry already has the resolved person + locale-correct displayRole.
const entries = await getMeetTheTeamProjectsWithPeople(locale);

const defaultFaceImage = await getDefaultFaceImage();

const projects = await Promise.all(
  entries.map(async ({ project, person, displayName, displayRole }) => {
    const portrait = await loadImage({
      glob: peopleImages,
      imagePath: resolveImagePath('/src/assets/people', person.data.coverImage),
      fallbackImage: defaultFaceImage,
      context: {
        itemTitle: project.data.title,
        itemSlug: project.slug,
      },
    });
    return {
      project,
      displayName,
      displayRole,
      loadedImage: portrait as ImageMetadata,
    };
  })
);

const content = await getPageContent('landing/meet-the-team', locale);
---

<section
  id="meet-the-team-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-20 sm:py-24 lg:py-32 scroll-mt-20"
>
  <!-- Headline in top left -->
  <h2
    class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-8 sm:mb-10 lg:mb-14 text-bears-text-onDark"
  >
    {content?.data.title}
  </h2>

  <!-- Responsive layout: flex-col for lg, grid for xl -->
  <div
    data-pagefind-ignore
    class="flex flex-col gap-6 lg:gap-8 xl:grid xl:grid-cols-[120px_minmax(0,2fr)_minmax(0,1fr)]"
    x-data="{
      activeIndex: 0,
      _reducedMotion: window.matchMedia('(prefers-reduced-motion: reduce)').matches,
      _openPanel(i) {
        const panel = this.$refs['teamPanel' + i];
        if (!panel) return;
        if (this._reducedMotion) { panel.style.height = 'auto'; return; }
        const target = panel.scrollHeight;
        panel.style.transition = 'none';
        panel.style.height = panel.offsetHeight + 'px';
        panel.offsetHeight;
        panel.style.transition = 'height 250ms ease';
        panel.style.height = target + 'px';
        setTimeout(() => {
          if (this.activeIndex === i) { panel.style.transition = ''; panel.style.height = 'auto'; }
        }, 260);
      },
      _closePanel(i) {
        const panel = this.$refs['teamPanel' + i];
        if (!panel) return;
        if (this._reducedMotion) { panel.style.height = '0px'; return; }
        panel.style.transition = 'none';
        panel.style.height = panel.offsetHeight + 'px';
        panel.offsetHeight;
        panel.style.transition = 'height 250ms ease';
        panel.style.height = '0px';
      }
    }"
    x-init="$nextTick(() => {
      const syncHeight = () => {
        const img = $refs.mainImage;
        const thumbs = $refs.thumbnails;
        const accordion = $refs.accordion;
        if (img && window.innerWidth >= 1280) {
          const height = img.offsetHeight + 'px';
          if (thumbs) thumbs.style.height = height;
          if (accordion) accordion.style.height = height;
        }
      };
      syncHeight();
      window.addEventListener('resize', syncHeight);

      const p0 = $refs['teamPanel0'];
      if (p0) p0.style.height = 'auto';

      $watch('activeIndex', (newVal, oldVal) => {
        if (oldVal !== null && oldVal !== newVal) _closePanel(oldVal);
        if (newVal !== null) _openPanel(newVal);

        const thumbs = $refs.thumbnails;
        if (thumbs) {
          const btn = thumbs.children[newVal];
          if (btn) btn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        const hThumbs = $refs.horizontalThumbnails;
        if (hThumbs) {
          const btn = hThumbs.children[newVal];
          if (btn) {
            const scrollLeft = btn.offsetLeft - hThumbs.offsetWidth / 2 + btn.offsetWidth / 2;
            hThumbs.scrollTo({ left: scrollLeft, behavior: 'smooth' });
          }
        }
      });
    })"
  >
    <!-- Thumbnail Stack for xl: only (vertical on left) -->
    <div
      x-ref="thumbnails"
      class="hidden
      xl:flex
      flex-col
      gap-3
      overflow-y-scroll
      scrollbar-bears-thin"
    >
      {
        projects.map((project, index) => (
          <button
            type="button"
            class="shrink-0 w-24 h-24 aspect-square rounded-lg overflow-hidden border-2 transition-all duration-200 hover:cursor-pointer"
            x-bind:class={`activeIndex === ${index} ? 'border-bears-accent scale-100' : 'border-transparent scale-95 hover:scale-100'`}
            x-on:click={`activeIndex = ${index}`}
            aria-label={`View ${project.project.data.title} project`}
          >
            <Img
              src={project.loadedImage}
              alt={project.displayName ?? project.project.data.title}
              class="w-full h-full object-cover"
              loading="eager"
              sizes="96px"
              enableClickToEnlarge={false}
            />
          </button>
        ))
      }
    </div>

    <!-- Two-column grid for lg and xl (becomes 2nd and 3rd columns in xl's 3-col grid) -->
    <div
      class="grid grid-cols-1 xl:grid-cols-subgrid xl:col-span-2 gap-6 lg:gap-8"
    >
      <!-- Left column: thumbnails + image -->
      <div class="flex flex-col gap-3 lg:gap-4">
        <!-- Thumbnail Row for < xl: (horizontal above image) -->
        <div
          x-ref="horizontalThumbnails"
          class="flex flex-row gap-3 pb-2 sm:pb-0 overflow-x-auto justify-center-safe xl:hidden scrollbar-bears-thin"
        >
          {
            projects.map((project, index) => (
              <button
                type="button"
                class="shrink-0 w-24 h-24 aspect-square rounded-lg overflow-hidden border-2 transition-all duration-200 hover:cursor-pointer"
                x-bind:class={`activeIndex === ${index} ? 'border-bears-accent scale-100' : 'border-transparent scale-95 hover:scale-100'`}
                x-on:click={`activeIndex = ${index}`}
                aria-label={`View ${project.project.data.title} project`}
              >
                <Img
                  src={project.loadedImage}
                  alt={project.displayName ?? project.project.data.title}
                  class="w-full h-full object-cover"
                  loading="eager"
                  sizes="96px"
                  enableClickToEnlarge={false}
                />
              </button>
            ))
          }
        </div>

        <!-- Main Image -->
        <div
          x-ref="mainImage"
          class="relative w-full aspect-4/3 rounded-lg overflow-hidden"
        >
          {
            projects.map((project, index) => (
              <button
                type="button"
                class="absolute inset-0 transition-opacity duration-300"
                x-bind:class={`activeIndex === ${index} ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'`}
                x-on:click={`activeIndex = ${index}`}
                aria-label={`View ${project.project.data.title} project details`}
              >
                <Img
                  src={project.loadedImage}
                  alt={project.displayName ?? project.project.data.title}
                  class="w-full h-full object-cover"
                  loading="eager"
                  sizes="(min-width: 1280px) 50vw, (min-width: 1024px) 66vw, 100vw"
                  enableClickToEnlarge={false}
                />
              </button>
            ))
          }
        </div>
      </div>

      <!-- Projects Accordion -->
      <div
        x-ref="accordion"
        class="flex flex-col xl:h-auto xl:overflow-y-auto scrollbar-bears-thin"
      >
        <div class="flex flex-col gap-2">
          {
            projects.map((project, index) => {
              const itemId = `team-accordion-${index}`;
              const isNotLast = index < projects.length - 1;

              return (
                <div
                  class="accordion-item rounded-lg overflow-hidden"
                  style={`animation-delay: ${index * 60}ms`}
                >
                  <button
                    type="button"
                    class="flex items-center justify-between w-full text-left py-3.5 px-4 text-base sm:text-lg font-semibold text-bears-text-onDark hover:bg-white/5 transition-colors duration-200 cursor-pointer group"
                    x-on:click={`activeIndex = ${index}`}
                    x-bind:aria-expanded={`activeIndex === ${index} ? 'true' : 'false'`}
                    aria-controls={itemId}
                  >
                    <span>{project.project.data.title}</span>
                    <svg
                      class="w-4 h-4 flex-shrink-0 ml-3 transition-[transform,color] duration-200"
                      x-bind:class={`activeIndex === ${index} ? 'rotate-180 text-bears-accent' : 'rotate-0 text-bears-text-onDark/60 group-hover:text-bears-accent'`}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </button>

                  <div
                    id={itemId}
                    x-ref={`teamPanel${index}`}
                    class="overflow-hidden"
                    style={index === 0 ? '' : 'height: 0px;'}
                  >
                    <div class="px-4 pb-4">
                      {project.displayName && (
                        <p class="text-xs sm:text-sm text-bears-text-onDark font-medium mb-2">
                          {project.displayName}
                          {project.displayRole && (
                            <span class="text-bears-text-onDark/60"> — {project.displayRole}</span>
                          )}
                        </p>
                      )}
                      <div
                        class="text-sm sm:text-base text-bears-text-onDark/90 leading-relaxed"
                        set:html={project.project.data.description}
                      />
                    </div>
                  </div>

                  {isNotLast && <div class="border-b border-white/5 mx-4" />}
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>
