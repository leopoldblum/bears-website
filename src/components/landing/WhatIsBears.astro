---
// WhatIsBears component - Explains what BEARS e.V. is
import type { ImageMetadata } from 'astro';
import Marquee from "@mdx/Marquee.astro";
import Button from "@mdx/Button.astro";
import Img from "@mdx/Img.astro";
import { whatIsBearsImages } from "@utils/imageGlobs";
import { loadImage, resolveImagePath } from "@utils/imageLoader";
import { getPageContent } from "@utils/contentQueries";
import { type Locale } from '@utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const content = await getPageContent('landing/what-is-bears', locale);
// Carousel images are locale-agnostic; they live on the EN singleton only.
const imagesEntry = await getPageContent('landing/what-is-bears', 'en');
const baseDir = '/src/assets/whatIsBears';

const resolvedImages = (await Promise.all(
  (imagesEntry?.data.carouselImages ?? []).map(async (item) => {
    const image = await loadImage({
      glob: whatIsBearsImages,
      imagePath: resolveImagePath(baseDir, item.src),
      context: { itemTitle: 'What is BEARS carousel' },
    });
    return image ? { image, alt: item.alt ?? '' } : null;
  }),
)).filter((x): x is { image: ImageMetadata; alt: string } => x !== null);
---

<section
  id="what-is-bears-section"
  class="container mx-auto px-4 sm:px-8 lg:px-16 py-20 sm:py-24 lg:py-32 scroll-mt-20"
>
  <div class="flex flex-col max-w-3xl mx-auto text-center">
    <!-- Header -->
    <h2
      class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-8 sm:mb-10 lg:mb-14"
    >
      {content?.data.title}
    </h2>

    <div data-pagefind-ignore>
      <!-- Explanation text -->
      {content?.data.description && (
        <p class="text-base sm:text-lg text-bears-text-onDark leading-relaxed">
          {content.data.description}
        </p>
      )}

      <!-- Button -->
      {content?.data.buttonText && content?.data.buttonHref && (
        <div class="mt-6 sm:mt-8">
          <Button variant="primary" href={content.data.buttonHref}>{content.data.buttonText}</Button>
        </div>
      )}
    </div>
  </div>

  {resolvedImages.length > 0 && (
    <div class="mt-16 sm:mt-20">
      <Marquee speed={160} gap="1.5rem" height="lg">
        {
          resolvedImages.map((img, index) => (
            <Img
              src={img.image}
              alt={img.alt || `BEARS Gallery ${index + 1}`}
              class="rounded-lg"
            />
          ))
        }
      </Marquee>
    </div>
  )}
</section>
