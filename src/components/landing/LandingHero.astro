---
// Landing Hero Component - Main hero section with video/image carousel background
// Media is loaded from the hero-slides content collection
// HeroCTAs are rendered via a React island for better interactivity

import type { ImageMetadata } from 'astro';
import Img from '@mdx/Img.astro';
import HeroCTAIsland from './HeroCTAIsland';
import CarouselArrow from '@reusable/CarouselArrow.astro';
import { getLandingHeroSlides } from '@utils/contentQueries';
import { heroImages, heroMedia } from '@utils/imageGlobs';

interface MediaItem {
  type: 'video' | 'image';
  src: string | ImageMetadata;
  alt?: string;
  poster?: string;
  shownText?: string;
}

interface HeroCTAItem {
  title: string;
  description: string;
  href: string;
}

interface Props {
  autoScroll?: boolean;
  autoScrollInterval?: number;
  showArrows?: boolean;
  showDots?: boolean;
  /** Array of 1-3 HeroCTA items to display at the bottom */
  ctas?: HeroCTAItem[];
}

const {
  autoScroll = false,
  autoScrollInterval = 8000,
  showArrows = true,
  showDots = false,
  ctas = [],
} = Astro.props;

// Load slides from content collection
const slides = await getLandingHeroSlides();

// Process slides into media items - all media from src/assets/hero/
const media: MediaItem[] = await Promise.all(
  slides.map(async (slide) => {
    let src: string | ImageMetadata;
    const mediaPath = `/src/assets/hero/landingpage/${slide.data.media}`;

    if (slide.data.type === 'video') {
      // Videos use the general media glob
      if (heroMedia[mediaPath]) {
        const module = await heroMedia[mediaPath]();
        src = module.default;
      } else {
        console.warn(`Hero video not found: ${mediaPath}`);
        src = '';
      }
    } else {
      // Images use the typed image glob for Astro Image optimization
      if (heroImages[mediaPath]) {
        const imageModule = await heroImages[mediaPath]();
        src = imageModule.default;
      } else {
        console.warn(`Hero image not found: ${mediaPath}`);
        src = '';
      }
    }

    // Load poster image if specified
    let posterSrc: string | undefined;
    if (slide.data.poster) {
      const posterPath = `/src/assets/hero/landingpage/${slide.data.poster}`;
      if (heroMedia[posterPath]) {
        const posterModule = await heroMedia[posterPath]();
        posterSrc = posterModule.default as string;
      }
    }

    return {
      type: slide.data.type,
      src,
      alt: slide.data.alt,
      poster: posterSrc,
      shownText: slide.data.shownText,
    };
  })
);

const hasMultipleSlides = media.length > 1;
const mediaJson = JSON.stringify(media.map((item, index) => ({
  index,
  type: item.type,
  shownText: item.shownText || '',
})));
---

<section
  class="relative h-[75vh] w-full max-w-[2560px] mx-auto overflow-hidden bg-linear-to-br from-[#1F1F1F] to-bears-bg"
  x-data={`{
    currentSlide: 0,
    totalSlides: ${media.length || 1},
    autoScrollInterval: null,
    autoScrollEnabled: ${autoScroll && hasMultipleSlides},
    media: ${mediaJson},

    init() {
      if (this.autoScrollEnabled) {
        this.startAutoScroll();
      }
    },

    nextSlide() {
      this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },
    prevSlide() {
      this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },
    goToSlide(index) {
      this.currentSlide = index;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },

    startAutoScroll() {
      if (this.autoScrollEnabled) {
        this.autoScrollInterval = setInterval(() => {
          this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
        }, ${autoScrollInterval});
      }
    },
    stopAutoScroll() {
      if (this.autoScrollInterval) {
        clearInterval(this.autoScrollInterval);
        this.autoScrollInterval = null;
      }
    },
    resetAutoScroll() {
      this.stopAutoScroll();
      this.startAutoScroll();
    },

    getCurrentShownText() {
      return this.media[this.currentSlide]?.shownText || '';
    },

    touchStartX: 0,
    touchStartY: 0,
    handleTouchStart(e) {
      this.touchStartX = e.touches[0].clientX;
      this.touchStartY = e.touches[0].clientY;
      this.stopAutoScroll();
    },
    handleTouchEnd(e) {
      const deltaX = e.changedTouches[0].clientX - this.touchStartX;
      const deltaY = e.changedTouches[0].clientY - this.touchStartY;
      if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > Math.abs(deltaY)) {
        if (deltaX < 0) this.nextSlide();
        else this.prevSlide();
      }
      this.startAutoScroll();
    }
  }`}
  @mouseenter="stopAutoScroll()"
  @mouseleave="startAutoScroll()"
  @touchstart="handleTouchStart($event)"
  @touchend="handleTouchEnd($event)"
>
  <!-- Media Layer -->
  <div class="absolute inset-0 z-0">
    {media.length > 0 ? (
      media.map((item, index) => (
        <div
          x-show={`currentSlide === ${index}`}
          x-transition:enter="transition ease-out duration-500"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-300"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="absolute inset-0"
        >
          {item.type === 'video' ? (
            <video
              class="absolute inset-0 w-full h-full object-cover"
              src={typeof item.src === 'string' ? item.src : undefined}
              poster={item.poster}
              autoplay
              muted
              loop
              playsinline
            />
          ) : (
            typeof item.src === 'object' ? (
              <Img
                src={item.src as ImageMetadata}
                alt={item.alt || ''}
                class="absolute inset-0 w-full h-full object-cover"
                loading="eager"
                sizes="(min-width: 2560px) 2560px, 100vw"
                enableClickToEnlarge={false}
                fetchpriority={index === 0 ? 'high' : undefined}
              />
            ) : (
              <img
                src={item.src as string}
                alt={item.alt || ''}
                class="absolute inset-0 w-full h-full object-cover"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            )
          )}
        </div>
      ))
    ) : (
      <!-- Fallback placeholder when no media provided -->
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] bg-cover bg-center opacity-30"></div>
    )}

    <!-- Base gradient overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-bears-bg/60 via-bears-bg/30 to-transparent"></div>

    <!-- Bottom gradient for CTA area (always visible base layer) -->
    <div class="absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t from-bears-bg via-bears-bg/80 to-transparent pointer-events-none"></div>

    <!-- Side gradients for wide viewports - fade into background (show only when >2560px) -->
    <div class="hidden min-[2561px]:block absolute top-0 bottom-0 left-0 w-32 bg-gradient-to-r from-bears-bg to-transparent z-10 pointer-events-none"></div>
    <div class="hidden min-[2561px]:block absolute top-0 bottom-0 right-0 w-32 bg-gradient-to-l from-bears-bg to-transparent z-10 pointer-events-none"></div>

    <!-- Dot Indicators -->
    {hasMultipleSlides && showDots && (
      <div class="absolute bottom-4 sm:bottom-6 lg:bottom-8 left-1/2 -translate-x-1/2 z-20 flex gap-2 sm:gap-3">
        {media.map((_, index) => (
          <button
            @click={`goToSlide(${index})`}
            :class={`currentSlide === ${index} ? 'bg-white scale-110' : 'bg-white/40 hover:bg-white/60'`}
            class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full transition-all duration-200 cursor-pointer"
            aria-label={`Go to slide ${index + 1}`}
          />
        ))}
      </div>
    )}
  </div>

  <!-- Navigation Arrows (outside media layer to avoid z-index blocking) -->
  {hasMultipleSlides && showArrows && (
    <>
      <CarouselArrow
        direction="prev"
        onClick="prevSlide()"
        variant="absolute"
        position="left"
        inverted={true}
      />
      <CarouselArrow
        direction="next"
        onClick="nextSlide()"
        variant="absolute"
        position="right"
        inverted={true}
      />
    </>
  )}

  <!-- Content Container -->
  <div class="relative z-10 h-full">
    <div class="container mx-auto px-4 sm:px-8 lg:px-16 h-full flex flex-col">
      
      <!-- Top Row: Logo (left) and shownText (right) -->
      <div class="flex justify-between items-start pt-24 sm:pt-28 lg:pt-32">
        <!-- Logo - top left -->
        <div class="flex-shrink-0">
          <h1 class="text-[3.5rem] sm:text-[5.5rem] lg:text-8xl font-bold text-bears-accent drop-shadow-lg">
            BEARS
          </h1>
        </div>

        <!-- shownText display (top right corner) -->
        <div
          x-show="getCurrentShownText()"
          x-text="getCurrentShownText()"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 translate-y-2"
          class="bg-black/50 backdrop-blur-sm rounded-xl px-4 py-2 text-white text-sm sm:text-base lg:text-lg max-w-xs text-right"
        ></div>
      </div>

      <!-- Bottom Row: HeroCTAs (React Island for better interactivity) -->
      {ctas.length > 0 && (
        <HeroCTAIsland ctas={ctas} client:load />
      )}
    </div>
  </div>
</section>
