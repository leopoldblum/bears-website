---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ImageModal from './ImageModal.astro';
import { allAssetImages } from '@utils/imageGlobs';
import { resolveImagePath } from '@utils/imageLoader';
import { resolveGlobKey } from '@utils/imageConstants';

interface Props {
  // Imported asset (hand-written MDX) OR a string path stored by Keystatic
  // (e.g. "/src/assets/events/<slug>/foo.jpg"). Undefined → placeholder.
  src?: ImageMetadata | string;
  alt: string;
  width?: string;
  sizes?: string;
  widths?: number[];
  class?: string;
  enableClickToEnlarge?: boolean;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  fill?: boolean;
}

const {
  src: rawSrc,
  alt,
  width = "100%",
  sizes: customSizes,
  widths = [240, 480, 720, 960, 1280, 1920, 2560],
  class: className,
  enableClickToEnlarge = true,
  loading = "lazy",
  fetchpriority,
  fill = false
} = Astro.props;

// Resolve string srcs (what Keystatic writes) to ImageMetadata.
// resolveImagePath is a no-op for fully-qualified /src/... paths.
let src: ImageMetadata | undefined;
if (typeof rawSrc === 'string') {
  const key = resolveGlobKey(allAssetImages, resolveImagePath('', rawSrc));
  if (!key) {
    throw new Error(
      `<Img>: image "${rawSrc}" not found under /src/assets/. ` +
      `If this was just uploaded via Keystatic, restart the dev server so Vite picks up the new file.`
    );
  }
  src = (await allAssetImages[key]!()).default;
} else {
  src = rawSrc;
}

// Auto-derive sizes from width if not provided
function deriveSizes(width: string): string {
  // Match percentage values (e.g., "50%", "33.333%")
  const percentMatch = width.match(/^(\d+(?:\.\d+)?)%$/);
  if (percentMatch) {
    return `${Math.round(parseFloat(percentMatch[1]))}vw`;
  }

  // For pixel values or other units, use as-is
  return width;
}

const sizes = customSizes || deriveSizes(width);

// Default to rounded-lg, but allow overriding via class prop
const roundedClass = className?.match(/\brounded(-\w+)?\b/) ? '' : 'rounded-lg';

// Render a visible placeholder when an editor has inserted an <Img /> via the
// CMS without choosing a source yet. Keeps the build green and surfaces the
// missing image to the content editor directly on the page.
const missingSrc = !src;

// Generate full-res modal image only if click-to-enlarge enabled and src present
const modalSrc = enableClickToEnlarge && !missingSrc
  ? (await getImage({ src, format: 'webp' })).src
  : undefined;
---

{missingSrc ? (
  <div
    class={`${roundedClass} border-2 border-dashed border-bears-accent/50 bg-bears-accent/5 text-bears-text-onDark/70 text-center text-sm p-6 my-4`}
    style={width !== '100%' ? `width: ${width}` : undefined}
  >
    <strong>Image missing</strong> — {alt ? `"${alt}"` : 'no src set in the CMS'}
  </div>
) : enableClickToEnlarge ? (
  <!-- With wrapper: enables click-to-enlarge modal -->
  <div
    class={`img-better group/image ${roundedClass} overflow-hidden ring-0 ring-bears-accent transition-all duration-300 hover:ring-2 ${width === '100%' ? 'w-full h-full' : 'h-full'} ${className || ''}`.trim()}
    x-data="{ modalOpen: false }"
    style={fill ? (width !== '100%' ? `width: ${width}` : undefined) : `aspect-ratio: ${src.width} / ${src.height}${width !== '100%' ? `; width: ${width}` : ''}`}
  >
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      class={`${fill ? 'w-full h-full object-cover object-center' : ''} ${className || ''} hover:cursor-pointer`.trim()}
      loading={loading}
      format="webp"
      fetchpriority={fetchpriority}
      x-on:click="modalOpen = true"
    />

    <ImageModal src={modalSrc!} alt={alt} />
  </div>
) : fill ? (
  <!-- With wrapper for fill mode: ensures image fills container -->
  <div class={`w-full h-full ${roundedClass} overflow-hidden ${className || ''}`.trim()}>
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      class={`!w-full !h-full object-cover object-center ${className || ''}`.trim()}
      loading={loading}
      format="webp"
      fetchpriority={fetchpriority}
    />
  </div>
) : (
  <!-- Without wrapper: just the optimized image -->
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    class={`${roundedClass} ${className || ''}`.trim()}
    loading={loading}
    format="webp"
    fetchpriority={fetchpriority}
  />
)}
