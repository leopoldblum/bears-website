---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ImageModal from './ImageModal.astro';

interface Props {
  src: ImageMetadata;  // Only ImageMetadata, no string URLs
  alt: string;
  width?: string;      // CSS width: "50%", "800px", "100%", etc. (default: "100%")
  sizes?: string;      // Optional override for srcset sizes (auto-derived from width if not provided)
  widths?: number[];   // Array of widths for srcset generation (default covers common cases)
  class?: string;      // Additional styling classes (rounded, shadow, etc.)
  enableClickToEnlarge?: boolean;  // Default: true. When false, renders without wrapper div.
  loading?: "eager" | "lazy";      // Default: "lazy"
  fetchpriority?: "high" | "low" | "auto";  // Default: undefined (browser default)
  fill?: boolean;      // When true, image fills parent container (ignores native aspect ratio). Default: false
}

const {
  src,
  alt,
  width = "100%",
  sizes: customSizes,
  widths = [240, 480, 720, 960, 1280, 1920, 2560],
  class: className,
  enableClickToEnlarge = true,
  loading = "lazy",
  fetchpriority,
  fill = false
} = Astro.props;

// Auto-derive sizes from width if not provided
function deriveSizes(width: string): string {
  // Match percentage values (e.g., "50%", "33.333%")
  const percentMatch = width.match(/^(\d+(?:\.\d+)?)%$/);
  if (percentMatch) {
    return `${Math.round(parseFloat(percentMatch[1]))}vw`;
  }

  // For pixel values or other units, use as-is
  return width;
}

const sizes = customSizes || deriveSizes(width);

// Default to rounded-lg, but allow overriding via class prop
const roundedClass = className?.match(/\brounded(-\w+)?\b/) ? '' : 'rounded-lg';

// Generate full-res modal image only if click-to-enlarge enabled
const modalSrc = enableClickToEnlarge
  ? (await getImage({ src, format: 'webp' })).src
  : undefined;
---

{enableClickToEnlarge ? (
  <!-- With wrapper: enables click-to-enlarge modal -->
  <div
    class={`img-better group/image ${roundedClass} overflow-hidden ring-0 ring-bears-accent transition-all duration-300 hover:ring-2 ${width === '100%' ? 'w-full h-full' : 'h-full'} ${className || ''}`.trim()}
    x-data="{ modalOpen: false }"
    style={fill ? (width !== '100%' ? `width: ${width}` : undefined) : `aspect-ratio: ${src.width} / ${src.height}${width !== '100%' ? `; width: ${width}` : ''}`}
  >
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      class={`${fill ? 'w-full h-full object-cover object-center' : ''} ${className || ''} hover:cursor-pointer`.trim()}
      loading={loading}
      format="webp"
      fetchpriority={fetchpriority}
      x-on:click="modalOpen = true"
    />

    <ImageModal src={modalSrc!} alt={alt} />
  </div>
) : fill ? (
  <!-- With wrapper for fill mode: ensures image fills container -->
  <div class={`w-full h-full ${roundedClass} overflow-hidden ${className || ''}`.trim()}>
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      class={`!w-full !h-full object-cover object-center ${className || ''}`.trim()}
      loading={loading}
      format="webp"
      fetchpriority={fetchpriority}
    />
  </div>
) : (
  <!-- Without wrapper: just the optimized image -->
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    class={`${roundedClass} ${className || ''}`.trim()}
    loading={loading}
    format="webp"
    fetchpriority={fetchpriority}
  />
)}
