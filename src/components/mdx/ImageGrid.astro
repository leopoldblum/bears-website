---
// ImageGrid - Simple responsive grid with optional square aspect ratio
// Default: native aspect ratios (preserves proportions)
// Optional: square aspect ratios (consistent layout)

type ColCount = 1 | 2 | 3 | 4;
type GapSize = 'sm' | 'md' | 'lg';

interface Props {
  /** Number of columns on large screens (≥1024px). Default: 2 */
  cols?: ColCount;
  /** Gap between items. Default: 'md' */
  gap?: GapSize;
  /** Additional CSS classes */
  class?: string;
  /** Force square aspect ratio (1:1) for all images. Default: false */
  displayAsSquare?: boolean;
}

const { cols = 2, gap = 'md', class: className, displayAsSquare = false } = Astro.props;

const colClasses: Record<ColCount, string> = {
  1: 'lg:grid-cols-1',
  2: 'lg:grid-cols-2',
  3: 'lg:grid-cols-3',
  4: 'lg:grid-cols-4',
};

const gapClasses: Record<GapSize, string> = {
  sm: 'gap-2 lg:gap-4',
  md: 'gap-4 lg:gap-6',
  lg: 'gap-6 lg:gap-8',
};

const lgColClass = colClasses[cols] ?? colClasses[2];
const gapClass = gapClasses[gap] ?? gapClasses['md'];
---

<div class:list={['image-grid grid grid-cols-1', lgColClass, gapClass, { 'square': displayAsSquare }, 'p-3 sm:p-4', className]}>
  <slot />
</div>

<style>
  :global(.image-grid) {
    align-items: center;
  }

  :global(.image-grid > *) {
    width: 100%;
    height: fit-content !important;
  }

  :global(.image-grid img),
  :global(.image-grid picture) {
    width: 100%;
    height: auto;
  }

  /* Square aspect ratio mode */
  :global(.image-grid.square > *) {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    object-fit: cover;
  }

  /* Ensure images within square containers fill properly */
  :global(.image-grid.square img),
  :global(.image-grid.square picture) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
