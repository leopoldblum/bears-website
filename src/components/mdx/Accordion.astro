---
import { markdownToHtml } from '@utils/markdown';

// Accordion - Reusable accordion component with self-managed state
// Usage: Pass items array with title, subtitle (optional), and content (Markdown format)

interface Props {
  items: Array<{
    title: string;           // Accordion header text (required)
    subtitle?: string;       // Optional subtitle/metadata
    content: string;         // Content in Markdown format (processed server-side to HTML)
  }>;
  defaultOpen?: number | null;  // Index of initially opened item (default: null - all closed)
  allowCloseAll?: boolean;      // Whether clicking an open item closes it (default: auto-derived from defaultOpen)
  allowMultiple?: boolean;      // Allow multiple items to be open simultaneously (default: false)
  width?: string;               // Optional width (default: "100%")
}

const {
  items = [],
  defaultOpen = null,
  allowCloseAll = defaultOpen === null || defaultOpen === undefined,  // Auto-derive if not explicitly set
  allowMultiple = false,  // Default to single-open mode for backward compatibility
  width = "100%",
} = Astro.props;

// Process Markdown content to HTML for all items
const processedItems = await Promise.all(
  items.map(async (item) => ({
    ...item,
    content: await markdownToHtml(item.content)
  }))
);

// Server-side check: is item open at initial render?
const isItemDefaultOpen = (index: number) =>
  defaultOpen !== null && defaultOpen !== undefined && defaultOpen === index;
---

<div
  class="flex flex-col gap-2"
  style={`width: ${width}`}
  x-data={`{
    activeIndex: ${defaultOpen !== null && defaultOpen !== undefined && !allowMultiple ? defaultOpen : 'null'},
    openIndices: ${allowMultiple && defaultOpen !== null && defaultOpen !== undefined ? `[${defaultOpen}]` : '[]'},
    allowCloseAll: ${allowCloseAll},
    allowMultiple: ${allowMultiple},
    _reducedMotion: window.matchMedia('(prefers-reduced-motion: reduce)').matches,
    isOpen(i) {
      return this.allowMultiple ? this.openIndices.includes(i) : this.activeIndex === i;
    },
    init() {
      this.$nextTick(() => {
        for (let i = 0; i < ${processedItems.length}; i++) {
          if (this.isOpen(i)) {
            const p = this.$refs['panel' + i];
            if (p) p.style.height = 'auto';
          }
        }
      });
    },
    toggle(i) {
      const wasOpen = this.isOpen(i);
      if (wasOpen && !this.allowMultiple && !this.allowCloseAll) return;
      if (!this.allowMultiple && !wasOpen && this.activeIndex !== null) {
        this._closePanel(this.activeIndex);
      }
      if (this.allowMultiple) {
        this.openIndices = wasOpen
          ? this.openIndices.filter(idx => idx !== i)
          : [...this.openIndices, i];
      } else {
        this.activeIndex = wasOpen ? null : i;
      }
      if (wasOpen) { this._closePanel(i); } else { this._openPanel(i); }
    },
    _openPanel(i) {
      const panel = this.$refs['panel' + i];
      if (!panel) return;
      if (this._reducedMotion) { panel.style.height = 'auto'; return; }
      const target = panel.scrollHeight;
      panel.style.transition = 'none';
      panel.style.height = panel.offsetHeight + 'px';
      panel.offsetHeight;
      panel.style.transition = 'height 250ms ease-out';
      panel.style.height = target + 'px';
      setTimeout(() => {
        if (this.isOpen(i)) { panel.style.transition = ''; panel.style.height = 'auto'; }
      }, 260);
    },
    _closePanel(i) {
      const panel = this.$refs['panel' + i];
      if (!panel) return;
      if (this._reducedMotion) { panel.style.height = '0px'; return; }
      panel.style.transition = 'none';
      panel.style.height = panel.offsetHeight + 'px';
      panel.offsetHeight;
      panel.style.transition = 'height 200ms ease-in';
      panel.style.height = '0px';
    }
  }`}
>
  {processedItems.map((item, index) => {
    const itemId = `accordion-item-${index}`;
    const isNotLast = index < processedItems.length - 1;

    return (
      <div
        class="accordion-item rounded-lg overflow-hidden"
        style={`animation-delay: ${index * 60}ms`}
      >
        <button
          type="button"
          class="flex items-center justify-between w-full text-left py-3.5 px-4 text-base sm:text-lg font-semibold text-bears-text-onDark hover:bg-white/5 transition-colors duration-200 cursor-pointer group"
          x-on:click={`toggle(${index})`}
          x-bind:aria-expanded={`isOpen(${index}) ? 'true' : 'false'`}
          aria-controls={itemId}
        >
          <span data-pagefind-weight="6">{item.title}</span>
          <svg
            class="w-4 h-4 flex-shrink-0 ml-3 transition-[transform,color] duration-200"
            x-bind:class={`isOpen(${index}) ? 'rotate-180 text-bears-accent' : 'rotate-0 text-bears-text-onDark/60 group-hover:text-bears-accent'`}
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id={itemId}
          x-ref={`panel${index}`}
          class="overflow-hidden"
          style={isItemDefaultOpen(index) ? '' : 'height: 0px;'}
        >
          <div class="px-4 pb-4">
            {item.subtitle && (
              <p class="not-prose text-xs sm:text-sm text-bears-accent font-medium mb-2">
                {item.subtitle}
              </p>
            )}
            <div
              class="text-sm sm:text-base text-bears-text-onDark/90 leading-relaxed"
              data-pagefind-weight="2"
              set:html={item.content}
            />
          </div>
        </div>

        {isNotLast && (
          <div class="border-b border-white/5 mx-4"></div>
        )}
      </div>
    );
  })}
</div>
