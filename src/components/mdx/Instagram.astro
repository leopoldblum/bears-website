---
interface Props {
  /** Instagram post URL or shortcode
   *  Accepts: full URL (e.g., "https://www.instagram.com/p/ABC123/"),
   *  or just the shortcode (e.g., "ABC123")
   */
  url: string;

  /** Preset size for the embed container
   *  @default "medium"
   */
  size?: 'small' | 'medium' | 'large' | 'full';

  /** Additional CSS classes for the outer container */
  class?: string;
}

function extractPermalink(input: string): string {
  // If it looks like a shortcode (alphanumeric, hyphens, underscores only)
  if (/^[\w-]+$/.test(input)) {
    return `https://www.instagram.com/p/${input}/`;
  }
  // Ensure trailing slash for Instagram embed compatibility
  return input.endsWith('/') ? input : `${input}/`;
}

const sizeMap = {
  small: '380px',
  medium: '460px',
  large: '540px',
  full: '100%',
} as const;

const {
  url,
  size = 'medium',
  class: className,
} = Astro.props;

const maxWidth = sizeMap[size];
const permalink = extractPermalink(url);
---

<div
  class:list={['not-prose instagram-feed-card rounded-xl border border-white/10 bg-white/[0.03] backdrop-blur-sm shadow-[0_4px_12px_rgba(0,0,0,0.4)] overflow-hidden transition-all duration-300 lg:hover:border-bears-accent/30 lg:hover:shadow-[0_8px_24px_rgba(0,0,0,0.5),0_0_20px_rgba(197,14,31,0.15)] lg:hover:scale-[1.02]', className]}
  style={`max-width: ${maxWidth}; width: 100%;`}
>
  <blockquote
    class="instagram-media"
    data-instgrm-permalink={permalink}
    data-instgrm-version="14"
    style="margin: 0; padding: 0; width: 100%;"
  >
    <div style="padding: 16px;">
      <a
        href={permalink}
        target="_blank"
        rel="noopener noreferrer"
        style="color: #3897f0; text-decoration: none;"
      >
        View on Instagram
      </a>
    </div>
  </blockquote>
</div>

<style is:global>
  .instagram-feed-card iframe {
    margin: 0 !important;
    display: block;
    min-width: 0 !important;
    max-width: 100% !important;
    filter: brightness(0.96) saturate(0.95);
  }
</style>

<script>
  if (!document.querySelector('script[src*="instagram.com/embed.js"]')) {
    const script = document.createElement('script');
    script.src = 'https://www.instagram.com/embed.js';
    script.async = true;
    document.body.appendChild(script);
  } else if (window.instgrm) {
    window.instgrm.Embeds.process();
  }

  // Add title attributes to Instagram iframes for accessibility (Lighthouse)
  document.querySelectorAll('.instagram-feed-card').forEach((container) => {
    new MutationObserver(() => {
      container.querySelectorAll('iframe:not([title])').forEach((iframe) => {
        iframe.setAttribute('title', 'Instagram post');
      });
    }).observe(container, { childList: true, subtree: true });
  });
</script>
