---
// Left - Left column wrapper for SideBySide component
// Usage: Wrap content for the left column in SideBySide layouts
// Automatically applies flex-1 for 50% width distribution

interface Props {
  class?: string;
  centerVertical?: boolean;
}

const { class: className, centerVertical = false } = Astro.props;
const centerClasses = centerVertical ? 'flex flex-col justify-center' : '';
---

<div class={`flex-1 min-w-0 py-2 lg:pl-0 lg:pr-10 ${centerClasses} ${className || ''}`}>
  <slot />
</div>