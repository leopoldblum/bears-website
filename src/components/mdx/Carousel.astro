---
import CarouselBetterComponent from "./Carousel.tsx";

type HeightPreset = "sm" | "md" | "lg" | "xl" | "auto";

interface Props {
  /**
   * Enable automatic scrolling through slides
   * @default false
   */
  autoScroll?: boolean;

  /**
   * Time interval in milliseconds between automatic slide transitions
   * Only applies when autoScroll is enabled
   * @default 5000
   */
  autoScrollInterval?: number;

  /**
   * Show previous/next arrow navigation buttons
   * @default true
   */
  showArrows?: boolean;

  /**
   * Show dot indicators for slide navigation
   * @default true
   */
  showDots?: boolean;

  /**
   * Height preset for the carousel
   * - 'sm': 300px
   * - 'md': 400px (default)
   * - 'lg': 500px
   * - 'xl': 600px
   * - 'auto': Content determines height (no fixed height)
   * @default "md"
   */
  height?: HeightPreset;
}

const {
  autoScroll = false,
  autoScrollInterval = 5000,
  showArrows = true,
  showDots = true,
  height = "md",
} = Astro.props;
---

<CarouselBetterComponent
  client:visible
  autoScroll={autoScroll}
  autoScrollInterval={autoScrollInterval}
  showArrows={showArrows}
  showDots={showDots}
  height={height}
>
  <slot />
</CarouselBetterComponent>
