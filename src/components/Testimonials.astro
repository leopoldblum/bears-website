---
// Testimonials - Testimonial Carousel Component
import { getCollection } from "astro:content";
import Carousel from "./reusable/Carousel.astro";
import TestimonialCard from "./TestimonialCard.astro";
import type { TestimonialEntry } from '../types';
import type { ImageMetadata } from 'astro';
import { loadImagesForCollection } from '../utils/imageLoader';
import defaultTestimonialImage from '../assets/default-images/default-testimonial.jpg';

// Fetch testimonials from content collection
const allTestimonials = await getCollection("testimonials");

// Sort alphabetically by filename (slug)
const sortedTestimonials = allTestimonials.sort((a: TestimonialEntry, b: TestimonialEntry) => a.slug.localeCompare(b.slug));

// Import all images from testimonials directory
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/testimonials/*.{jpg,jpeg,png}");

// Load images for testimonials
const testimonialsWithLoadedImages = await loadImagesForCollection({
  glob: images,
  collection: sortedTestimonials,
  baseDir: '/src/assets/testimonials',
  imageField: 'image',
  fallbackImage: defaultTestimonialImage,
  postType: 'testimonial',
});

// Map to format expected by TestimonialCard
const testimonials = testimonialsWithLoadedImages.map((testimonial) => ({
  ...testimonial.data,
  image: testimonial.loadedImage as ImageMetadata, // Safe: fallback ensures never null
}));

---

<section class="container mx-auto px-4 sm:px-8 lg:px-16 pt-4 sm:pt-6 lg:pt-8 pb-16 sm:pb-20 lg:pb-24">
  <!-- Heading -->
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-6 sm:mb-8 lg:mb-12">
    What Members Think
  </h2>

  <!-- Testimonial Carousel -->
  <Carousel autoScrollInterval={5000}>
    {testimonials.map((testimonial) => (
      <TestimonialCard
        quote={testimonial.quote}
        name={testimonial.name}
        role={testimonial.role}
        image={testimonial.image}
      />
    ))}
  </Carousel>
</section>
