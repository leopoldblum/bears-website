---
// Testimonials - Testimonial Carousel Component
import Carousel from "./reusable/Carousel.astro";
import TestimonialCard from "./TestimonialCard.astro";
import type { ImageMetadata } from 'astro';
import { loadCollectionImages } from '../utils/imageLoader';
import { getTestimonialsSorted } from '../utils/contentQueries';

// Get testimonials sorted alphabetically by slug
const sortedTestimonials = await getTestimonialsSorted();

// Load images for testimonials
const testimonialsWithLoadedImages = await loadCollectionImages(
  sortedTestimonials,
  'testimonial'
);

// Map to format expected by TestimonialCard
const testimonials = testimonialsWithLoadedImages.map((testimonial) => ({
  ...testimonial.data,
  image: testimonial.loadedImage, // Guaranteed non-null by loader (schema field: coverImage, component prop: image)
}));

---

<section class="container mx-auto px-4 sm:px-8 lg:px-16 pt-4 sm:pt-6 lg:pt-8 pb-16 sm:pb-20 lg:pb-24">
  <!-- Heading -->
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark mb-6 sm:mb-8 lg:mb-12">
    What Members Think
  </h2>

  <!-- Testimonial Carousel -->
  <Carousel autoScrollInterval={5000}>
    {testimonials.map((testimonial) => (
      <TestimonialCard
        quote={testimonial.quote}
        name={testimonial.name}
        role={testimonial.role}
        image={testimonial.image}
      />
    ))}
  </Carousel>
</section>
