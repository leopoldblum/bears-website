---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocItems = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{tocItems.length >= 2 && (
  <nav class="docs-toc" aria-label="Table of contents">
    <p class="docs-toc-title">On this page</p>
    <ul>
      {tocItems.map(h => (
        <li>
          <a
            href={`#${h.slug}`}
            class:list={["docs-toc-link", h.depth === 3 && "docs-toc-indent"]}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .docs-toc {
    position: sticky;
    top: 5rem; /* header (3.5rem) + gap */
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding-left: 1rem;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .docs-toc-title {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-bears-text-onDark);
    opacity: 0.4;
    margin-bottom: 0.75rem;
  }

  .docs-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .docs-toc li {
    margin: 0;
  }

  .docs-toc-link {
    display: block;
    padding: 0.2rem 0;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-bears-text-onDark);
    opacity: 0.45;
    text-decoration: none;
    transition: opacity 0.15s ease, color 0.15s ease;
    overflow-wrap: break-word;
  }

  .docs-toc-link:hover {
    opacity: 1;
    color: var(--color-bears-accent);
  }

  .docs-toc-indent {
    padding-left: 0.75rem;
    font-size: 0.75rem;
  }
</style>
