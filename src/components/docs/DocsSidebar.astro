---
import { getDocsBySection } from "@utils/contentQueries";
import type { CollectionEntry } from "astro:content";

const sections = await getDocsBySection();
const currentPath = Astro.url.pathname;

const sectionConfig: Record<string, { label: string; order: number }> = {
  guides: { label: "Guides", order: 1 },
  dev: { label: "Dev Docs", order: 2 },
};

const sortedSections = Object.entries(sections).sort(
  ([a], [b]) => (sectionConfig[a]?.order ?? 99) - (sectionConfig[b]?.order ?? 99)
);

/** Groups docs by their `group` field. Ungrouped docs come first (key: ""). */
function groupDocs(docs: CollectionEntry<'docs'>[]) {
  const groups: Record<string, CollectionEntry<'docs'>[]> = {};
  docs.forEach(doc => {
    const key = doc.data.group ?? '';
    if (!groups[key]) groups[key] = [];
    groups[key].push(doc);
  });
  return Object.entries(groups).sort(([a], [b]) => {
    if (a === '') return -1;
    if (b === '') return 1;
    return a.localeCompare(b);
  });
}

function isActive(slug: string) {
  const href = `/docs/${slug}/`;
  return currentPath === href || currentPath === `/docs/${slug}`;
}

function groupHasActive(docs: CollectionEntry<'docs'>[]) {
  return docs.some(doc => isActive(doc.slug));
}
---

<!-- Desktop sidebar -->
<aside class="hidden lg:block w-64 shrink-0 border-r border-white/10">
  <nav class="sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto py-6 px-4 scrollbar-bears-thin">
    {sortedSections.map(([sectionKey, docs], i) => (
      <div class:list={["mb-6", i > 0 && "pt-6 border-t border-white/10"]}>
        <h3 class="text-xs uppercase tracking-wider text-bears-text-onDark/50 font-semibold mb-2 px-3">
          {sectionConfig[sectionKey]?.label ?? sectionKey}
        </h3>
        <ul>
          {groupDocs(docs).map(([groupName, groupItems]) => (
            <>
              {groupName ? (
                <li x-data={`{ expanded: JSON.parse(localStorage.getItem('docs-nav-${sectionKey}-${groupName}') ?? 'true') }`} x-init={`$watch('expanded', v => localStorage.setItem('docs-nav-${sectionKey}-${groupName}', JSON.stringify(v)))`} class="mt-2">
                  <button
                    x-on:click="expanded = !expanded"
                    class="flex items-center justify-between w-full px-3 py-1 text-[0.6875rem] uppercase tracking-wider font-medium cursor-pointer transition-colors text-bears-text-onDark/30 hover:text-bears-text-onDark/50"
                  >
                    <span>{groupName}</span>
                    <svg
                      class="w-3 h-3 transition-transform duration-150"
                      x-bind:class="expanded ? 'rotate-90' : ''"
                      fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </button>
                  <div
                    class="grid transition-[grid-template-rows] duration-200 ease-out"
                    x-bind:style="'grid-template-rows:' + (expanded ? '1fr' : '0fr')"
                    style="grid-template-rows: 0fr"
                    data-group-key={`docs-nav-${sectionKey}-${groupName}`}
                  >
                    <ul class="overflow-hidden">
                      {groupItems.map(doc => (
                        <li>
                          <a
                            href={`/docs/${doc.slug}/`}
                            class:list={[
                              "block px-3 py-1.5 rounded text-sm transition-colors",
                              isActive(doc.slug)
                                ? "text-bears-accent bg-white/5 font-medium"
                                : "text-bears-text-onDark/70 hover:text-bears-text-onDark hover:bg-white/5",
                            ]}
                          >
                            {doc.data.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </li>
              ) : (
                <>
                  {groupItems.map(doc => (
                    <li>
                      <a
                        href={`/docs/${doc.slug}/`}
                        class:list={[
                          "block px-3 py-1.5 rounded text-sm transition-colors",
                          isActive(doc.slug)
                            ? "text-bears-accent bg-white/5 font-medium"
                            : "text-bears-text-onDark/70 hover:text-bears-text-onDark hover:bg-white/5",
                        ]}
                      >
                        {doc.data.title}
                      </a>
                    </li>
                  ))}
                </>
              )}
            </>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<!-- Mobile sidebar overlay -->
<div
  x-data="{ open: false }"
  x-on:toggle-docs-sidebar.window="open = !open"
  x-cloak
>
  <!-- Backdrop -->
  <div
    x-show="open"
    x-transition:enter="transition-opacity duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-40 bg-black/60 lg:hidden"
    x-on:click="open = false"
  ></div>

  <!-- Slide-out panel -->
  <aside
    x-show="open"
    x-transition:enter="transition-transform duration-200"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition-transform duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    class="fixed top-0 left-0 z-50 w-72 h-full bg-bears-bg border-r border-white/10 lg:hidden"
  >
    <div class="flex items-center justify-between px-4 py-3 border-b border-white/10">
      <span class="text-sm font-semibold text-bears-text-onDark">Navigation</span>
      <button
        x-on:click="open = false"
        class="text-bears-text-onDark/70 hover:text-bears-text-onDark cursor-pointer"
        aria-label="Close sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="overflow-y-auto h-[calc(100%-3.25rem)] py-4 px-4 scrollbar-bears-thin">
      {sortedSections.map(([sectionKey, docs], i) => (
        <div class:list={["mb-6", i > 0 && "pt-6 border-t border-white/10"]}>
          <h3 class="text-xs uppercase tracking-wider text-bears-text-onDark/50 font-semibold mb-2 px-3">
            {sectionConfig[sectionKey]?.label ?? sectionKey}
          </h3>
          <ul>
            {groupDocs(docs).map(([groupName, groupItems]) => (
              <>
                {groupName ? (
                  <li x-data={`{ expanded: JSON.parse(localStorage.getItem('docs-nav-${sectionKey}-${groupName}') ?? 'true') }`} x-init={`$watch('expanded', v => localStorage.setItem('docs-nav-${sectionKey}-${groupName}', JSON.stringify(v)))`} class="mt-2">
                    <button
                      x-on:click="expanded = !expanded"
                      class="flex items-center justify-between w-full px-3 py-1 text-[0.6875rem] uppercase tracking-wider font-medium cursor-pointer transition-colors text-bears-text-onDark/30 hover:text-bears-text-onDark/50"
                    >
                      <span>{groupName}</span>
                      <svg
                        class="w-3 h-3 transition-transform duration-150"
                        x-bind:class="expanded ? 'rotate-90' : ''"
                        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </button>
                    <div
                      class="grid transition-[grid-template-rows] duration-200 ease-out"
                      x-bind:style="'grid-template-rows:' + (expanded ? '1fr' : '0fr')"
                      style="grid-template-rows: 0fr"
                      data-group-key={`docs-nav-${sectionKey}-${groupName}`}
                    >
                      <ul class="overflow-hidden">
                        {groupItems.map(doc => (
                          <li>
                            <a
                              href={`/docs/${doc.slug}/`}
                              class:list={[
                                "block px-3 py-1.5 rounded text-sm transition-colors",
                                isActive(doc.slug)
                                  ? "text-bears-accent bg-white/5 font-medium"
                                  : "text-bears-text-onDark/70 hover:text-bears-text-onDark hover:bg-white/5",
                              ]}
                            >
                              {doc.data.title}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </li>
                ) : (
                  <>
                    {groupItems.map(doc => (
                      <li>
                        <a
                          href={`/docs/${doc.slug}/`}
                          class:list={[
                            "block px-3 py-1.5 rounded text-sm transition-colors",
                            isActive(doc.slug)
                              ? "text-bears-accent bg-white/5 font-medium"
                              : "text-bears-text-onDark/70 hover:text-bears-text-onDark hover:bg-white/5",
                          ]}
                        >
                          {doc.data.title}
                        </a>
                      </li>
                    ))}
                  </>
                )}
              </>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </aside>
</div>

<script is:inline>
document.querySelectorAll('[data-group-key]').forEach(function(el) {
  if (localStorage.getItem(el.getAttribute('data-group-key')) !== 'false') {
    el.style.gridTemplateRows = '1fr';
  }
});
</script>
