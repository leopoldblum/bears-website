---
// NewsGridElement component - Reusable news preview card with image overlay
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { PostType } from '../types';
import defaultEventImage from "../assets/default-images/default-event.jpg";
import defaultProjectImage from "../assets/default-images/default-project.jpg";

interface Props {
  coverImage: ImageMetadata | null;
  imageAlt: string;
  date: string;
  title: string;
  description: string;
  href?: string;
  postType?: PostType;
}

const { coverImage, imageAlt, date, title, description, href, postType } = Astro.props;

// Use provided coverImage or fall back to default based on postType
const defaultCoverImage = postType === 'projects' ? defaultProjectImage : defaultEventImage;
const finalCoverImage = coverImage ?? defaultCoverImage;

const Wrapper = href ? 'a' : 'div';
---

<Wrapper href={href} class="relative h-80 rounded-lg overflow-hidden group cursor-pointer transition-transform duration-300 lg:hover:scale-102 block">
  <!-- Background Image - Always present -->
  <Image
    src={finalCoverImage}
    alt={imageAlt}
    class="w-full h-full object-cover"
    loading="lazy"
    format="webp"
  />

  <!-- Gradient Overlay on bottom half -->
  <div class="absolute inset-x-0 bottom-0 h-1/2 bg-[linear-gradient(to_top,rgba(0,0,0,0.95)_0%,rgba(0,0,0,0.9)_50%,rgba(0,0,0,0.85)_65%,rgba(0,0,0,0.6)_80%,rgba(0,0,0,0.15)_90%,transparent_100%)]"></div>

  <!-- Content -->
  <div class="absolute inset-x-0 bottom-0 p-6">
    <!-- Date -->
<div class="absolute top-[-150px] left-0 z-10">
  <span class="
    text-xs
    font-medium
    uppercase
    tracking-wide
    text-white
    bg-black/70
    backdrop-blur-sm
    px-3 py-1
    rounded-full
    shadow-md
  ">
    {date}
  </span>
</div>

    <!-- Title -->
    <h3 class="text-xl sm:text-2xl font-bold text-bears-text-onDark mb-3 group-hover:text-bears-accent transition-colors">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm sm:text-base text-bears-text-onDark/90 leading-relaxed">
      {description}
    </p>
  </div>
</Wrapper>
