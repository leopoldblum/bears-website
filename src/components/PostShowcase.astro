---
// NewsGridElement component - Reusable news preview card with image overlay
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  coverImage: ImageMetadata;
  imageAlt: string;
  date: string;
  title: string;
  description: string;
  href?: string;
}

const { coverImage, imageAlt, date, title, description, href } = Astro.props;

const Wrapper = href ? 'a' : 'div';
---

<Wrapper href={href} class="relative h-80 rounded-lg overflow-hidden group cursor-pointer transition-transform duration-300 lg:hover:scale-101 block">
  <!-- Background Image - Always present -->
  <Image
    src={coverImage}
    alt={imageAlt}
    class="w-full h-full object-cover"
    format="webp"
    loading={'eager'}
  />

  <!-- Date Badge - Top Left -->
  <div class="absolute top-4 left-4 z-10">
    <span class="
      flex items-center gap-2
      text-xs
      font-medium
      uppercase
      tracking-wide
      text-white
      bg-black/70
      backdrop-blur-sm
      px-3 py-1
      rounded-full
      shadow-md
    ">
      <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      {date}
    </span>
  </div>

  <!-- Title and Description - Bottom with Dynamic Gradient -->
  <div class="absolute inset-x-0 bottom-0 transition-all duration-300">
    <!-- Gradient Background - Expands with content -->
    <div class="absolute inset-0 bg-[linear-gradient(to_top,rgba(0,0,0,0.95)_0%,rgba(0,0,0,0.9)_50%,rgba(0,0,0,0.85)_65%,rgba(0,0,0,0.6)_80%,rgba(0,0,0,0.15)_90%,transparent_100%)] transition-all duration-300"></div>

    <!-- Content -->
    <div class="relative p-6">
      <!-- Title -->
      <h3 class="text-xl sm:text-2xl font-bold text-bears-text-onDark mb-3 group-hover:text-bears-accent transition-colors">
        {title}
      </h3>

      <!-- Description - Always visible on mobile, shows on hover on desktop -->
      <p class="text-sm sm:text-base text-bears-text-onDark/90 leading-relaxed max-h-40 opacity-100 lg:max-h-0 lg:opacity-0 overflow-hidden lg:group-hover:max-h-40 lg:group-hover:opacity-100 transition-all duration-300">
        {description}
      </p>
    </div>
  </div>
</Wrapper>
