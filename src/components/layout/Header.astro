<header
  class="bg-bears-bg text-bears-text-onDark p-4 sticky top-0 z-40 transition-transform duration-300"
  x-data="{ mobileMenuOpen: false, lastScrollY: 0, headerHidden: false }"
  x-init="lastScrollY = window.scrollY"
  x-on:scroll.window="
    if (mobileMenuOpen) { headerHidden = false; return; }
    headerHidden = window.scrollY > lastScrollY && window.scrollY > 60;
    lastScrollY = window.scrollY;
  "
  x-bind:class="{ '-translate-y-full': headerHidden }"
>
  <div class="max-w-screen-2xl mx-auto px-5 lg:px-[1vw] py-2">
    <div class="relative flex items-center justify-between lg:gap-4">
      <div class="shrink-0">
        <a href="/" class="text-2xl font-bold text-bears-accent">BEARS</a>
      </div>

      <button
        x-on:click="mobileMenuOpen = !mobileMenuOpen"
        class="lg:hidden relative w-10 h-10 flex items-center justify-center text-bears-text-onDark hover:text-bears-accent transition-colors cursor-pointer"
        aria-label="Toggle menu"
        :aria-expanded="mobileMenuOpen"
      >
        <div class="w-5 h-5 relative flex flex-col justify-center items-center">
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? 'rotate-45 translate-y-0' : '-translate-y-1.5'"
          ></span>
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? 'opacity-0 scale-x-0' : 'opacity-100 scale-x-100'"
          ></span>
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? '-rotate-45 translate-y-0' : 'translate-y-1.5'"
          ></span>
        </div>
      </button>

      <div class="hidden lg:flex shrink-0 items-center gap-4 lg:gap-8">
        <input
          type="search"
          placeholder="Search..."
          class="max-w-64 px-3 py-1.5 rounded-lg bg-[#303030] text-bears-text-onDark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-bears-accent"
          disabled
        />

        <nav class="flex items-center justify-end gap-4 lg:gap-8 px-4 lg:px-[2vw]">
          <a href="/projects" class="hover:text-bears-accent transition-colors">Projects</a>
          <a href="/sponsors" class="hover:text-bears-accent transition-colors">Sponsors</a>
          <a href="/events" class="hover:text-bears-accent transition-colors">Events</a>
          <a href="/about-us" class="hover:text-bears-accent transition-colors">About Us</a>
        </nav>

        <div class="flex items-center gap-1 text-sm">
          <button class="hover:text-bears-accent transition-colors">DE</button>
          <span class="text-gray-500">|</span>
          <button class="hover:text-bears-accent transition-colors">ENG</button>
        </div>
      </div>
    </div>

    <div
      x-cloak
      x-show="mobileMenuOpen"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-3 scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 -translate-y-3 scale-95"
      x-on:click.away="mobileMenuOpen = false"
      @keydown.escape.window="mobileMenuOpen = false"
      class="lg:hidden fixed left-0 right-0 top-15 z-50 mx-3 sm:mx-4 bg-black/70 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_8px_32px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.05)] overflow-hidden"
    >
      <!-- Accent Gradient Bar -->
      <div class="h-0.5 bg-linear-to-r from-bears-accent via-bears-accent/80 to-transparent"></div>

      <div class="p-5">
        <!-- Panel Header -->
        <div class="flex items-center justify-between mb-5">
          <h3 class="text-base font-semibold text-bears-text-onDark tracking-wide uppercase select-none">Menu</h3>
        </div>

        <!-- Search Input -->
        <div class="mb-4">
          <input
            type="search"
            placeholder="Search..."
            class="w-full px-3 py-2.5 rounded-lg bg-white/10 text-bears-text-onDark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-bears-accent border border-white/5"
            disabled
          />
        </div>

        <!-- Nav Links -->
        <nav class="flex flex-col gap-1">
          <a href="/projects" class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-md text-bears-text-onDark/90 hover:text-bears-text-onDark hover:bg-white/5 transition-all duration-150" style="animation-delay: 0ms">
            <span class="w-0.5 h-4 bg-bears-accent rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-150"></span>
            <span>Projects</span>
          </a>
          <a href="/sponsors" class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-md text-bears-text-onDark/90 hover:text-bears-text-onDark hover:bg-white/5 transition-all duration-150" style="animation-delay: 60ms">
            <span class="w-0.5 h-4 bg-bears-accent rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-150"></span>
            <span>Sponsors</span>
          </a>
          <a href="/events" class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-md text-bears-text-onDark/90 hover:text-bears-text-onDark hover:bg-white/5 transition-all duration-150" style="animation-delay: 120ms">
            <span class="w-0.5 h-4 bg-bears-accent rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-150"></span>
            <span>Events</span>
          </a>
          <a href="/about-us" class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-md text-bears-text-onDark/90 hover:text-bears-text-onDark hover:bg-white/5 transition-all duration-150" style="animation-delay: 180ms">
            <span class="w-0.5 h-4 bg-bears-accent rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-150"></span>
            <span>About Us</span>
          </a>
        </nav>

        <!-- Language Selector -->
        <div class="nav-link flex items-center gap-2 mt-3 pt-4 border-t border-white/5" style="animation-delay: 240ms">
          <span class="text-xs font-semibold text-bears-text-onDark/60 uppercase tracking-wider select-none">Language:</span>
          <button class="text-sm text-bears-text-onDark/80 hover:text-bears-accent transition-colors cursor-pointer">DE</button>
          <span class="text-bears-text-onDark/30">|</span>
          <button class="text-sm text-bears-text-onDark/80 hover:text-bears-accent transition-colors cursor-pointer">ENG</button>
        </div>
      </div>
    </div>
  </div>
</header>
