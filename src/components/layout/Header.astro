---
import { Image } from 'astro:assets';
import { headerLogoImages } from '@utils/imageGlobs';
import { getPageContent } from '@utils/contentQueries';
import { localizeUrl, stripLocalePrefix, getAlternateLocale, type Locale } from '@utils/i18n';

// Load the first image from src/assets/header/
const logoEntry = Object.values(headerLogoImages)[0];
const bearsLogo = logoEntry ? (await logoEntry()).default : null;

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;

const navContent = await getPageContent('header/navigation', locale);
const navLinks = navContent?.data.navLinks ?? [
  { href: "/projects", label: "Projects" },
  { href: "/sponsors", label: "Sponsors" },
  { href: "/events", label: "Events" },
  { href: "/about-us", label: "About Us" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string): boolean {
  const cleanCurrent = stripLocalePrefix(currentPath);
  return cleanCurrent === href;
}

// Language switcher
const alternateLocale = getAlternateLocale(locale);
const barePath = stripLocalePrefix(currentPath);
const alternateUrl = localizeUrl(barePath, alternateLocale);
const searchPlaceholder = locale === 'de' ? 'Suche...' : 'Search...';
const noResultsText = locale === 'de' ? 'Keine Ergebnisse' : 'No results found';
---

<header
  class="bg-bears-bg text-bears-text-onDark sticky top-0 z-40 transition-transform duration-300"
  x-data="{
    mobileMenuOpen: false,
    lastScrollY: 0,
    headerHidden: false,

    searchQuery: '',
    searchResults: [],
    searchActive: false,
    selectedIndex: -1,
    mobileResultsHeight: 0,

    async doSearch() {
      if (!window.__pagefind) {
        try {
          window.__pagefind = await import('/pagefind/pagefind.js');
          await window.__pagefind.init({ language: document.documentElement.lang });
        } catch (e) { console.error('Pagefind load failed:', e); return; }
      }
      if (!this.searchQuery.trim()) { this.searchResults = []; return; }
      try {
        const s = await window.__pagefind.search(this.searchQuery.trim());
        const results = await Promise.all(s.results.slice(0, 8).map(r => r.data()));
        this.searchResults = results.map(r => {
          const subs = r.sub_results || [];
          const best = subs.length > 1
            ? subs.reduce((a, b) => {
                const sa = a.weighted_locations?.reduce((s, l) => s + l.balanced_score, 0) || 0;
                const sb = b.weighted_locations?.reduce((s, l) => s + l.balanced_score, 0) || 0;
                return sb > sa ? b : a;
              })
            : subs[0];
          if (best) {
            r.displayUrl = best.url;
            r.displayTitle = best.title || r.meta?.title || 'Untitled';
            r.displayExcerpt = best.excerpt || '';
          } else {
            r.displayUrl = r.url;
            r.displayTitle = r.meta?.title || 'Untitled';
            r.displayExcerpt = r.excerpt || '';
          }
          return r;
        });
        this.selectedIndex = -1;
        this.updateMobileHeight();
      } catch (e) { console.error('Pagefind search failed:', e); }
    },

    onSearchInput() {
      clearTimeout(window.__searchTimer);
      if (!this.searchQuery.trim()) { this.searchResults = []; this.selectedIndex = -1; this.mobileResultsHeight = 0; return; }
      window.__searchTimer = setTimeout(() => this.doSearch(), 150);
    },

    closeSearch() {
      this.searchActive = false;
      this.searchQuery = '';
      this.searchResults = [];
      this.selectedIndex = -1;
      this.mobileResultsHeight = 0;
    },

    updateMobileHeight() {
      this.$nextTick(() => {
        const el = this.$refs.mobileResultsInner;
        this.mobileResultsHeight = el ? el.scrollHeight : 0;
      });
    },

    selectNext() {
      if (this.searchResults.length === 0) return;
      this.selectedIndex = (this.selectedIndex + 1) % this.searchResults.length;
      this.$nextTick(() => {
        this.$refs.desktopResults?.querySelector('[data-idx=' + this.selectedIndex + ']')?.scrollIntoView({ block: 'nearest' });
        this.$refs.mobileResults?.querySelector('[data-idx=' + this.selectedIndex + ']')?.scrollIntoView({ block: 'nearest' });
      });
    },

    selectPrev() {
      if (this.searchResults.length === 0) return;
      this.selectedIndex = this.selectedIndex <= 0 ? this.searchResults.length - 1 : this.selectedIndex - 1;
      this.$nextTick(() => {
        this.$refs.desktopResults?.querySelector('[data-idx=' + this.selectedIndex + ']')?.scrollIntoView({ block: 'nearest' });
        this.$refs.mobileResults?.querySelector('[data-idx=' + this.selectedIndex + ']')?.scrollIntoView({ block: 'nearest' });
      });
    },

    confirmSelection() {
      if (this.selectedIndex >= 0 && this.searchResults[this.selectedIndex]) {
        window.location.href = this.searchResults[this.selectedIndex].displayUrl;
      }
    },

    stripSection(url) {
      const clean = url.endsWith('/') ? url.slice(0, -1) : url;
      let parts = clean.split('/').filter(Boolean);
      if (parts[0] === 'de') parts = parts.slice(1);
      if (parts.length === 0) return 'Home';
      return parts[0].charAt(0).toUpperCase() + parts[0].slice(1).replace(/-/g, ' ');
    }
  }"
  x-init="lastScrollY = window.scrollY"
  x-on:scroll.window="
    if (mobileMenuOpen) { headerHidden = false; return; }
    const shouldHide = window.scrollY > lastScrollY && window.scrollY > 60;
    if (shouldHide && !headerHidden && searchActive) { searchActive = false; $refs.desktopSearch?.blur(); }
    headerHidden = shouldHide;
    lastScrollY = window.scrollY;
  "
  x-on:keydown.window="
    if (($event.metaKey || $event.ctrlKey) && $event.key === 'k') {
      $event.preventDefault();
      if (window.innerWidth >= 1024) {
        searchActive = true;
        $nextTick(() => $refs.desktopSearch?.focus());
      } else {
        mobileMenuOpen = true;
        $nextTick(() => $refs.mobileSearch?.focus());
      }
    }
  "
  x-bind:class="{ '-translate-y-full': headerHidden }"
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <div class="flex items-center justify-between">
      <a href={localizeUrl('/', locale)} class="shrink-0">
        {bearsLogo ? (
          <Image src={bearsLogo} alt="BEARS" class="h-7 w-auto" width={400} loading="eager" />
        ) : (
          <span class="text-2xl font-bold text-bears-accent">BEARS</span>
        )}
      </a>

      <button
        x-on:click="mobileMenuOpen = !mobileMenuOpen"
        class="lg:hidden relative w-10 h-10 flex items-center justify-center text-bears-text-onDark hover:text-bears-accent transition-colors cursor-pointer"
        aria-label="Toggle menu"
        :aria-expanded="mobileMenuOpen"
      >
        <div class="w-5 h-5 relative flex flex-col justify-center items-center">
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? 'rotate-45 translate-y-0' : '-translate-y-1.5'"
          ></span>
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? 'opacity-0 scale-x-0' : 'opacity-100 scale-x-100'"
          ></span>
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? '-rotate-45 translate-y-0' : 'translate-y-1.5'"
          ></span>
        </div>
      </button>

      <div class="hidden lg:flex items-center gap-12">
        <!-- Desktop Search -->
        <div class="relative" x-on:click.outside="searchActive = false">
          <div class="flex items-center w-48 rounded-lg bg-bears-bg-elevated transition-all duration-300"
               :class="searchActive && 'w-72 ring-2 ring-bears-accent/40 shadow-[0_2px_8px_rgba(0,0,0,0.25)]'"
            <svg class="w-4 h-4 text-gray-400 shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              x-ref="desktopSearch"
              id="desktop-search"
              name="search"
              type="text"
              x-model="searchQuery"
              x-on:input="onSearchInput()"
              x-on:focus="searchActive = true"
              x-on:keydown.arrow-down.prevent="selectNext()"
              x-on:keydown.arrow-up.prevent="selectPrev()"
              x-on:keydown.enter.prevent="confirmSelection()"
              x-on:keydown.escape="closeSearch(); $refs.desktopSearch.blur()"
              placeholder={searchPlaceholder}
              class="w-full bg-transparent text-sm text-bears-text-onDark placeholder-gray-400 focus:outline-none px-2 py-1.5"
              autocomplete="off"
            />
          </div>

          <!-- Desktop Results Dropdown -->
          <div
            x-show="searchActive && searchQuery.trim().length > 0"
            x-transition:enter="transition ease-out duration-150"
            x-transition:enter-start="opacity-0 -translate-y-1"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-100"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            x-ref="desktopResults"
            class="absolute left-0 right-0 top-full mt-2 bg-black/80 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_8px_32px_rgba(0,0,0,0.5)] overflow-hidden max-h-[70vh] overflow-y-auto scrollbar-bears-thin"
            x-cloak
          >
            <!-- No results -->
            <template x-if="searchResults.length === 0">
              <div class="px-4 py-6 text-center text-gray-400 text-sm">
                {noResultsText}
              </div>
            </template>

            <!-- Results -->
            <template x-if="searchResults.length > 0">
              <div class="py-1">
                <template x-for="(result, idx) in searchResults" :key="result.url + idx">
                  <a
                    :href="result.displayUrl"
                    :data-idx="idx"
                    x-on:mouseenter="selectedIndex = idx"
                    x-on:mousedown.prevent
                    class="search-result block px-4 py-2.5 transition-colors duration-75"
                    :class="selectedIndex === idx ? 'bg-white/10' : 'hover:bg-white/5'"
                  >
                    <div class="flex items-center gap-2">
                      <span class="text-sm font-medium truncate"
                            :class="selectedIndex === idx ? 'text-white' : 'text-bears-text-onDark/90'"
                            x-text="result.displayTitle"></span>
                      <span class="text-[10px] uppercase tracking-wider text-gray-500 shrink-0"
                            x-text="stripSection(result.url)"></span>
                    </div>
                    <div class="text-xs text-gray-400 mt-0.5 line-clamp-1 search-excerpt"
                         x-html="result.displayExcerpt"></div>
                  </a>
                </template>
              </div>
            </template>
          </div>
        </div>

        <nav class="flex items-center gap-8">
          {navLinks.map(({ href, label }) => (
            <a
              href={localizeUrl(href, locale)}
              class:list={[
                "transition-colors",
                isActive(href)
                  ? "text-bears-accent"
                  : "hover:text-bears-accent",
              ]}
            >
              {label}
            </a>
          ))}
          <div class="flex items-center gap-1.5 text-sm uppercase tracking-wider" role="group" aria-label={locale === 'de' ? 'Sprache wählen' : 'Select language'}>
            {locale === 'en' ? (
              <span class="font-semibold text-bears-text-onDark" aria-current="true">EN</span>
            ) : (
              <a href={alternateUrl} class="text-bears-text-onDark/60 hover:text-bears-text-onDark transition-colors">EN</a>
            )}
            <span class="text-bears-text-onDark/20">|</span>
            {locale === 'de' ? (
              <span class="font-semibold text-bears-text-onDark" aria-current="true">DE</span>
            ) : (
              <a href={alternateUrl} class="text-bears-text-onDark/60 hover:text-bears-text-onDark transition-colors">DE</a>
            )}
          </div>
        </nav>
      </div>
    </div>

    <div
      x-cloak
      x-show="mobileMenuOpen"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-3 scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 -translate-y-3 scale-95"
      x-on:click.away="mobileMenuOpen = false"
      @keydown.escape.window="mobileMenuOpen = false"
      class="lg:hidden fixed left-0 right-0 top-15 z-50 mx-3 sm:mx-4 bg-black/70 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_8px_32px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.05)] overflow-hidden"
    >
      <!-- Accent Gradient Bar -->
      <div class="h-0.5 bg-linear-to-r from-bears-accent via-bears-accent/80 to-transparent"></div>

      <div class="p-5">
        <!-- Mobile Search -->
        <div class="mb-4">
          <div class="flex items-center rounded-lg bg-white/10 border border-white/5 transition-all duration-300"
               :class="searchActive ? 'ring-2 ring-bears-accent/40 shadow-[0_2px_8px_rgba(0,0,0,0.25)]' : ''">
            <svg class="w-4 h-4 text-gray-400 shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              x-ref="mobileSearch"
              id="mobile-search"
              name="search"
              type="text"
              x-model="searchQuery"
              x-on:input="onSearchInput()"
              x-on:focus="searchActive = true"
              x-on:keydown.arrow-down.prevent="selectNext()"
              x-on:keydown.arrow-up.prevent="selectPrev()"
              x-on:keydown.enter.prevent="confirmSelection()"
              x-on:keydown.escape="closeSearch(); $refs.mobileSearch.blur()"
              placeholder={searchPlaceholder}
              class="w-full bg-transparent text-sm text-bears-text-onDark placeholder-gray-400 focus:outline-none px-2 py-2.5"
              autocomplete="off"
            />
          </div>

          <!-- Mobile Results (JS-measured height for smooth transitions) -->
          <div
            class="mt-2 overflow-hidden transition-[height] duration-200 ease-out"
            :style="'height:' + mobileResultsHeight + 'px'"
          >
            <div x-ref="mobileResultsInner">
              <div
                x-show="searchResults.length > 0"
                x-ref="mobileResults"
                class="bg-white/5 rounded-lg overflow-hidden max-h-60 overflow-y-auto scrollbar-bears-thin"
              >
                <template x-for="(result, idx) in searchResults" :key="result.url + idx">
                  <a
                    :href="result.displayUrl"
                    :data-idx="idx"
                    x-on:mouseenter="selectedIndex = idx"
                    class="search-result block px-3 py-2 transition-colors duration-75"
                    :class="selectedIndex === idx ? 'bg-white/10' : 'hover:bg-white/5'"
                  >
                    <div class="flex items-center gap-2">
                      <span class="text-sm font-medium truncate"
                            :class="selectedIndex === idx ? 'text-white' : 'text-bears-text-onDark/90'"
                            x-text="result.displayTitle"></span>
                      <span class="text-[10px] uppercase tracking-wider text-gray-500 shrink-0"
                            x-text="stripSection(result.url)"></span>
                    </div>
                    <div class="text-xs text-gray-400 mt-0.5 line-clamp-1 search-excerpt"
                         x-html="result.displayExcerpt"></div>
                  </a>
                </template>
              </div>

              <!-- Mobile No Results -->
              <div
                x-show="searchResults.length === 0 && window.__pagefind"
                class="px-3 py-4 text-center text-gray-400 text-sm"
              >
                {noResultsText}
              </div>
            </div>
          </div>
        </div>

        <!-- Nav Links -->
        <nav class="flex flex-col gap-1">
          {navLinks.map(({ href, label }, index) => (
            <a
              href={localizeUrl(href, locale)}
              class:list={[
                "nav-link group flex items-center gap-3 px-3 py-2.5 rounded-md transition-all duration-150",
                isActive(href)
                  ? "text-bears-accent bg-white/5"
                  : "text-bears-text-onDark/90 hover:text-bears-text-onDark hover:bg-white/5",
              ]}
              style={`animation-delay: ${index * 60}ms`}
            >
              <span
                class:list={[
                  "w-0.5 h-4 bg-bears-accent rounded-full transition-opacity duration-150",
                  isActive(href) ? "opacity-100" : "opacity-0 group-hover:opacity-100",
                ]}
              ></span>
              <span>{label}</span>
            </a>
          ))}
          <div class="flex justify-center mt-4 pt-3 border-t border-white/5">
            <div class="flex items-center gap-2 text-sm uppercase tracking-wider" role="group" aria-label={locale === 'de' ? 'Sprache wählen' : 'Select language'}>
              {locale === 'en' ? (
                <span class="font-semibold text-bears-text-onDark" aria-current="true">EN</span>
              ) : (
                <a href={alternateUrl} class="text-bears-text-onDark/60 hover:text-bears-text-onDark transition-colors">EN</a>
              )}
              <span class="text-bears-text-onDark/20">|</span>
              {locale === 'de' ? (
                <span class="font-semibold text-bears-text-onDark" aria-current="true">DE</span>
              ) : (
                <a href={alternateUrl} class="text-bears-text-onDark/60 hover:text-bears-text-onDark transition-colors">DE</a>
              )}
            </div>
          </div>
        </nav>
      </div>
    </div>
  </div>
</header>
