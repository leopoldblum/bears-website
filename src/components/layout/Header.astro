<header
  class="bg-bears-bg text-bears-text-onDark p-4 sticky top-0 z-40 transition-transform duration-300"
  x-data="{ mobileMenuOpen: false, lastScrollY: 0, headerHidden: false }"
  x-init="lastScrollY = window.scrollY"
  x-on:scroll.window="
    if (mobileMenuOpen) { headerHidden = false; return; }
    headerHidden = window.scrollY > lastScrollY && window.scrollY > 60;
    lastScrollY = window.scrollY;
  "
  x-bind:class="{ '-translate-y-full': headerHidden }"
>
  <div class="max-w-screen-2xl mx-auto px-5 lg:px-[1vw] py-2">
    <div class="relative flex items-center justify-between lg:gap-4">
      <div class="shrink-0">
        <a href="/" class="text-2xl font-bold text-bears-accent">BEARS</a>
      </div>

      <button
        x-on:click="mobileMenuOpen = !mobileMenuOpen"
        class="lg:hidden text-bears-text-onDark hover:text-bears-accent transition-colors p-2 cursor-pointer"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <div class="hidden lg:flex shrink-0 items-center gap-4 lg:gap-8">
        <input
          type="search"
          placeholder="Search..."
          class="max-w-64 px-3 py-1.5 rounded-lg bg-[#303030] text-bears-text-onDark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-bears-accent"
          disabled
        />

        <nav class="flex items-center justify-end gap-4 lg:gap-8 px-4 lg:px-[2vw]">
          <a href="/projects" class="hover:text-bears-accent transition-colors">Projects</a>
          <a href="/sponsors" class="hover:text-bears-accent transition-colors">Sponsors</a>
          <a href="/events" class="hover:text-bears-accent transition-colors">Events</a>
          <a href="/about-us" class="hover:text-bears-accent transition-colors">About Us</a>
        </nav>

        <div class="flex items-center gap-1 text-sm">
          <button class="hover:text-bears-accent transition-colors">DE</button>
          <span class="text-gray-500">|</span>
          <button class="hover:text-bears-accent transition-colors">ENG</button>
        </div>
      </div>
    </div>

    <div
      x-cloak
      x-show="mobileMenuOpen"
      class="lg:hidden fixed left-0 right-0 top-15 z-50 bg-bears-bg px-4 py-4 border-t border-gray-700 shadow-lg"
      x-on:click.away="mobileMenuOpen = false"
    >
      <div class="mb-4">
        <input
          type="search"
          placeholder="Search..."
          class="w-full px-3 py-2.5 rounded-lg bg-[#303030] text-bears-text-onDark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-bears-accent"
          disabled
        />
      </div>

      <nav class="flex flex-col gap-3">
        <a href="/projects" class="hover:text-bears-accent transition-colors py-2">Projects</a>
        <a href="/sponsors" class="hover:text-bears-accent transition-colors py-2">Sponsors</a>
        <a href="/events" class="hover:text-bears-accent transition-colors py-2">Events</a>
        <a href="/about-us" class="hover:text-bears-accent transition-colors py-2">About Us</a>

        <div class="flex items-center gap-2 pt-3 border-t border-gray-700">
          <span class="text-sm text-gray-400">Language:</span>
          <button class="hover:text-bears-accent transition-colors text-sm">DE</button>
          <span class="text-gray-500">|</span>
          <button class="hover:text-bears-accent transition-colors text-sm">ENG</button>
        </div>
      </nav>
    </div>
  </div>
</header>
