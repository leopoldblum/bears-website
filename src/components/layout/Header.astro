---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/projects", label: "Projects" },
  { href: "/sponsors", label: "Sponsors" },
  { href: "/events", label: "Events" },
  { href: "/about-us", label: "About Us" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header
  class="bg-bears-bg text-bears-text-onDark sticky top-0 z-40 transition-transform duration-300"
  x-data="{ mobileMenuOpen: false, lastScrollY: 0, headerHidden: false }"
  x-init="lastScrollY = window.scrollY"
  x-on:scroll.window="
    if (mobileMenuOpen) { headerHidden = false; return; }
    headerHidden = window.scrollY > lastScrollY && window.scrollY > 60;
    lastScrollY = window.scrollY;
  "
  x-bind:class="{ '-translate-y-full': headerHidden }"
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <div class="flex items-center justify-between">
      <a href="/" class="text-2xl font-bold text-bears-accent shrink-0">BEARS</a>

      <button
        x-on:click="mobileMenuOpen = !mobileMenuOpen"
        class="lg:hidden relative w-10 h-10 flex items-center justify-center text-bears-text-onDark hover:text-bears-accent transition-colors cursor-pointer"
        aria-label="Toggle menu"
        :aria-expanded="mobileMenuOpen"
      >
        <div class="w-5 h-5 relative flex flex-col justify-center items-center">
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? 'rotate-45 translate-y-0' : '-translate-y-1.5'"
          ></span>
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? 'opacity-0 scale-x-0' : 'opacity-100 scale-x-100'"
          ></span>
          <span
            class="absolute h-0.5 w-5 bg-current rounded-full transition-all duration-300 ease-out"
            :class="mobileMenuOpen ? '-rotate-45 translate-y-0' : 'translate-y-1.5'"
          ></span>
        </div>
      </button>

      <div class="hidden lg:flex items-center gap-12">
        <input
          type="search"
          placeholder="Search..."
          class="max-w-64 px-3 py-1.5 rounded-lg bg-[#303030] text-bears-text-onDark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-bears-accent"
          disabled
        />

        <nav class="flex items-center gap-8">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                "transition-colors",
                isActive(href)
                  ? "text-bears-accent"
                  : "hover:text-bears-accent",
              ]}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div
      x-cloak
      x-show="mobileMenuOpen"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-3 scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 -translate-y-3 scale-95"
      x-on:click.away="mobileMenuOpen = false"
      @keydown.escape.window="mobileMenuOpen = false"
      class="lg:hidden fixed left-0 right-0 top-15 z-50 mx-3 sm:mx-4 bg-black/70 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_8px_32px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.05)] overflow-hidden"
    >
      <!-- Accent Gradient Bar -->
      <div class="h-0.5 bg-linear-to-r from-bears-accent via-bears-accent/80 to-transparent"></div>

      <div class="p-5">
        <!-- Search Input -->
        <div class="mb-4">
          <input
            type="search"
            placeholder="Search..."
            class="w-full px-3 py-2.5 rounded-lg bg-white/10 text-bears-text-onDark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-bears-accent border border-white/5"
            disabled
          />
        </div>

        <!-- Nav Links -->
        <nav class="flex flex-col gap-1">
          {navLinks.map(({ href, label }, index) => (
            <a
              href={href}
              class:list={[
                "nav-link group flex items-center gap-3 px-3 py-2.5 rounded-md transition-all duration-150",
                isActive(href)
                  ? "text-bears-accent bg-white/5"
                  : "text-bears-text-onDark/90 hover:text-bears-text-onDark hover:bg-white/5",
              ]}
              style={`animation-delay: ${index * 60}ms`}
            >
              <span
                class:list={[
                  "w-0.5 h-4 bg-bears-accent rounded-full transition-opacity duration-150",
                  isActive(href) ? "opacity-100" : "opacity-0 group-hover:opacity-100",
                ]}
              ></span>
              <span>{label}</span>
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
</header>
