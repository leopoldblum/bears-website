---
const currentYear = new Date().getFullYear();
---

<footer class="bg-bears-bg-light">
  <!-- Accent top separator -->
  <div
    class="h-px bg-gradient-to-r from-transparent via-bears-accent/40 to-transparent"
  >
  </div>

  <div class="container mx-auto px-4 sm:px-8 lg:px-12 pt-12 sm:pt-16 lg:pt-20">
    <!-- Main footer grid: stacks on mobile, horizontal on desktop -->
    <div
      class="flex flex-col lg:grid lg:grid-cols-[auto_1fr_auto] gap-12 lg:gap-16 lg:items-start"
    >
      <!-- Logo + Address -->
      <div class="flex flex-col gap-4 items-center lg:items-start">
        <a
          href="/"
          class="text-bears-accent text-2xl lg:text-3xl font-bold hover:text-bears-accent-muted transition-colors"
        >
          BEARS
        </a>
        <address
          class="not-italic text-sm text-bears-text-onLight/60 leading-relaxed text-center lg:text-left"
        >
          Berlin Experimental Astronautics<br />
          Research Student team e.V.<br />
          c/o TU Berlin - Institut für Luft-<br />
          und Raumfahrt<br />
          Marchstraße 12-14<br />
          10587 Berlin
        </address>
      </div>

      <!-- Navigation -->
      <nav
        class="grid grid-cols-2 gap-x-8 gap-y-10 lg:grid-cols-4 lg:gap-x-12 lg:gap-y-8 justify-items-center lg:justify-items-start"
      >
        <!-- Projects Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a
              href="/projects"
              class="hover:text-bears-accent transition-colors"
            >
              Projects
            </a>
          </h3>
          <a
            href="/projects?status=ongoing"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Current Projects
          </a>
          <a
            href="/projects?status=completed"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Past Projects
          </a>
          <a
            href="#"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Research Areas
          </a>
        </div>

        <!-- Sponsors Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a
              href="/sponsors"
              class="hover:text-bears-accent transition-colors"
            >
              Sponsors
            </a>
          </h3>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Become a Sponsor
          </a>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Sponsorship Tiers
          </a>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Our Partners
          </a>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Benefits
          </a>
        </div>

        <!-- Events Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a
              href="/events"
              class="hover:text-bears-accent transition-colors"
            >
              Events
            </a>
          </h3>
          <a
            href="/events?date=upcoming"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Upcoming Events
          </a>
          <a
            href="/events?category=competitions-and-workshops"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Competitions & Workshops
          </a>
          <a
            href="/events?category=competitions-and-workshops"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Conventions
          </a>
          <a
            href="/events?date=past"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Past Events
          </a>
        </div>

        <!-- About Us Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a
              href="/about-us"
              class="hover:text-bears-accent transition-colors"
            >
              About Us
            </a>
          </h3>
          <a
            href="#"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Our Team
          </a>
          <a
            href="/media"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Media
          </a>
          <a
            href="#"
            class="text-sm text-bears-text-onLight/50 hover:text-bears-accent transition-colors"
          >
            Contact
          </a>
        </div>
      </nav>

      <!-- Social Media Icons -->
      <div
        class="flex gap-3 items-center justify-center lg:justify-end lg:self-center"
      >
        <a
          href="#"
          class="group w-10 h-10 rounded-full bg-bears-text-onLight/10 flex items-center justify-center hover:bg-bears-accent hover:scale-110 transition-all duration-200"
          aria-label="Social media 1"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 32 32"
            class="fill-bears-text-onLight group-hover:fill-white transition-colors duration-200"
          >
            <circle cx="16" cy="16" r="14"></circle>
          </svg>
        </a>
        <a
          href="#"
          class="group w-10 h-10 rounded-full bg-bears-text-onLight/10 flex items-center justify-center hover:bg-bears-accent hover:scale-110 transition-all duration-200"
          aria-label="Social media 2"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 32 32"
            class="fill-bears-text-onLight group-hover:fill-white transition-colors duration-200"
          >
            <circle cx="16" cy="16" r="14"></circle>
          </svg>
        </a>
        <a
          href="#"
          class="group w-10 h-10 rounded-full bg-bears-text-onLight/10 flex items-center justify-center hover:bg-bears-accent hover:scale-110 transition-all duration-200"
          aria-label="Social media 3"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 32 32"
            class="fill-bears-text-onLight group-hover:fill-white transition-colors duration-200"
          >
            <circle cx="16" cy="16" r="14"></circle>
          </svg>
        </a>
        <a
          href="#"
          class="group w-10 h-10 rounded-full bg-bears-text-onLight/10 flex items-center justify-center hover:bg-bears-accent hover:scale-110 transition-all duration-200"
          aria-label="Social media 4"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 32 32"
            class="fill-bears-text-onLight group-hover:fill-white transition-colors duration-200"
          >
            <circle cx="16" cy="16" r="14"></circle>
          </svg>
        </a>
      </div>
    </div>

    <!-- Separator -->
    <div class="h-px bg-bears-text-onLight/10 mt-12 sm:mt-16 lg:mt-20"></div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 sm:pt-8 pb-8 sm:pb-10 lg:pb-12"
    >
      <p class="text-xs text-bears-text-onLight/40">
        &copy; {currentYear} BEARS e.V. All rights reserved.
      </p>
      <div
        class="flex items-center gap-4 text-xs text-bears-text-onLight/40"
      >
        <a
          href="#"
          class="hover:text-bears-accent transition-colors"
        >
          Impressum
        </a>
        <span class="text-bears-text-onLight/20">|</span>
        <a
          href="#"
          class="hover:text-bears-accent transition-colors"
        >
          Datenschutz
        </a>
      </div>
    </div>
  </div>
</footer>
