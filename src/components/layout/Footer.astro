---
import { getPageContent } from "@utils/contentQueries";
import { socialIcons } from "@utils/socialIcons";

const currentYear = new Date().getFullYear();

const socialContent = await getPageContent("site/social-links");
const socialLinks = socialContent?.data.socialLinks ?? [];

const addressContent = await getPageContent("footer/footer-address");
const addressLines = addressContent?.data.items ?? [];

const navContent = await getPageContent("footer/navigation");
const navColumns = navContent?.data.navColumns ?? [
  {
    heading: "Projects", href: "/projects",
    links: [
      { label: "Current Projects", href: "/projects?status=ongoing#what-we-build" },
      { label: "Experimental Rocketry", href: "/projects?category=experimental-rocketry#what-we-build" },
      { label: "Science & Experiments", href: "/projects?category=science-and-experiments#what-we-build" },
      { label: "Robotics", href: "/projects?category=robotics#what-we-build" },
      { label: "Past Projects", href: "/projects?status=completed#what-we-build" },
    ],
  },
  {
    heading: "Sponsors", href: "/sponsors",
    links: [
      { label: "Become a Sponsor", href: "/sponsors#become-a-sponsor-title" },
      { label: "Our Partners", href: "/sponsors#diamond" },
      { label: "Benefits", href: "/sponsors" },
    ],
  },
  {
    heading: "Events", href: "/events",
    links: [
      { label: "Upcoming Events", href: "/events?date=upcoming#whats-happening" },
      { label: "Competitions & Workshops", href: "/events?category=competitions-and-workshops#whats-happening" },
      { label: "Conventions", href: "/events?category=trade-fairs-and-conventions#whats-happening" },
      { label: "Past Events", href: "/events?date=past#whats-happening" },
    ],
  },
  {
    heading: "About Us", href: "/about-us",
    links: [
      { label: "Our Team", href: "/about-us#faces-of-bears-title" },
      { label: "Media", href: "/media" },
      { label: "Contact", href: "/contact" },
      { label: "FAQ", href: "/about-us#faq-title" },
    ],
  },
];

const bottomBarContent = await getPageContent("footer/bottom-bar");
const copyrightText = (bottomBarContent?.data.title ?? "© {year} BEARS e.V. All rights reserved.").replace("{year}", String(currentYear));
const legalLinks = bottomBarContent?.data.navLinks ?? [
  { label: "Impressum", href: "/imprint" },
  { label: "Datenschutz", href: "/datenschutz" },
];

---

<footer class="bg-bears-bg-light">
  <!-- Accent top separator -->
  <div
    class="h-px bg-gradient-to-r from-transparent via-bears-accent/40 to-transparent"
  >
  </div>

  <div class="container mx-auto px-4 sm:px-8 lg:px-12 pt-12 sm:pt-16 lg:pt-20">
    <!-- Main footer content: single row at lg+ via flex + contents -->
    <div
      class="flex flex-col lg:flex-row lg:justify-between lg:items-start gap-12 lg:gap-6 xl:gap-8"
    >
      <!-- Logo + Address -->
      <div class="lg:order-first flex flex-col gap-4 items-center lg:items-start min-w-0">
        <a
          href="/"
          class="text-bears-accent text-2xl lg:text-3xl font-bold hover:text-bears-accent-muted transition-colors"
        >
          BEARS
        </a>
        <address
          class="not-italic text-sm text-bears-text-onLight/70 leading-relaxed text-center lg:text-left"
        >
          {addressLines.length > 0
            ? addressLines.map((line, i) => <>{line}{i < addressLines.length - 1 && <br />}</>)
            : <>Berlin Experimental Astronautics<br />Research Student team e.V.<br />c/o TU Berlin - Institut für Luft- und Raumfahrt<br />Marchstraße 12-14<br />10587 Berlin</>
          }
        </address>
      </div>

      <!-- Navigation: grid on mobile, dissolves into parent flex row at lg -->
      <nav
        class="grid grid-cols-2 gap-x-8 gap-y-10 lg:contents justify-items-center"
      >
        {navColumns.map((column) => (
          <div class="flex flex-col gap-2 text-center lg:text-left min-w-0">
            <h3
              class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
            >
              <a
                href={column.href}
                class="hover:text-bears-accent transition-colors"
              >
                {column.heading}
              </a>
            </h3>
            {column.links.map((link) => (
              <a
                href={link.href}
                class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
              >
                {link.label}
              </a>
            ))}
          </div>
        ))}
      </nav>

      <!-- Social Media Icons -->
      <div
        class="lg:order-last flex gap-3 items-center justify-center shrink-0"
      >
        {
          socialLinks.map((link) => {
            const icon = socialIcons[link.platform];
            if (!icon) return null;
            return (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                x-data="{ hovered: false }"
                x-on:mouseenter="hovered = true"
                x-on:mouseleave="hovered = false"
                x-bind:style={link.hoverColor ? `hovered ? 'background-color: ${link.hoverColor}' : ''` : undefined}
                class:list={[
                  "group w-10 h-10 rounded-full bg-bears-text-onLight/10 flex items-center justify-center hover:scale-110 transition-all duration-200",
                  !link.hoverColor && "hover:bg-bears-accent",
                ]}
                aria-label={icon.label}
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  class="fill-bears-text-onLight group-hover:fill-white transition-colors duration-200"
                >
                  <path d={icon.path} />
                </svg>
              </a>
            );
          })
        }
      </div>
    </div>

    <!-- Separator -->
    <div class="h-px bg-bears-text-onLight/10 mt-12 sm:mt-16 lg:mt-20"></div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 sm:pt-8 pb-8 sm:pb-10 lg:pb-12"
    >
      <p class="text-xs text-bears-text-onLight/60">
        {copyrightText}
      </p>
      <div class="flex items-center gap-4 text-xs text-bears-text-onLight/60">
        {legalLinks.map((link, i) => (
          <>
            {i > 0 && <span class="text-bears-text-onLight/30">|</span>}
            <a href={link.href} class="hover:text-bears-accent transition-colors">
              {link.label}
            </a>
          </>
        ))}
      </div>
    </div>
  </div>
</footer>
