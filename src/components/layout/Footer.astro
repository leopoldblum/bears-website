---
import { getPageContent } from "@utils/contentQueries";

const currentYear = new Date().getFullYear();

const socialContent = await getPageContent("footer/social-links");
const socialLinks = socialContent?.data.socialLinks ?? [];

const addressContent = await getPageContent("footer/footer-address");
const addressLines = addressContent?.data.items ?? [];

const socialIcons: Record<string, { label: string; path: string }> = {
  instagram: {
    label: "Instagram",
    path: "M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z",
  },
  linkedin: {
    label: "LinkedIn",
    path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
  youtube: {
    label: "YouTube",
    path: "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
};
---

<footer class="bg-bears-bg-light">
  <!-- Accent top separator -->
  <div
    class="h-px bg-gradient-to-r from-transparent via-bears-accent/40 to-transparent"
  >
  </div>

  <div class="container mx-auto px-4 sm:px-8 lg:px-12 pt-12 sm:pt-16 lg:pt-20">
    <!-- Main footer grid: stacks on mobile, horizontal on desktop -->
    <div
      class="flex flex-col lg:grid lg:grid-cols-[auto_1fr_auto] gap-12 lg:gap-16 lg:items-start"
    >
      <!-- Logo + Address -->
      <div class="flex flex-col gap-4 items-center lg:items-start">
        <a
          href="/"
          class="text-bears-accent text-2xl lg:text-3xl font-bold hover:text-bears-accent-muted transition-colors"
        >
          BEARS
        </a>
        <address
          class="not-italic text-sm text-bears-text-onLight/70 leading-relaxed text-center lg:text-left"
        >
          {addressLines.length > 0
            ? addressLines.map((line, i) => <>{line}{i < addressLines.length - 1 && <br />}</>)
            : <>Berlin Experimental Astronautics<br />Research Student team e.V.<br />c/o TU Berlin - Institut für Luft- und Raumfahrt<br />Marchstraße 12-14<br />10587 Berlin</>
          }
        </address>
      </div>

      <!-- Navigation -->
      <nav
        class="grid grid-cols-2 gap-x-8 gap-y-10 lg:grid-cols-4 lg:gap-x-12 lg:gap-y-8 justify-items-center lg:justify-items-start"
      >
        <!-- Projects Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a
              href="/projects"
              class="hover:text-bears-accent transition-colors"
            >
              Projects
            </a>
          </h3>
          <a
            href="/projects?status=ongoing"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Current Projects
          </a>
          <a
            href="/projects?status=completed"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Past Projects
          </a>
          <a
            href="#"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Research Areas
          </a>
        </div>

        <!-- Sponsors Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a
              href="/sponsors"
              class="hover:text-bears-accent transition-colors"
            >
              Sponsors
            </a>
          </h3>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Become a Sponsor
          </a>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Sponsorship Tiers
          </a>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Our Partners
          </a>
          <a
            href="/sponsors"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Benefits
          </a>
        </div>

        <!-- Events Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a href="/events" class="hover:text-bears-accent transition-colors">
              Events
            </a>
          </h3>
          <a
            href="/events?date=upcoming"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Upcoming Events
          </a>
          <a
            href="/events?category=competitions-and-workshops"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Competitions & Workshops
          </a>
          <a
            href="/events?category=competitions-and-workshops"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Conventions
          </a>
          <a
            href="/events?date=past"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Past Events
          </a>
        </div>

        <!-- About Us Column -->
        <div class="flex flex-col gap-2 text-center lg:text-left">
          <h3
            class="text-sm lg:text-base font-semibold uppercase tracking-wider text-bears-text-onLight mb-3"
          >
            <a
              href="/about-us"
              class="hover:text-bears-accent transition-colors"
            >
              About Us
            </a>
          </h3>
          <a
            href="#"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Our Team
          </a>
          <a
            href="/media"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Media
          </a>
          <a
            href="/contact"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            Contact
          </a>
          <a
            href="/about-us#faq"
            class="text-sm text-bears-text-onLight/70 hover:text-bears-accent transition-colors"
          >
            FAQ
          </a>
        </div>
      </nav>

      <!-- Social Media Icons -->
      <div
        class="flex gap-3 items-center justify-center lg:justify-end lg:self-center"
      >
        {
          socialLinks.map((link) => {
            const icon = socialIcons[link.platform];
            if (!icon) return null;
            return (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                x-data="{ hovered: false }"
                x-on:mouseenter="hovered = true"
                x-on:mouseleave="hovered = false"
                x-bind:style={link.hoverColor ? `hovered ? 'background-color: ${link.hoverColor}' : ''` : ''}
                class:list={[
                  "group w-10 h-10 rounded-full bg-bears-text-onLight/10 flex items-center justify-center hover:scale-110 transition-all duration-200",
                  !link.hoverColor && "hover:bg-bears-accent",
                ]}
                aria-label={icon.label}
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  class="fill-bears-text-onLight group-hover:fill-white transition-colors duration-200"
                >
                  <path d={icon.path} />
                </svg>
              </a>
            );
          })
        }
      </div>
    </div>

    <!-- Separator -->
    <div class="h-px bg-bears-text-onLight/10 mt-12 sm:mt-16 lg:mt-20"></div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 sm:pt-8 pb-8 sm:pb-10 lg:pb-12"
    >
      <p class="text-xs text-bears-text-onLight/60">
        &copy; {currentYear} BEARS e.V. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-xs text-bears-text-onLight/60">
        <a href="/imprint" class="hover:text-bears-accent transition-colors">
          Impressum
        </a>
        <span class="text-bears-text-onLight/30">|</span>
        <a href="#" class="hover:text-bears-accent transition-colors">
          Datenschutz
        </a>
      </div>
    </div>
  </div>
</footer>
