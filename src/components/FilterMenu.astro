---
import CategoryFilter from "./CategoryFilter.astro";

interface FilterGroup {
  /**
   * Label displayed above the filter group (e.g., "Category", "Date")
   */
  label: string;

  /**
   * Alpine.js state variable name (e.g., "activeCategory", "dateFilter")
   */
  stateVariable: string;

  /**
   * Array of category values to display as filter options
   */
  categories: string[];

  /**
   * Mapping of category values to human-readable labels
   */
  categoryLabels: Record<string, string>;
}

interface Props {
  /**
   * Array of filter groups to display in the dropdown
   */
  filterGroups: FilterGroup[];
}

const { filterGroups } = Astro.props;
---

<div class="relative inline-block">
  <!-- Filter Icon Button -->
  <button
    type="button"
    @click="filterMenuOpen = !filterMenuOpen"
    class="p-2 rounded-lg border border-bears-accent-muted text-bears-text-onDark hover:bg-bears-accent hover:border-bears-accent transition-all duration-200 cursor-pointer"
    aria-label="Toggle filters"
    :aria-expanded="filterMenuOpen"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-5 h-5"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
      />
    </svg>
  </button>

  <!-- Active Filter Indicator Dot -->
  <span
    x-show="hasActiveFilters"
    x-cloak
    class="absolute -top-1 -right-1 w-3 h-3 bg-bears-accent rounded-full border-2 border-bears-bg"
  ></span>

  <!-- Dropdown Panel -->
  <div
    x-cloak
    x-show="filterMenuOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    @click.away="filterMenuOpen = false"
    @keydown.escape.window="filterMenuOpen = false"
    class="absolute right-0 top-full mt-2 z-30 w-72 sm:w-80 bg-bears-bg border border-bears-accent-muted rounded-lg shadow-xl p-4"
  >
    <!-- Panel Header -->
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-bears-text-onDark">Filters</h3>
      <button
        type="button"
        @click="clearFilters()"
        class="text-sm text-bears-accent hover:text-bears-text-onDark transition-colors cursor-pointer"
      >
        Clear all
      </button>
    </div>

    <!-- Filter Groups -->
    {filterGroups.map((group, index) => (
      <div class={index < filterGroups.length - 1 ? "mb-4" : ""}>
        <h4 class="text-sm font-medium text-bears-text-muted mb-2">{group.label}</h4>
        <div @click="currentPage = 1">
          <CategoryFilter
            categories={group.categories}
            categoryLabels={group.categoryLabels}
            stateVariable={group.stateVariable}
          />
        </div>
      </div>
    ))}
  </div>
</div>
