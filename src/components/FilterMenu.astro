---
import CategoryFilter from "./CategoryFilter.astro";

interface FilterGroup {
  /**
   * Label displayed above the filter group (e.g., "Category", "Date")
   */
  label: string;

  /**
   * Alpine.js state variable name (e.g., "activeCategory", "dateFilter")
   */
  stateVariable: string;

  /**
   * Array of category values to display as filter options
   */
  categories: string[];

  /**
   * Mapping of category values to human-readable labels
   */
  categoryLabels: Record<string, string>;
}

interface Props {
  /**
   * Array of filter groups to display in the dropdown
   */
  filterGroups: FilterGroup[];
}

const { filterGroups } = Astro.props;
---

<div class="relative inline-block">
  <!-- Filter Trigger Button -->
  <button
    type="button"
    @click="filterMenuOpen = !filterMenuOpen"
    :class="hasActiveFilters ? 'border-bears-accent bg-bears-accent/10' : 'border-white/20 hover:border-bears-accent/50'"
    class="relative flex items-center gap-2 px-3 py-2 rounded-lg border text-bears-text-onDark transition-all duration-200 cursor-pointer group"
    aria-label="Toggle filters"
    :aria-expanded="filterMenuOpen"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-4 h-4 transition-colors"
      :class="hasActiveFilters ? 'text-bears-accent' : 'text-bears-text-onDark group-hover:text-bears-accent'"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
      ></path>
    </svg>
    <span class="text-sm font-medium hidden sm:inline">Filter</span>

    <!-- Active Filter Count Badge -->
    <span
      x-show="hasActiveFilters"
      x-cloak
      x-transition:enter="transition ease-out duration-150"
      x-transition:enter-start="scale-0 opacity-0"
      x-transition:enter-end="scale-100 opacity-100"
      x-transition:leave="transition ease-in duration-100"
      x-transition:leave-start="scale-100 opacity-100"
      x-transition:leave-end="scale-0 opacity-0"
      class="absolute -top-2 -right-2 min-w-5 h-5 flex items-center justify-center px-1.5 text-xs font-bold bg-bears-accent text-white rounded-full shadow-[0_0_10px_rgba(197,14,31,0.5)]"
      x-text="(typeof activeCategory !== 'undefined' ? activeCategory.length : 0) + (typeof dateFilter !== 'undefined' ? dateFilter.length : 0) + (typeof completionStatus !== 'undefined' ? completionStatus.length : 0)"
    ></span>
  </button>

  <!-- Dropdown Panel -->
  <div
    x-cloak
    x-show="filterMenuOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-3 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 -translate-y-3 scale-95"
    @click.away="filterMenuOpen = false"
    @keydown.escape.window="filterMenuOpen = false"
    class="absolute right-0 top-full mt-3 z-30 w-72 sm:w-80 bg-black/70 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_8px_32px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.05)] overflow-hidden"
  >
    <!-- Accent Bar -->
    <div
      class="h-0.5 bg-linear-to-r from-bears-accent via-bears-accent/80 to-transparent"
    >
    </div>

    <!-- Panel Content -->
    <div class="p-5">
      <!-- Panel Header -->
      <div class="flex items-center justify-between mb-5">
        <h3
          class="text-base font-semibold text-bears-text-onDark tracking-wide uppercase select-none"
        >
          Filters
        </h3>
        <button
          type="button"
          @click="clearFilters()"
          x-show="hasActiveFilters"
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          class="flex items-center gap-1.5 text-xs font-medium text-bears-accent hover:text-white transition-colors cursor-pointer group/clear"
        >
          <svg
            class="w-3.5 h-3.5 transition-transform group-hover/clear:rotate-90"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
          Clear all
        </button>
      </div>

      <!-- Filter Groups -->
      {
        filterGroups.map((group, index) => (
          <div
            class={`filter-group ${index < filterGroups.length - 1 ? "mb-5 pb-5 border-b border-white/5" : ""}`}
            style={`animation-delay: ${index * 60}ms`}
          >
            <h4 class="text-xs font-semibold text-bears-text-onDark/60 mb-3 uppercase tracking-wider select-none">
              {group.label}
            </h4>
            <div @click="currentPage = 1">
              <CategoryFilter
                categories={group.categories}
                categoryLabels={group.categoryLabels}
                stateVariable={group.stateVariable}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
