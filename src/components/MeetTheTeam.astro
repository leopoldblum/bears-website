---
// MeetTheTeam component
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import defaultProjectImage from '../assets/default-images/default-project.jpg';
import { loadImagesForCollection } from '../utils/imageLoader';

// Fetch projects that should be displayed in MeetTheTeam accordion
const allProjects = await getCollection('posts', ({ id, data }) => {
  return id.startsWith('projects/') &&
         data.displayMeetTheTeam === true &&
         (import.meta.env.DEV || !data.isDraft);
});

// Sort by date descending (newest first) and limit to 5 projects
const sortedProjects = allProjects
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5); // Limit to maximum 5 projects

// Load images for all projects
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/projects/*.{jpg,jpeg,png,webp}");
const projects = await loadImagesForCollection({
  glob: images,
  collection: sortedProjects,
  baseDir: '/src/assets/projects',
  imageField: 'coverImage',
  fallbackImage: defaultProjectImage,
  postType: 'project'
});
---

<section class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24">
  <!-- Headline in top left -->
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 sm:mb-8 lg:mb-12 text-bears-text-onDark">Meet the Team</h2>

  <!-- 3-column grid: thumbnails | main image | accordion -->
  <div class="grid grid-cols-1 lg:grid-cols-[120px_1fr_400px] gap-6 lg:gap-8" x-data="{ activeProject: 0 }">

    <!-- Left: Thumbnail Stack -->
    <div class="flex flex-row lg:flex-col lg:justify-between gap-3 overflow-x-auto lg:overflow-y-auto lg:overflow-x-visible lg:h-[550px]">
      {projects.map((project, index) => (
        <button
          type="button"
          class="shrink-0 w-24 h-24 aspect-square rounded-lg overflow-hidden border-2 transition-all duration-200"
          x-bind:class={`activeProject === ${index} ? 'border-bears-accent scale-100' : 'border-transparent scale-95 hover:scale-100'`}
          x-on:click={`activeProject = ${index}`}
          aria-label={`View ${project.data.title} project`}
        >
          <Image
            src={project.loadedImage || defaultProjectImage}
            alt={project.data.title}
            class="w-full h-full object-cover"
            loading="eager"
            format="webp"
          />
        </button>
      ))}
    </div>

    <!-- Middle: Main Image -->
    <div class="relative w-full aspect-4/3 lg:aspect-auto lg:h-[550px] rounded-lg overflow-hidden">
      {projects.map((project, index) => (
        <div
          class="absolute inset-0 transition-opacity duration-300"
          x-bind:class={`activeProject === ${index} ? 'opacity-100 z-10' : 'opacity-0 z-0'`}
        >
          <Image
            src={project.loadedImage || defaultProjectImage}
            alt={project.data.title}
            class="w-full h-full object-cover"
            loading="eager"
            format="webp"
          />
        </div>
      ))}
    </div>

    <!-- Right: Projects Accordion -->
    <div class="flex flex-col lg:h-[550px] overflow-y-auto lg:border-y lg:border-bears-text-onDark/20">
      {projects.map((project, index) => (
        <div class="border-t border-b border-bears-text-onDark/20">
          <button
            type="button"
            class="w-full text-left py-4 px-2 text-base sm:text-lg font-semibold text-bears-text-onDark hover:text-bears-accent transition-colors duration-200 cursor-pointer"
            x-on:click={`activeProject !== ${index} && (activeProject = ${index})`}
            aria-expanded={index === 0 ? "true" : "false"}
            aria-controls={`project-${index}`}
          >
            {project.data.title}
          </button>

          <div
            id={`project-${index}`}
            class="grid transition-[grid-template-rows] duration-300 ease-in-out"
            x-bind:class={`activeProject === ${index} ? 'grid-rows-[1fr]' : 'grid-rows-[0fr]'`}
          >
            <div class="overflow-hidden">
              <div class="pb-4 px-2">
                {project.data.headOfProject && (
                  <p class="text-xs sm:text-sm text-bears-accent font-medium mb-2">
                    {project.data.headOfProject}
                  </p>
                )}
                <p class="text-sm sm:text-base text-bears-text-onDark/90 leading-relaxed">
                  {project.data.description}
                </p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
