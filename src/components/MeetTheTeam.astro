---
// MeetTheTeam component
import { Image } from 'astro:assets';
import { loadCollectionImages } from '../utils/imageLoader';
import { getMeetTheTeamProjects } from '../utils/contentQueries';

// Get projects for MeetTheTeam section (filtered and sorted)
const sortedProjects = await getMeetTheTeamProjects();

// Load images for all projects
const projects = await loadCollectionImages(sortedProjects, 'project');
---

<section class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24">
  <!-- Headline in top left -->
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 sm:mb-8 lg:mb-12 text-bears-text-onDark">Meet the Team</h2>

  <!-- Responsive layout: flex-col for lg, grid for xl -->
  <div
    class="flex flex-col gap-6 lg:gap-8 xl:grid xl:grid-cols-[120px_minmax(0,2fr)_minmax(0,1fr)]"
    x-data="{ activeIndex: 0 }"
    x-init="$nextTick(() => {
      const syncHeight = () => {
        const img = $refs.mainImage;
        const thumbs = $refs.thumbnails;
        const accordion = $refs.accordion;
        if (img && window.innerWidth >= 1280) {
          const height = img.offsetHeight + 'px';
          if (thumbs) thumbs.style.height = height;
          if (accordion) accordion.style.height = height;
        }
      };
      syncHeight();
      window.addEventListener('resize', syncHeight);

      $watch('activeIndex', (index) => {
        const thumbs = $refs.thumbnails;
        if (thumbs) {
          const btn = thumbs.children[index];
          if (btn) btn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        const hThumbs = $refs.horizontalThumbnails;
        if (hThumbs) {
          const btn = hThumbs.children[index];
          if (btn) {
            const scrollLeft = btn.offsetLeft - hThumbs.offsetWidth / 2 + btn.offsetWidth / 2;
            hThumbs.scrollTo({ left: scrollLeft, behavior: 'smooth' });
          }
        }
      });
    })"
  >

    <!-- Thumbnail Stack for xl: only (vertical on left) -->
    <div x-ref="thumbnails" class="hidden xl:flex flex-col gap-3 overflow-y-auto">
      {projects.map((project, index) => (
        <button
          type="button"
          class="shrink-0 w-24 h-24 aspect-square rounded-lg overflow-hidden border-2 transition-all duration-200 hover:cursor-pointer"
          x-bind:class={`activeIndex === ${index} ? 'border-bears-accent scale-100' : 'border-transparent scale-95 hover:scale-100'`}
          x-on:click={`activeIndex = ${index}`}
          aria-label={`View ${project.data.title} project`}
        >
          <Image
            src={project.loadedImage}
            alt={project.data.title}
            class="w-full h-full object-cover"
            loading="eager"
            format="webp"
          />
        </button>
      ))}
    </div>

    <!-- Two-column grid for lg and xl (becomes 2nd and 3rd columns in xl's 3-col grid) -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px] xl:grid-cols-subgrid xl:col-span-2 gap-6 lg:gap-8">

      <!-- Left column: thumbnails + image -->
      <div class="flex flex-col gap-3 lg:gap-4">

        <!-- Thumbnail Row for < xl: (horizontal above image) -->
        <div x-ref="horizontalThumbnails" class="flex flex-row gap-3 pb-2 sm:pb-0 overflow-x-auto sm:justify-center xl:hidden">
          {projects.map((project, index) => (
            <button
              type="button"
              class="shrink-0 w-24 h-24 aspect-square rounded-lg overflow-hidden border-2 transition-all duration-200 hover:cursor-pointer"
              x-bind:class={`activeIndex === ${index} ? 'border-bears-accent scale-100' : 'border-transparent scale-95 hover:scale-100'`}
              x-on:click={`activeIndex = ${index}`}
              aria-label={`View ${project.data.title} project`}
            >
              <Image
                src={project.loadedImage}
                alt={project.data.title}
                class="w-full h-full object-cover"
                loading="eager"
                format="webp"
              />
            </button>
          ))}
        </div>

        <!-- Main Image -->
        <div x-ref="mainImage" class="relative w-full aspect-4/3 rounded-lg overflow-hidden">
          {projects.map((project, index) => (
            <button
              type="button"
              class="absolute inset-0 transition-opacity duration-300"
              x-bind:class={`activeIndex === ${index} ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'`}
              x-on:click={`activeIndex = ${index}`}
              aria-label={`View ${project.data.title} project details`}
            >
              <Image
                src={project.loadedImage}
                alt={project.data.title}
                class="w-full h-full object-cover"
                loading="eager"
                format="webp"
              />
            </button>
          ))}
        </div>

      </div>

      <!-- Projects Accordion -->
      <div x-ref="accordion" class="flex flex-col lg:h-[550px] xl:h-auto overflow-y-auto">
        <div class="flex flex-col gap-2">
          {projects.map((project, index) => {
            const itemId = `team-accordion-${index}`;
            const isNotLast = index < projects.length - 1;

            return (
              <div
                class="accordion-item rounded-lg overflow-hidden"
                style={`animation-delay: ${index * 60}ms`}
              >
                <button
                  type="button"
                  class="flex items-center justify-between w-full text-left py-3.5 px-4 text-base sm:text-lg font-semibold text-bears-text-onDark hover:bg-white/5 transition-all duration-200 cursor-pointer group"
                  x-on:click={`activeIndex = ${index}`}
                  x-bind:aria-expanded={`activeIndex === ${index} ? 'true' : 'false'`}
                  aria-controls={itemId}
                >
                  <span>{project.data.title}</span>
                  <svg
                    class="w-4 h-4 flex-shrink-0 ml-3 transition-all duration-200"
                    x-bind:class={`activeIndex === ${index} ? 'rotate-180 text-bears-accent' : 'rotate-0 text-bears-text-onDark/60 group-hover:text-bears-accent'`}
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>

                <div
                  id={itemId}
                  class="grid transition-[grid-template-rows] duration-200 ease-in-out"
                  x-bind:class={`activeIndex === ${index} ? 'grid-rows-[1fr]' : 'grid-rows-[0fr]'`}
                >
                  <div class="overflow-hidden">
                    <div class="px-4 pb-4">
                      {project.data.headOfProject && (
                        <p class="text-xs sm:text-sm text-bears-accent font-medium mb-2">
                          {project.data.headOfProject}
                        </p>
                      )}
                      <div
                        class="text-sm sm:text-base text-bears-text-onDark/90 leading-relaxed"
                        set:html={project.data.description}
                      />
                    </div>
                  </div>
                </div>

                {isNotLast && (
                  <div class="border-b border-white/5 mx-4"></div>
                )}
              </div>
            );
          })}
        </div>
      </div>

    </div>

  </div>
</section>
