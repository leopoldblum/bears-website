---
// MeetTheTeam component
import { Image } from 'astro:assets';
import { loadCollectionImages } from '../utils/imageLoader';
import { getMeetTheTeamProjects } from '../utils/contentQueries';
import Accordion from './reusable/Accordion.astro';

// Get projects for MeetTheTeam section (filtered and sorted)
const sortedProjects = await getMeetTheTeamProjects();

// Load images for all projects
const projects = await loadCollectionImages(sortedProjects, 'project');
---

<section class="container mx-auto px-4 sm:px-8 lg:px-16 py-16 sm:py-20 lg:py-24">
  <!-- Headline in top left -->
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 sm:mb-8 lg:mb-12 text-bears-text-onDark">Meet the Team</h2>

  <!-- 3-column grid: thumbnails | main image | accordion -->
  <div
    class="grid grid-cols-1 lg:grid-cols-[120px_1fr_400px] gap-6 lg:gap-8"
    x-data="{ activeProject: 0 }"
    x-init="$watch(() => $refs.teamAccordion?.activeIndex, value => { if (value !== undefined) activeProject = value })"
  >

    <!-- Left: Thumbnail Stack -->
    <div class="flex flex-row lg:flex-col lg:justify-between gap-3 overflow-x-auto lg:overflow-y-auto lg:overflow-x-visible lg:h-[550px]">
      {projects.map((project, index) => (
        <button
          type="button"
          class="shrink-0 w-24 h-24 aspect-square rounded-lg overflow-hidden border-2 transition-all duration-200 hover:cursor-pointer"
          x-bind:class={`activeProject === ${index} ? 'border-bears-accent scale-100' : 'border-transparent scale-95 hover:scale-100'`}
          x-on:click={`activeProject = ${index}; if ($refs.teamAccordion) $refs.teamAccordion.activeIndex = ${index}`}
          aria-label={`View ${project.data.title} project`}
        >
          <Image
            src={project.loadedImage}
            alt={project.data.title}
            class="w-full h-full object-cover"
            loading="eager"
            format="webp"
          />
        </button>
      ))}
    </div>

    <!-- Middle: Main Image -->
    <div class="relative w-full aspect-4/3 lg:aspect-auto lg:h-[550px] rounded-lg overflow-hidden">
      {projects.map((project, index) => (
        <div
          class="absolute inset-0 transition-opacity duration-300"
          x-bind:class={`activeProject === ${index} ? 'opacity-100 z-10' : 'opacity-0 z-0'`}
        >
          <Image
            src={project.loadedImage}
            alt={project.data.title}
            class="w-full h-full object-cover"
            loading="eager"
            format="webp"
          />
        </div>
      ))}
    </div>

    <!-- Right: Projects Accordion -->
    <Accordion
      x-ref="teamAccordion"
      items={projects.map(p => ({
        title: p.data.title,
        subtitle: p.data.headOfProject,
        content: p.data.description
      }))}
      defaultOpen={0}
      maxHeight="lg:h-[550px]"
    />

  </div>
</section>
