---
// Center - Horizontal centering wrapper component
// Usage: Wrap any content to center it horizontally
// Multiple children will be stacked vertically with consistent spacing

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={`flex flex-col items-center gap-4 w-full max-w-full ${className || ''}`}>
  <slot />
</div>
