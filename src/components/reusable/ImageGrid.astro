---
// ImageGrid - Reusable component for displaying images in a responsive grid
// Features: configurable columns, square (grid) or native (masonry) aspect ratios, responsive sizing, hover effects, smart lazy loading, required alt text

import type { ImageWithAlt } from "@types";
import Img from "@mdx/Img.astro";

interface Props {
  /** Array of images with alt text to display in the grid */
  images: ImageWithAlt[];
  /** Number of columns in the grid (default: 4) */
  cols?: 2 | 3 | 4 | 5 | 6;
  /** Gap between images (default: 'md') */
  gap?: "sm" | "md" | "lg";
  /** Additional CSS classes for the grid container */
  class?: string;
  /** Whether to enable click-to-enlarge functionality (default: true) */
  enableClickToEnlarge?: boolean;
  /** Aspect ratio mode: 'square' crops to 1:1, 'native' uses masonry column layout (default: 'square') */
  aspectRatio?: "square" | "native";
}

const {
  images,
  cols = 4,
  gap = "md",
  class: className,
  enableClickToEnlarge = true,
  aspectRatio = "square",
} = Astro.props;

// Grid column classes - responsive breakpoints (square mode)
const colClasses: Record<number, string> = {
  2: "grid-cols-2",
  3: "grid-cols-2 sm:grid-cols-3",
  4: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4",
  5: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-5",
  6: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-6",
};

// Gap classes - responsive spacing
const gapClasses: Record<string, string> = {
  sm: "gap-2",
  md: "gap-3 lg:gap-4",
  lg: "gap-4 lg:gap-6",
};

// Responsive image sizes matching grid columns
// Helps browser select optimal image from srcset
const sizeClasses: Record<number, string> = {
  2: "50vw",
  3: "(min-width: 640px) 33vw, 50vw",
  4: "(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw",
  5: "(min-width: 1024px) 20vw, (min-width: 640px) 33vw, 50vw",
  6: "(min-width: 1024px) 17vw, (min-width: 640px) 33vw, 50vw",
};

const gridCols = colClasses[cols] ?? colClasses[4];
const gridGap = gapClasses[gap] ?? gapClasses["md"];
const imageSizes = sizeClasses[cols] ?? sizeClasses[4];

// --- Masonry layout (native mode) ---

// Responsive column widths: [mobile%, sm%, lg%]
const masonryWidths: Record<number, [string, string, string]> = {
  2: ["50%", "50%", "50%"],
  3: ["50%", "33.333%", "33.333%"],
  4: ["50%", "33.333%", "25%"],
  5: ["50%", "33.333%", "20%"],
  6: ["50%", "33.333%", "16.666%"],
};

// Masonry gap: horizontal padding on columns + vertical gap within columns
const masonryColPadding: Record<string, string> = {
  sm: "px-1",
  md: "px-1.5 lg:px-2",
  lg: "px-2 lg:px-3",
};

const masonryColGap: Record<string, string> = {
  sm: "gap-2",
  md: "gap-3 lg:gap-4",
  lg: "gap-4 lg:gap-6",
};

// Distribute images into columns (round-robin) preserving original index
interface ImageWithOriginalIndex extends ImageWithAlt {
  originalIndex: number;
}

const [mobileWidth, smWidth, lgWidth] = masonryWidths[cols] ?? masonryWidths[4];
const colPadding = masonryColPadding[gap] ?? masonryColPadding["md"];
const colGap = masonryColGap[gap] ?? masonryColGap["md"];

const masonryColumns: ImageWithOriginalIndex[][] = (() => {
  if (aspectRatio !== "native") return [];
  const columns: ImageWithOriginalIndex[][] = Array.from({ length: cols }, () => []);
  // Track cumulative height of each column (relative, since all images display at equal width)
  const columnHeights = new Array(cols).fill(0);

  images.forEach((img, i) => {
    // Place each image in the shortest column for balanced heights
    let shortestCol = 0;
    for (let c = 1; c < cols; c++) {
      if (columnHeights[c] < columnHeights[shortestCol]) {
        shortestCol = c;
      }
    }
    columns[shortestCol].push({ ...img, originalIndex: i });
    columnHeights[shortestCol] += img.image.height / img.image.width;
  });
  return columns;
})();
---

{aspectRatio === "native" ? (
  <!-- MASONRY MODE: Column-based flex layout for true image wall -->
  <div
    class={`not-prose masonry-row flex flex-wrap px-4 sm:px-6 py-3 ${className || ""}`}
    style={`--masonry-sm-width: ${smWidth}; --masonry-lg-width: ${lgWidth};`}
  >
    {masonryColumns.map((column) => (
      <div
        class={`masonry-column flex flex-col ${colPadding} ${colGap}`}
        style={`flex: 0 0 ${mobileWidth}; max-width: ${mobileWidth};`}
      >
        {column.map((item) => (
          <div class="overflow-hidden rounded-lg group/image ring-0 ring-bears-accent transition-all duration-300 hover:ring-2">
            <Img
              src={item.image}
              alt={item.alt}
              class="w-full h-auto object-cover transition-transform duration-300 group-hover/image:scale-105"
              width="100%"
              sizes={imageSizes}
              loading={item.originalIndex <= cols * 2 ? "eager" : "lazy"}
              enableClickToEnlarge={enableClickToEnlarge}
            />
          </div>
        ))}
      </div>
    ))}
  </div>
) : (
  <!-- SQUARE MODE: CSS Grid with 1:1 aspect ratio -->
  <div
    class={`not-prose grid ${gridCols} ${gridGap} items-center px-4 sm:px-6 py-3 ${className || ""}`}
  >
    {images.map(({ image, alt }, index) => (
      <div class="square-grid-item overflow-hidden rounded-lg group/image ring-0 ring-bears-accent transition-all duration-300 hover:ring-2">
        <div class="w-full h-full">
          <Img
            src={image}
            alt={alt}
            class="w-full h-full object-cover object-center transition-transform duration-300 group-hover/image:scale-105"
            width="100%"
            sizes={imageSizes}
            loading={index <= cols * 2 ? "eager" : "lazy"}
            enableClickToEnlarge={enableClickToEnlarge}
          />
        </div>
      </div>
    ))}
  </div>
)}

<style>
  /* SQUARE MODE ONLY */
  .square-grid-item {
    position: relative;
    aspect-ratio: 1 / 1;
  }

  .square-grid-item picture,
  .square-grid-item img {
    display: block;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
  }

  /* MASONRY MODE: Responsive column widths via CSS custom properties */
  @media (min-width: 640px) {
    .masonry-column {
      flex-basis: var(--masonry-sm-width) !important;
      max-width: var(--masonry-sm-width) !important;
    }
  }

  @media (min-width: 1024px) {
    .masonry-column {
      flex-basis: var(--masonry-lg-width) !important;
      max-width: var(--masonry-lg-width) !important;
    }
  }

  /* Ensure Img component internals fill column width */
  .masonry-column :global(.img-better) {
    width: 100%;
    height: auto;
  }

  .masonry-column :global(picture),
  .masonry-column :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
