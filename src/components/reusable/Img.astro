---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type WidthValue =
  | `${number}%`  // Percentage strings (e.g., "50%", "100%")
  | number;       // Pixel values

interface Props {
  src: string | ImageMetadata; // String URL or imported image
  alt: string;  // Required for accessibility
  class?: string;
  width?: WidthValue;
  height?: number;
  loading?: 'eager' | 'lazy';
  priority?: boolean;
}

const { src, alt, class: className, width, height, loading, priority } = Astro.props;

// Loading strategy
const autoLoading = loading ?? 'lazy';

// Base classes
const defaultClasses = 'h-auto object-cover';
const finalClasses = `${defaultClasses} ${className ?? ''}`;

// Determine if src is an imported image or URL string
const isImportedImage = typeof src === 'object' && 'src' in src;

// Handle width values
const isPercentageWidth = typeof width === 'string' && width.endsWith('%');
const widthStyle = isPercentageWidth ? `width: ${width}` : undefined;
const numericWidth = typeof width === 'number' ? width : undefined;
---

{isImportedImage ? (
  <!-- Optimized image from src/assets -->
  <Image
    src={src as ImageMetadata}
    alt={alt}
    width={numericWidth}
    height={height}
    class={finalClasses}
    style={widthStyle}
    loading={autoLoading}
    decoding={priority ? 'sync' : 'async'}
  />
) : (
  <!-- External URL - fallback to regular img tag -->
  <img
    src={src as string}
    alt={alt}
    width={numericWidth}
    height={height}
    class={finalClasses}
    style={widthStyle}
    loading={autoLoading}
    fetchpriority={priority ? 'high' : undefined}
  />
)}