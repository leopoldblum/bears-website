---
// PageHeroImage Component - Full viewport height hero with background image
// Displays a title in the bottom left quadrant with gradient overlay

import Img_better from "../mdx/Img_better.astro";
import type { ImageMetadata } from "astro";

interface Props {
  /** Background image to display */
  image: ImageMetadata;
  /** Alt text for the background image */
  alt: string;
  /** Title text displayed in bottom left */
  title: string;
  /** Optional subtitle text displayed below title */
  subtitle?: string;
  /** Additional CSS classes */
  class?: string;
  /** Loading strategy for the image - 'eager' for above-fold, 'lazy' for below-fold */
  loading?: "eager" | "lazy";
}

const {
  image,
  alt,
  title,
  subtitle,
  class: className,
  loading = "eager",
} = Astro.props;
---

<section
  class={`relative h-[50vh] lg:h-[60vh] w-full max-w-[2560px] mx-auto overflow-hidden ${className || ""}`}
>
  {/* Background Image Layer */}
  <div class="absolute inset-0 z-0">
    <Img_better
      src={image}
      alt={alt}
      class="w-full h-full object-cover"
      loading={loading}
      sizes="(min-width: 2560px) 2560px, 100vw"
      enableClickToEnlarge={false}
      fetchpriority="high"
    />
  </div>

  {/* Gradient overlay for text readability - similar to LandingHero */}
  <div
    class="absolute inset-0 bg-gradient-to-r from-bears-bg/80 via-bears-bg/40 to-transparent z-10"
  >
  </div>

  {/* Bottom gradient for better text contrast */}
  <div
    class="absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t from-bears-bg via-bears-bg/60 to-transparent pointer-events-none z-10"
  >
  </div>

  {
    /* Side gradients for wide viewports - fade into background (show only when >2560px) */
  }
  <div
    class="hidden min-[2561px]:block absolute top-0 bottom-0 left-0 w-32 bg-gradient-to-r from-bears-bg to-transparent z-10 pointer-events-none"
  >
  </div>
  <div
    class="hidden min-[2561px]:block absolute top-0 bottom-0 right-0 w-32 bg-gradient-to-l from-bears-bg to-transparent z-10 pointer-events-none"
  >
  </div>

  {/* Content Container - Title in bottom left quadrant */}
  <div class="relative z-20 h-full">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-end">
      <div class="w-full lg:w-1/2 pb-16 sm:pb-20 lg:pb-24">
        {/* Title */}
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-bears-accent leading-tight"
        >
          {title}
        </h1>

        {/* Divider between title and subtitle */}
        <div
          class="h-[2px] bg-gradient-to-r from-white/30 via-white/10 to-transparent my-4 sm:my-6 rounded-full"
        >
        </div>

        {/* Optional Subtitle */}
        {
          subtitle && (
            <p class="text-lg sm:text-xl lg:text-2xl text-bears-text-onDark/80 max-w-xl">
              {subtitle}
            </p>
          )
        }
      </div>
    </div>
  </div>
</section>
