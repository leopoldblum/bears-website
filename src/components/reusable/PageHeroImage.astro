---
// PageHeroImage Component - Full viewport height hero with background image
// Displays a title in the bottom left quadrant with gradient overlay

import Img from "@mdx/Img.astro";
import type { ImageMetadata } from "astro";

interface Props {
  /** Background image to display */
  image: ImageMetadata;
  /** Alt text for the background image */
  alt: string;
  /** Title text displayed in bottom left */
  title: string;
  /** Optional subtitle text displayed below title */
  subtitle?: string;
  /** Gradient color variant - 'dark' fades to bears-bg, 'light' fades to bears-bg-light */
  variant?: "dark" | "light";
  /** Additional CSS classes */
  class?: string;
  /** Loading strategy for the image - 'eager' for above-fold, 'lazy' for below-fold */
  loading?: "eager" | "lazy";
  /** Hidden search terms that Pagefind indexes but users don't see (e.g. nav-label aliases) */
  searchAliases?: string[];
}

const {
  image,
  alt,
  title,
  subtitle,
  variant = "dark",
  class: className,
  loading = "eager",
  searchAliases = [],
} = Astro.props;

const isLight = variant === "light";
---

<section
  id="page-hero"
  class={`relative h-[50vh] lg:h-[60vh] min-h-[450px] max-h-[800px] w-full max-w-[2560px] mx-auto overflow-hidden scroll-mt-20 ${className || ""}`}
>
  {/* Background Image Layer */}
  <div class="absolute inset-0 z-0">
    <Img
      src={image}
      alt={alt}
      class="w-full h-full object-cover"
      loading={loading}
      sizes="(min-width: 2560px) 2560px, 100vw"
      enableClickToEnlarge={false}
      fetchpriority="high"
    />
  </div>

  {/* Gradient overlay for text readability - similar to LandingHero */}
  <div
    class:list={[
      "absolute inset-0 bg-gradient-to-r to-transparent z-10",
      isLight ? "from-bears-bg-light/80 via-bears-bg-light/40" : "from-bears-bg/80 via-bears-bg/40",
    ]}
  >
  </div>

  {/* Bottom gradient for better text contrast */}
  <div
    class:list={[
      "absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t to-transparent pointer-events-none z-10",
      isLight ? "from-bears-bg-light via-bears-bg-light/60" : "from-bears-bg via-bears-bg/60",
    ]}
  >
  </div>

  {/* Side gradients for wide viewports - fade into background (show only when >2560px) */}
  <div
    class:list={[
      "hidden min-[2561px]:block absolute top-0 bottom-0 left-0 w-32 bg-gradient-to-r to-transparent z-10 pointer-events-none",
      isLight ? "from-bears-bg-light" : "from-bears-bg",
    ]}
  >
  </div>
  <div
    class:list={[
      "hidden min-[2561px]:block absolute top-0 bottom-0 right-0 w-32 bg-gradient-to-l to-transparent z-10 pointer-events-none",
      isLight ? "from-bears-bg-light" : "from-bears-bg",
    ]}
  >
  </div>

  {/* Content Container - Title in bottom left quadrant */}
  <div class="relative z-20 h-full">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-end">
      <div class="w-full lg:w-1/2 pb-16 sm:pb-20 lg:pb-24">
        {/* Title */}
        <h1
          id="page-title"
          class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-bears-accent leading-tight scroll-mt-20"
          data-pagefind-weight="10"
        >
          {title}
        </h1>

        {/* Hidden search aliases for Pagefind — lets users find this page by alternative terms */}
        {searchAliases.length > 0 && (
          <span class="sr-only" data-pagefind-weight="10">
            {searchAliases.join(' ')}
          </span>
        )}

        {/* Divider between title and subtitle */}
        <div
          class:list={[
            "h-[2px] bg-gradient-to-r from-30% via-70% to-transparent my-4 sm:my-6 rounded-full",
            isLight ? "from-black/20 via-black/10" : "from-white/30 via-white/15",
          ]}
        >
        </div>

        {/* Optional Subtitle */}
        {
          subtitle && (
            <p class:list={[
              "text-lg sm:text-xl lg:text-2xl max-w-xl",
              isLight ? "text-bears-text-onLight/80" : "text-bears-text-onDark/80",
            ]} data-pagefind-weight="6">
              {subtitle}
            </p>
          )
        }
      </div>
    </div>
  </div>
</section>
