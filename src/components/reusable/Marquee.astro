---
// Marquee - Seamless infinite horizontal auto-scroll component
// Uses dynamic cloning to ensure content always fills viewport
// Works with any content: images (via Img component), HTML, etc.

interface Props {
  speed?: number;           // Pixels per second (default: 50)
  gap?: string;             // Gap between items (default: "2rem")
  pauseOnHover?: boolean;   // Pause animation on hover (default: true)
  height?: string;          // Item height, CSS value (default: "16rem")
  direction?: 'left' | 'right'; // Scroll direction (default: 'left')
}

const {
  speed = 50,
  gap = "2rem",
  pauseOnHover = true,
  height = "16rem",
  direction = 'left',
} = Astro.props;
---

<div
  class="marquee-container"
  x-data={`{
    ready: false,
    originalChildren: [],
    originalWidth: 0,

    async init() {
      const content = this.$refs.content;
      const container = this.$el;

      // Wait for images to load before measuring
      const images = content.querySelectorAll('img');
      if (images.length > 0) {
        await Promise.all(
          Array.from(images).map(img => {
            return new Promise((resolve) => {
              if (img.complete) {
                resolve();
              } else {
                img.addEventListener('load', resolve, { once: true });
                img.addEventListener('error', resolve, { once: true });
              }
            });
          })
        );
      }

      // Store original children and measure original width
      this.originalChildren = Array.from(content.children).map(child => child.cloneNode(true));
      this.originalWidth = content.scrollWidth;

      // Get gap in pixels for width calculation
      const computedGap = parseFloat(getComputedStyle(content).gap) || 0;
      const totalOriginalWidth = this.originalWidth + computedGap;

      // Clone items until content overflows the container
      let safetyCounter = 0;
      while (content.scrollWidth <= container.clientWidth && safetyCounter < 100) {
        this.originalChildren.forEach(child => {
          content.appendChild(child.cloneNode(true));
        });
        safetyCounter++;
      }

      // Add one more complete set for seamless animation buffer
      this.originalChildren.forEach(child => {
        content.appendChild(child.cloneNode(true));
      });

      // Set CSS variables for animation
      this.$el.style.setProperty('--marquee-width', totalOriginalWidth + 'px');
      this.$el.style.setProperty('--marquee-duration', (totalOriginalWidth / ${speed}) + 's');

      this.ready = true;
    }
  }`}
  x-bind:class="{ 'marquee-ready': ready }"
  style={`--marquee-gap: ${gap}; --marquee-height: ${height};`}
>
  <div
    class={`marquee-track ${direction === 'right' ? 'marquee-reverse' : ''} ${pauseOnHover ? 'marquee-pause-on-hover' : ''}`}
    x-ref="track"
  >
    <div class="marquee-content" x-ref="content">
      <slot />
    </div>
  </div>
</div>

<style>
  .marquee-container {
    width: 100%;
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  /* Only animate when ready */
  .marquee-ready .marquee-track {
    animation: marquee-scroll var(--marquee-duration, 20s) linear infinite;
  }

  /* Reverse direction */
  .marquee-ready .marquee-track.marquee-reverse {
    animation-direction: reverse;
  }

  .marquee-track.marquee-pause-on-hover:hover {
    animation-play-state: paused;
  }

  .marquee-content {
    display: flex;
    align-items: center;
    gap: var(--marquee-gap);
    flex-shrink: 0;
    height: var(--marquee-height);
  }

  /* Ensure slotted items fit within height */
  .marquee-content :global(> *) {
    height: 100%;
    width: auto;
    flex-shrink: 0;
  }

  /* Handle images specifically */
  .marquee-content :global(img) {
    height: 100%;
    width: auto;
    object-fit: cover;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-1 * var(--marquee-width)));
    }
  }
</style>
