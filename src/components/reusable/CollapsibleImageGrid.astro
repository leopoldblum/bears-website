---
// CollapsibleImageGrid - Reusable collapsible wrapper around ImageGrid
// Shows a preview height of images when collapsed with gradient overlay + expand arrow
// Expands to show all images with a collapse arrow at the bottom
// Accepts an optional "header" slot rendered inside the Alpine scope (for clickable headers that call toggle())

import type { ImageWithAlt } from "@types";
import CarouselArrow from "./CarouselArrow.astro";
import ImageGrid from "./ImageGrid.astro";

interface Props {
  /** Images to display in the grid */
  images: ImageWithAlt[];
  /** Number of columns (default: 4) */
  cols?: 2 | 3 | 4 | 5 | 6;
  /** Gap between images (default: 'md') */
  gap?: "sm" | "md" | "lg";
  /** Number of preview rows visible when collapsed (default: 1) */
  previewRows?: number;
  /** Additional CSS classes for the ImageGrid */
  class?: string;
}

const {
  images,
  cols = 4,
  gap = "md",
  previewRows = 1,
  class: className,
} = Astro.props;

// Compute column widths for preview height CSS
// ImageGrid always uses 2 cols on mobile, then `cols` cols on lg+
const mobileColWidth = "50vw";
const desktopColWidth = `${+(100 / cols).toFixed(3)}vw`;
---

<div
  class="collapsible-grid relative"
  x-data={`{
    isOpen: false,
    contentHeight: 0,
    overflows: false,
    isAnimating: false,
    calculateHeight() {
      const wrapper = this.$refs.wrapper;
      const content = this.$refs.content;
      if (content && wrapper) {
        this.contentHeight = content.scrollHeight;
        this.overflows = wrapper.scrollHeight > wrapper.clientHeight + 10;
      }
    },
    toggle() {
      if (this.isAnimating) return;
      this.isAnimating = true;
      this.isOpen = !this.isOpen;
      setTimeout(() => { this.isAnimating = false; }, 500);
    }
  }`}
  x-init="
    $nextTick(() => {
      calculateHeight();
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => calculateHeight(), 100);
      });
      $refs.content?.querySelectorAll('img').forEach(img => {
        if (!img.complete) img.addEventListener('load', () => calculateHeight());
      });
    });
  "
>
  <slot name="header" />

  <div
    x-ref="wrapper"
    class="overflow-hidden transition-all duration-500 ease-in-out"
    x-bind:style="`max-height: ${isOpen ? contentHeight + 'px' : 'var(--preview-height, 300px)'}`"
    x-bind:class="isOpen ? 'pb-6' : 'pb-0'"
  >
    <div x-ref="content">
      <ImageGrid
        images={images}
        cols={cols}
        gap={gap}
        enableClickToEnlarge={true}
        aspectRatio="native"
        class={className}
      />
    </div>
  </div>

  <!-- Gradient overlay with expand arrow (shown when collapsed) -->
  <div
    class="absolute bottom-0 left-0 right-0 h-40 sm:h-48 flex items-end justify-center pb-4 pointer-events-none transition-all duration-500 ease-out"
    x-bind:class="isOpen ? 'opacity-0 translate-y-full pointer-events-none' : 'opacity-100 translate-y-0'"
    x-show="overflows"
    style="background: linear-gradient(to bottom, transparent 0%, color-mix(in srgb, var(--color-bears-bg) 30%, transparent) 20%, color-mix(in srgb, var(--color-bears-bg) 70%, transparent) 40%, var(--color-bears-bg) 60%, var(--color-bears-bg) 100%);"
  >
    <div class="pointer-events-auto">
      <CarouselArrow
        direction="down"
        onClick="toggle()"
        variant="flex"
        class="[&_svg]:-mt-1"
      />
    </div>
  </div>

  <!-- Collapse arrow (shown when expanded) -->
  <div
    x-show="overflows"
    class="flex justify-center pt-6 transition-all duration-300"
    x-bind:class="isOpen ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4 pointer-events-none'"
  >
    <CarouselArrow
      direction="prev"
      onClick="toggle()"
      variant="flex"
      class="rotate-90 [&_svg]:rotate-0"
    />
  </div>
</div>

<style define:vars={{ mobileColWidth, desktopColWidth, previewRows }}>
  .collapsible-grid [x-ref="wrapper"] {
    will-change: max-height;
  }

  @media (max-width: 640px) {
    .collapsible-grid {
      --preview-height: calc((var(--mobileColWidth) - 1.5rem) * var(--previewRows));
    }
  }

  @media (min-width: 641px) and (max-width: 1024px) {
    .collapsible-grid {
      --preview-height: calc((var(--mobileColWidth) - 2rem) * var(--previewRows));
    }
  }

  @media (min-width: 1025px) {
    .collapsible-grid {
      --preview-height: calc((var(--desktopColWidth) - 3rem) * var(--previewRows));
    }
  }
</style>
