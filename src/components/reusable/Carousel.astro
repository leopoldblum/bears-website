---
// Carousel - Reusable carousel component with auto-scroll and manual navigation
// Usage: Wrap any content as direct children - carousel will auto-detect and handle them

interface Props {
  /**
   * Enable automatic scrolling through slides
   * @default false
   */
  autoScroll?: boolean;

  /**
   * Time interval in milliseconds between automatic slide transitions
   * Only applies when autoScroll is enabled
   * @default 5000
   */
  autoScrollInterval?: number;

  /**
   * Show previous/next arrow navigation buttons
   * @default true
   */
  showArrows?: boolean;

  /**
   * Show dot indicators for slide navigation
   * @default true
   */
  showDots?: boolean;

  /**
   * Minimum height Tailwind class for the carousel container
   * @default "min-h-120"
   * @example "min-h-96", "min-h-[500px]"
   */
  minHeight?: string;
}

const {
  autoScroll = false,
  autoScrollInterval = 5000,
  showArrows = true,
  showDots = true,
  minHeight = "min-h-120",
} = Astro.props;
---

<div
  x-data={`{
    currentSlide: 0,
    totalSlides: 0,
    autoScrollInterval: null,
    autoScrollEnabled: ${autoScroll},

    init() {
      const children = Array.from(this.$refs.slidesContainer.children);
      this.totalSlides = children.length;

      // Apply Alpine directives and styling to each child dynamically
      children.forEach((child, index) => {
        child.setAttribute('x-show', \`currentSlide === \${index}\`);
        child.setAttribute('x-transition:enter', 'transition ease-out duration-300');
        child.setAttribute('x-transition:enter-start', 'opacity-0 transform scale-95');
        child.setAttribute('x-transition:enter-end', 'opacity-100 transform scale-100');
        child.setAttribute('x-transition:leave', 'transition ease-in duration-200');
        child.setAttribute('x-transition:leave-start', 'opacity-100 transform scale-100');
        child.setAttribute('x-transition:leave-end', 'opacity-0 transform scale-95');
        child.classList.add('absolute', 'w-full');
      });

      if (this.autoScrollEnabled) {
        this.startAutoScroll();
      }
    },

    // Navigation methods
    nextSlide() {
      this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
    },
    prevSlide() {
      this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },
    goToSlide(index) {
      this.currentSlide = index;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },

    // Auto-scroll methods
    startAutoScroll() {
      if (this.autoScrollEnabled) {
        this.autoScrollInterval = setInterval(() => {
          this.nextSlide();
        }, ${autoScrollInterval});
      }
    },
    stopAutoScroll() {
      if (this.autoScrollInterval) {
        clearInterval(this.autoScrollInterval);
        this.autoScrollInterval = null;
      }
    },
    resetAutoScroll() {
      this.stopAutoScroll();
      this.startAutoScroll();
    }
  }`}
  class="w-full"
>
  <!-- Carousel Container with Navigation -->
  <div class={`relative flex items-center justify-center ${minHeight} gap-4 sm:gap-6 lg:gap-8`}>

    {showArrows && (
      <!-- Previous Arrow Button -->
      <button
        @click="prevSlide()"
        @mouseenter="stopAutoScroll()"
        @mouseleave="startAutoScroll()"
        class="shrink-0 bg-gradient-to-b from-bears-accent to-bears-accent-muted text-white rounded-lg px-3 py-7 sm:px-4 sm:py-10 lg:px-5 lg:py-14 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.2),0_4px_16px_rgba(0,0,0,0.4),0_0_20px_rgba(197,14,31,0.3)] hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.25),0_6px_24px_rgba(0,0,0,0.5),0_0_32px_rgba(197,14,31,0.5)] hover:scale-110 active:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.15),0_2px_8px_rgba(0,0,0,0.4),0_0_12px_rgba(197,14,31,0.2)] active:scale-105 transition-[box-shadow,transform] duration-200 ease-out hover:duration-150 active:duration-75 active:ease-in focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bears-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bears-bg cursor-pointer"
        aria-label="Previous slide"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6 lg:w-7 lg:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
    )}

    <!-- Slides Container (80% width) -->
    <div
      class={`relative w-[80%] flex items-center justify-center ${minHeight}`}
      @mouseenter="stopAutoScroll()"
      @mouseleave="startAutoScroll()"
      x-ref="slidesContainer"
    >
      <slot />
    </div>

    {showArrows && (
      <!-- Next Arrow Button -->
      <button
        @click="nextSlide()"
        @mouseenter="stopAutoScroll()"
        @mouseleave="startAutoScroll()"
        class="shrink-0 bg-gradient-to-b from-bears-accent to-bears-accent-muted text-white rounded-lg px-3 py-7 sm:px-4 sm:py-10 lg:px-5 lg:py-14 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.2),0_4px_16px_rgba(0,0,0,0.4),0_0_20px_rgba(197,14,31,0.3)] hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.25),0_6px_24px_rgba(0,0,0,0.5),0_0_32px_rgba(197,14,31,0.5)] hover:scale-110 active:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.15),0_2px_8px_rgba(0,0,0,0.4),0_0_12px_rgba(197,14,31,0.2)] active:scale-105 transition-[box-shadow,transform] duration-200 ease-out hover:duration-150 active:duration-75 active:ease-in focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bears-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bears-bg cursor-pointer"
        aria-label="Next slide"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6 lg:w-7 lg:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    )}
  </div>

  {showDots && (
    <!-- Dot Indicators (Auto-generated based on slide count) -->
    <div class="flex justify-center gap-2 sm:gap-3 mt-8 sm:mt-10 lg:mt-12">
      <template x-for="index in totalSlides" :key="index">
        <button
          @click="goToSlide(index - 1)"
          :class="currentSlide === index - 1 ? 'bg-gradient-to-b from-bears-accent to-bears-accent-muted border-bears-accent/30 shadow-[0_0_16px_rgba(197,14,31,0.5),0_2px_8px_rgba(0,0,0,0.4)] scale-110 hover:shadow-[0_0_20px_rgba(197,14,31,0.6),0_2px_8px_rgba(0,0,0,0.4)]' : 'bg-white/10 backdrop-blur-sm border-white/20 shadow-[0_2px_8px_rgba(0,0,0,0.3)] hover:scale-105 hover:border-white/30'"
          class="w-3 h-3 sm:w-3.5 sm:h-3.5 lg:w-4 lg:h-4 rounded-full border transition-[background,border-color,box-shadow,transform] duration-200 cursor-pointer"
          :aria-label="`Go to slide ${index}`"
          :aria-current="currentSlide === index - 1 ? 'true' : 'false'"
        ></button>
      </template>
    </div>
  )}
</div>
