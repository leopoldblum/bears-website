---
// MediaAccordion - Reusable accordion component for displaying media categories
// Shows 2 rows of images as preview when closed, with gradient overlay and expand arrow
// Displays all images in a grid when opened

import type { ImageMetadata } from "astro";
import CarouselArrow from "../CarouselArrow.astro";
import Img_better from "../mdx/Img_better.astro";

interface Props {
  /** Category title displayed at the top */
  title: string;
  /** Array of images to display in the grid */
  images: ImageMetadata[];
  /** Additional CSS classes */
  class?: string;
  /** Number of columns in the grid (default: 4) */
  cols?: 2 | 3 | 4 | 5 | 6;
  /** Gap between images (default: 'md') */
  gap?: "sm" | "md" | "lg";
}

const { title, images, class: className, cols = 4, gap = "md" } = Astro.props;

// Grid column classes
const colClasses: Record<number, string> = {
  2: "grid-cols-2",
  3: "grid-cols-2 sm:grid-cols-3",
  4: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4",
  5: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-5",
  6: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-6",
};

// Gap classes
const gapClasses: Record<string, string> = {
  sm: "gap-2",
  md: "gap-3 lg:gap-4",
  lg: "gap-4 lg:gap-6",
};

// Responsive image sizes matching grid columns
const sizeClasses: Record<number, string> = {
  2: "50vw",
  3: "(min-width: 640px) 33vw, 50vw",
  4: "(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw",
  5: "(min-width: 1024px) 20vw, (min-width: 640px) 33vw, 50vw",
  6: "(min-width: 1024px) 17vw, (min-width: 640px) 33vw, 50vw",
};

const gridCols = colClasses[cols] ?? colClasses[4];
const gridGap = gapClasses[gap] ?? gapClasses["md"];
const imageSizes = sizeClasses[cols] ?? sizeClasses[4];
// Generate unique ID for this accordion instance
const accordionId = `media-accordion-${Math.random().toString(36).substring(2, 9)}`;
---

<div
  class={`media-accordion rounded-lg overflow-hidden ${className || ""}`}
  x-data={`{
    isOpen: false,
    contentHeight: 0,
    isAnimating: false,
    calculateHeight() {
      const content = this.$refs.content;
      if (content) {
        this.contentHeight = content.scrollHeight;
      }
    },
    toggle() {
      if (this.isAnimating) return;
      this.isAnimating = true;
      this.isOpen = !this.isOpen;
      setTimeout(() => {
        this.isAnimating = false;
      }, 500);
    }
  }`}
  x-init="
    $nextTick(() => {
      calculateHeight();
      let resizeTimer;
      const handleResize = () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => calculateHeight(), 100);
      };
      window.addEventListener('resize', handleResize);
      
      // Recalculate when images load
      const images = $refs.content?.querySelectorAll('img');
      images?.forEach(img => {
        if (!img.complete) {
          img.addEventListener('load', () => calculateHeight());
        }
      });
    });
  "
>
  {/* Accordion Header */}
  <button
    type="button"
    class="w-full flex items-center justify-between px-4 sm:px-6 py-4 sm:py-5 text-left hover:bg-white/5 transition-colors duration-200 cursor-pointer group"
    x-on:click="toggle()"
    x-bind:aria-expanded="isOpen ? 'true' : 'false'"
    aria-controls={accordionId}
  >
    <div class="flex items-baseline gap-2 sm:gap-3">
      <span class="text-sm sm:text-lg text-bears-accent/80 font-medium"
        >This is</span
      >
      <h3
        class="text-2xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark"
      >
        {title}
      </h3>
    </div>
    <svg
      class="w-5 h-5 flex-shrink-0 ml-3 transition-transform duration-300 text-bears-text-onDark/60 group-hover:text-bears-accent"
      x-bind:class="isOpen ? 'rotate-180 text-bears-accent' : 'rotate-0'"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </button>

  {/* Divider */}
  <div class="header-divider mb-4 sm:mb-6"></div>

  {/* Accordion Content */}
  <div
    id={accordionId}
    class="relative"
    x-bind:class="isOpen ? 'pb-6' : 'pb-0'"
  >
    {/* Content Wrapper with smooth height animation */}
    <div
      x-ref="wrapper"
      class="overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]"
      x-bind:style="`max-height: ${isOpen ? contentHeight + 'px' : 'var(--preview-height, 300px)'}`"
    >
      {/* Image Grid Container */}
      <div
        x-ref="content"
        class={`grid ${gridCols} ${gridGap} px-4 sm:px-6 pt-2`}
      >
        {
          images.map((image, index) => (
            <div class="relative aspect-square overflow-hidden rounded-lg group/image ring-0 ring-bears-accent transition-all duration-300 hover:ring-2">
              <div class="w-full h-full">
                <Img_better
                  src={image}
                  alt={`${title} image ${index + 1}`}
                  class="w-full h-full object-cover object-center transition-transform duration-300 group-hover/image:scale-105"
                  width="100%"
                  sizes={imageSizes}
                  loading={index <= cols * 2 ? "eager" : "lazy"}
                  enableClickToEnlarge={true}
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Gradient Overlay (shown when closed) */}
    <div
      class="absolute bottom-0 left-0 right-0 h-40 sm:h-48 flex items-end justify-center pb-4 pointer-events-none transition-all duration-500 ease-out"
      x-bind:class="isOpen ? 'opacity-0 translate-y-full pointer-events-none' : 'opacity-100 translate-y-0'"
      style="background: linear-gradient(to bottom, transparent 0%, color-mix(in srgb, var(--color-bears-bg) 30%, transparent) 20%, color-mix(in srgb, var(--color-bears-bg) 70%, transparent) 40%, var(--color-bears-bg) 60%, var(--color-bears-bg) 100%);"
    >
      {/* Arrow Down Icon using CarouselArrow component */}
      <div class="pointer-events-auto" x-on:click="toggle()">
        <CarouselArrow
          direction="down"
          onClick="toggle()"
          variant="flex"
          class="[&_svg]:-mt-1"
        />
      </div>
    </div>

    {/* Collapse Button (shown when open) */}
    <div
      class="flex justify-center pt-6 transition-all duration-300"
      x-bind:class="isOpen ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4 pointer-events-none'"
    >
      <CarouselArrow
        direction="prev"
        onClick="toggle()"
        variant="flex"
        class="rotate-90 [&_svg]:rotate-0"
      />
    </div>
  </div>
</div>

<style>
  /* Divider styling - similar to PostLayout */
  .header-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
  }

  /* Smooth height transition */
  .media-accordion [x-ref="wrapper"] {
    will-change: max-height;
  }

  /* Preview height calculation for different screen sizes */
  @media (max-width: 640px) {
    .media-accordion {
      --preview-height: calc((50vw - 1.5rem) * 1);
    }
  }

  @media (min-width: 641px) and (max-width: 1024px) {
    .media-accordion {
      --preview-height: calc((33.333vw - 2rem) * 1);
    }
  }

  @media (min-width: 1025px) {
    .media-accordion {
      --preview-height: calc((16.666vw - 2.5rem) * 1);
    }
  }
</style>
