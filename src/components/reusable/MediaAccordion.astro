---
// MediaAccordion - Accordion component for displaying media categories
// Shows a clickable header with title + chevron, and a collapsible image grid below
// If all images fit in one row, renders statically without accordion behavior

import type { ImageMetadata } from "astro";
import type { ImageWithAlt } from "@types";
import CollapsibleImageGrid from "./CollapsibleImageGrid.astro";
import GradientDivider from "./GradientDivider.astro";
import ImageGrid from "./ImageGrid.astro";

interface Props {
  /** Category title displayed at the top */
  title: string;
  /** Array of images to display in the grid */
  images: ImageMetadata[];
  /** Additional CSS classes */
  class?: string;
  /** Number of columns in the grid (default: 4) */
  cols?: 2 | 3 | 4 | 5 | 6;
  /** Gap between images (default: 'md') */
  gap?: "sm" | "md" | "lg";
}

const { title, images, class: className, cols = 4, gap = "md" } = Astro.props;

// Clamp cols to image count so images fill the width, but never below 3 on wide screens
const effectiveCols = Math.min(cols, Math.max(3, images.length)) as typeof cols;

// Transform images to include alt text
const imagesWithAlt: ImageWithAlt[] = images.map((image, index) => ({
  image,
  alt: `${title} image ${index + 1}`,
}));

// If all images fit in one row, skip accordion functionality
const fitsInOneRow = images.length <= effectiveCols;
---

{fitsInOneRow ? (
  <div class={`media-accordion rounded-lg overflow-hidden ${className || ""}`}>
    {/* Static Header */}
    <div class="w-full px-4 sm:px-8 py-6 sm:py-8">
      <p class="text-xs sm:text-sm font-semibold uppercase tracking-widest text-bears-accent mb-1 sm:mb-2">
        This is
      </p>
      <h3 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark">
        {title}
      </h3>
      <GradientDivider class="mt-4 sm:mt-6" />
    </div>

    {/* Image Grid - no accordion wrapper */}
    <div class="pb-6">
      <ImageGrid
        images={imagesWithAlt}
        cols={effectiveCols}
        gap={gap}
        enableClickToEnlarge={true}
        aspectRatio="native"
      />
    </div>
  </div>
) : (
  <div class={`media-accordion rounded-lg overflow-hidden ${className || ""}`}>
    <CollapsibleImageGrid images={imagesWithAlt} cols={effectiveCols} gap={gap} previewRows={1}>
      <Fragment slot="header">
        {/* Accordion Header */}
        <button
          type="button"
          class="w-full flex items-center justify-between px-4 sm:px-8 py-6 sm:py-8 text-left hover:bg-white/5 transition-colors duration-200 cursor-pointer group"
          x-on:click="toggle()"
          x-bind:aria-expanded="isOpen ? 'true' : 'false'"
        >
          <div>
            <p class="text-xs sm:text-sm font-semibold uppercase tracking-widest text-bears-accent mb-1 sm:mb-2">
              This is
            </p>
            <h3 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-bears-text-onDark">
              {title}
            </h3>
          </div>
          <svg
            class="w-6 h-6 sm:w-7 sm:h-7 shrink-0 ml-4 transition-transform duration-300 text-bears-text-onDark/60 group-hover:text-bears-accent"
            x-bind:class="isOpen ? 'rotate-180 text-bears-accent' : 'rotate-0'"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        {/* Divider */}
        <GradientDivider class="mb-4 sm:mb-6" />
      </Fragment>
    </CollapsibleImageGrid>
  </div>
)}
