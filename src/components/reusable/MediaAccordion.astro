---
// MediaAccordion - Reusable accordion component for displaying media categories
// Shows 2 rows of images as preview when closed, with gradient overlay and expand arrow
// Displays all images in a grid when opened

import type { ImageMetadata } from 'astro';
import CarouselArrow from '../CarouselArrow.astro';
import Img from '../mdx/Img.astro';

interface Props {
  /** Category title displayed at the top */
  title: string;
  /** Array of images to display in the grid */
  images: ImageMetadata[];
  /** Additional CSS classes */
  class?: string;
  /** Number of columns in the grid (default: 4) */
  cols?: 2 | 3 | 4 | 5 | 6;
  /** Gap between images (default: 'md') */
  gap?: 'sm' | 'md' | 'lg';
}

const {
  title,
  images,
  class: className,
  cols = 4,
  gap = 'md'
} = Astro.props;

// Grid column classes
const colClasses: Record<number, string> = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 sm:grid-cols-3',
  4: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
  5: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-5',
  6: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-6',
};

// Gap classes
const gapClasses: Record<string, string> = {
  sm: 'gap-2',
  md: 'gap-3 lg:gap-4',
  lg: 'gap-4 lg:gap-6',
};

const gridCols = colClasses[cols] ?? colClasses[4];
const gridGap = gapClasses[gap] ?? gapClasses['md'];

// Generate unique ID for this accordion instance
const accordionId = `media-accordion-${Math.random().toString(36).substring(2, 9)}`;
---

<div
  class={`media-accordion rounded-lg overflow-hidden  ${className || ''}`}
  x-data={`{ isOpen: false }`}
>
  {/* Accordion Header */}
  <button
    type="button"
    class="w-full flex items-center justify-between px-4 sm:px-6 py-4 sm:py-5 text-left hover:bg-white/5 transition-colors duration-200 cursor-pointer group"
    x-on:click="isOpen = !isOpen"
    x-bind:aria-expanded="isOpen ? 'true' : 'false'"
    aria-controls={accordionId}
  >
    <div class="flex flex-col pl-4">
      <span class="text-sm sm:text-base text-bears-accent mt-2 mb-4">This is</span>
      <h3 class="text-2xl sm:text-5xl font-bold text-bears-text-onDark pl-2">
        {title}
      </h3>
    </div>
    <svg
      class="w-5 h-5 flex-shrink-0 ml-3 transition-transform duration-300 text-bears-text-onDark/60 group-hover:text-bears-accent"
      x-bind:class="isOpen ? 'rotate-180 text-bears-accent' : 'rotate-0'"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  {/* Divider */}
  <div class="header-divider mb-4 sm:mb-6"></div>
  
  {/* Accordion Content */}
  <div
    id={accordionId}
    class="relative"
    x-bind:class="isOpen ? 'pb-6' : 'pb-0'"
  >
    {/* Image Grid Container */}
    <div
      class={`grid ${gridCols} ${gridGap} px-4 sm:px-6 overflow-hidden transition-all duration-500 ease-in-out`}
      x-bind:style="isOpen ? 'max-height: none;' : 'max-height: calc((100vw - 3rem) / 2 * 1.15 + (100vw - 3rem) / 2 * 1.15 / 2 + 0.25rem)'"
      x-bind:class="isOpen ? '' : 'max-h-[calc((min(100vw,1280px)-3rem)/4*1.15+(min(100vw,1280px)-3rem)/4*1.15/2+0.5rem)]'"
    >
      {images.map((image, index) => (
        <div class="relative aspect-square overflow-hidden rounded-lg group/image">
          <Img
            src={image}
            alt={`${title} image ${index + 1}`}
            class="w-full h-full object-cover transition-transform duration-300 group-hover/image:scale-105"
            loading={index < 8 ? "eager" : "lazy"}
            enableClickToEnlarge={true}
          />
        </div>
      ))}
    </div>

    {/* Gradient Overlay (shown when closed) */}
    <div
      class="absolute bottom-0 left-0 right-0 h-32 sm:h-40 flex items-end justify-center pb-4 pointer-events-none transition-opacity duration-300"
      x-bind:class="isOpen ? 'opacity-0' : 'opacity-100'"
      style="background: linear-gradient(to bottom, transparent 0%, rgba(26, 26, 26, 0.7) 40%, rgba(26, 26, 26, 0.95) 100%);"
    >
      {/* Arrow Down Icon using CarouselArrow component */}
      <div class="pointer-events-auto" x-on:click="isOpen = true">
        <CarouselArrow
          direction="down"
          onClick="isOpen = true"
          variant="flex"
          class="[&_svg]:-mt-1"
        />
      </div>
    </div>
  </div>
</div>

<style>
  /* Divider styling - similar to PostLayout */
  .header-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
  }

  /* Ensure smooth height transition */
  .media-accordion .grid {
    will-change: max-height;
  }

  /* Responsive max-height for closed state - shows 1 full row + 1/2 of second row */
  @media (min-width: 640px) {
    .media-accordion .grid:not([style*="max-height: none"]) {
      max-height: calc((100vw - 4rem) / 3 * 1.15 + (100vw - 4rem) / 3 * 1.15 / 2 + 0.5rem) !important;
    }
  }

  @media (min-width: 1024px) {
    .media-accordion .grid:not([style*="max-height: none"]) {
      max-height: calc((min(100vw, 1280px) - 4rem) / 4 * 1.15 + (min(100vw, 1280px) - 4rem) / 4 * 1.15 / 2 + 0.75rem) !important;
    }
  }
</style>
