---
// Button component - Reusable button with multiple variants
// Supports both button and link elements, Alpine.js integration, and MDX usage

interface Props {
  // Content (slot takes priority over content prop)
  content?: string;

  // Navigation
  href?: string; // If provided, renders <a>, else <button>

  // Styling
  variant?: 'primary' | 'secondary' | 'inverse'; // Default: 'primary'
  size?: 'standard' | 'large'; // Default: 'standard'

  // HTML attributes
  type?: 'button' | 'submit' | 'reset'; // Default: 'button' (only for <button> elements)
  disabled?: boolean;

  // Accessibility
  ariaLabel?: string;

  // Alpine.js integration
  xData?: string;
  onClick?: string;
  xShow?: string;
  xBind?: string;

  // Escape hatch for additional classes
  class?: string;
}

const {
  content,
  href,
  variant = 'primary',
  size = 'standard',
  type = 'button',
  disabled = false,
  ariaLabel,
  xData,
  onClick,
  xShow,
  xBind,
  class: className,
} = Astro.props;

// Dynamic element selection (pattern from PostShowcase.astro)
const Element = href ? 'a' : 'button';

// Base classes (all variants)
const baseClasses = [
  'not-prose',
  'rounded-full',
  'font-medium',
  'cursor-pointer',
  'inline-flex items-center justify-center',
  'origin-center',
  'transition-all',
  'duration-300 ease-out',
  'hover:duration-300',
  'active:duration-200 active:ease-in',
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bears-accent',
  'focus-visible:ring-offset-2 focus-visible:ring-offset-bears-bg',
].join(' ');

// Size classes
const sizeClasses = {
  standard: 'px-5 py-2.5 sm:px-7 sm:py-3 text-sm sm:text-base',
  large: 'px-7 py-3 sm:px-9 sm:py-3.5 text-base sm:text-lg',
};

// Variant classes
const variantClasses = {
  primary: [
    'bg-gradient-to-b from-bears-accent to-bears-accent-muted',
    'text-bears-text-onDark',
    'shadow-[inset_0_1px_0_0_rgba(255,255,255,0.2),0_4px_16px_rgba(0,0,0,0.4),0_0_20px_rgba(197,14,31,0.3)]',
    'hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.25),0_6px_24px_rgba(0,0,0,0.5),0_0_32px_rgba(197,14,31,0.5)]',
    'hover:scale-105',
    'active:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.15),0_2px_8px_rgba(0,0,0,0.4),0_0_12px_rgba(197,14,31,0.2)]',
  ].join(' '),
  secondary: [
    'bg-transparent text-bears-text-onDark',
    'border-2 border-bears-accent/40',
    'shadow-[0_0_0_0_rgba(197,14,31,0)]',
    'hover:border-bears-accent',
    'hover:bg-bears-accent/10',
    'hover:shadow-[0_0_20px_rgba(197,14,31,0.25)]',
    'hover:scale-105',
    'active:bg-bears-accent/5',
  ].join(' '),
  inverse: [
    'bg-gradient-to-b from-[#2F2F2F] to-bears-text-onLight',
    'text-bears-text-onDark',
    'shadow-[inset_0_1px_0_0_rgba(255,255,255,0.15),0_4px_16px_rgba(43,43,43,0.4)]',
    'hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.2),0_6px_24px_rgba(43,43,43,0.5),0_0_16px_rgba(43,43,43,0.2)]',
    'hover:scale-105',
    'active:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.1),0_2px_8px_rgba(43,43,43,0.4)]',
    'focus-visible:ring-offset-bears-bg-light',
  ].join(' '),
};

// Disabled state classes
const disabledClasses = disabled ? [
  'opacity-40',
  'cursor-not-allowed',
  'grayscale',
  'shadow-none',
  'hover:shadow-none',
  'hover:translate-y-0',
  '!bg-gradient-to-b !from-gray-600 !to-gray-700',
].join(' ') : '';

// Compose final classes
const buttonClasses = [
  baseClasses,
  sizeClasses[size],
  variantClasses[variant],
  disabledClasses,
  className || '',
].filter(Boolean).join(' ');

// Build Alpine.js attributes object
const alpineAttrs: Record<string, string> = {};
if (xData) alpineAttrs['x-data'] = xData;
if (onClick) alpineAttrs['@click'] = onClick;
if (xShow) alpineAttrs['x-show'] = xShow;
if (xBind) alpineAttrs['x-bind:class'] = xBind;

// Compute final classes (add pointer-events-none for disabled links)
const finalClasses = href && disabled ? buttonClasses + ' pointer-events-none' : buttonClasses;
---

<Element
  class={finalClasses}
  aria-label={ariaLabel}
  {...alpineAttrs}
  {...(href ? { href, ...(disabled && { 'aria-disabled': 'true' }) } : { type, disabled })}
>
  <slot>{content}</slot>
</Element>
