<style>
  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50%));
    }
  }
  
  .animate-scroll {
    animation: scroll 25s linear infinite;
    width: fit-content;
  }
  
  .animate-scroll:hover {
    animation-play-state: paused;
  }
</style>
