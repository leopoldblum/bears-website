---
// Landing Hero Component - Main hero section with video/image carousel background
// Media is loaded from the landingHero content collection
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import HeroCategory from './reusable/HeroCategory.astro';
import CarouselArrow from './CarouselArrow.astro';
import { getLandingHeroSlides } from '@utils/contentQueries';
import { heroImages, heroMedia } from '@utils/imageGlobs';

interface MediaItem {
  type: 'video' | 'image';
  src: string | ImageMetadata;
  alt?: string;
  poster?: string;
  shownText?: string;
}

interface Props {
  autoScroll?: boolean;
  autoScrollInterval?: number;
  showArrows?: boolean;
  showDots?: boolean;
}

const {
  autoScroll = false,
  autoScrollInterval = 8000,
  showArrows = true,
  showDots = false,
} = Astro.props;

// Load slides from content collection
const slides = await getLandingHeroSlides();

// Process slides into media items - all media from src/assets/hero/
const media: MediaItem[] = await Promise.all(
  slides.map(async (slide) => {
    let src: string | ImageMetadata;
    const mediaPath = `/src/assets/hero/${slide.data.media}`;
    
    if (slide.data.type === 'video') {
      // Videos use the general media glob
      if (heroMedia[mediaPath]) {
        const module = await heroMedia[mediaPath]();
        src = module.default;
      } else {
        console.warn(`Hero video not found: ${mediaPath}`);
        src = '';
      }
    } else {
      // Images use the typed image glob for Astro Image optimization
      if (heroImages[mediaPath]) {
        const imageModule = await heroImages[mediaPath]();
        src = imageModule.default;
      } else {
        console.warn(`Hero image not found: ${mediaPath}`);
        src = '';
      }
    }

    // Load poster image if specified
    let posterSrc: string | undefined;
    if (slide.data.poster) {
      const posterPath = `/src/assets/hero/${slide.data.poster}`;
      if (heroMedia[posterPath]) {
        const posterModule = await heroMedia[posterPath]();
        posterSrc = posterModule.default as string;
      }
    }

    return {
      type: slide.data.type,
      src,
      alt: slide.data.alt,
      poster: posterSrc,
      shownText: slide.data.shownText,
    };
  })
);

const hasMultipleSlides = media.length > 1;
const mediaJson = JSON.stringify(media.map((item, index) => ({
  index,
  type: item.type,
  shownText: item.shownText || '',
})));
---

<section
  class="relative h-[calc(100vh-4rem)] w-full overflow-hidden bg-linear-to-br from-[#1F1F1F] to-bears-bg"
  x-data={`{
    currentSlide: 0,
    totalSlides: ${media.length || 1},
    autoScrollInterval: null,
    autoScrollEnabled: ${autoScroll && hasMultipleSlides},
    media: ${mediaJson},

    init() {
      if (this.autoScrollEnabled) {
        this.startAutoScroll();
      }
    },

    nextSlide() {
      this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },
    prevSlide() {
      this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },
    goToSlide(index) {
      this.currentSlide = index;
      if (this.autoScrollEnabled) {
        this.resetAutoScroll();
      }
    },

    startAutoScroll() {
      if (this.autoScrollEnabled) {
        this.autoScrollInterval = setInterval(() => {
          this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
        }, ${autoScrollInterval});
      }
    },
    stopAutoScroll() {
      if (this.autoScrollInterval) {
        clearInterval(this.autoScrollInterval);
        this.autoScrollInterval = null;
      }
    },
    resetAutoScroll() {
      this.stopAutoScroll();
      this.startAutoScroll();
    },

    getCurrentShownText() {
      return this.media[this.currentSlide]?.shownText || '';
    }
  }`}
  @mouseenter="stopAutoScroll()"
  @mouseleave="startAutoScroll()"
>
  <!-- Media Layer -->
  <div class="absolute inset-0 z-0">
    {media.length > 0 ? (
      media.map((item, index) => (
        <div
          x-show={`currentSlide === ${index}`}
          x-transition:enter="transition ease-out duration-500"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-300"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="absolute inset-0"
        >
          {item.type === 'video' ? (
            <video
              class="absolute inset-0 w-full h-full object-cover"
              src={typeof item.src === 'string' ? item.src : undefined}
              poster={item.poster}
              autoplay
              muted
              loop
              playsinline
            />
          ) : (
            typeof item.src === 'object' ? (
              <Image
                src={item.src as ImageMetadata}
                alt={item.alt || ''}
                class="absolute inset-0 w-full h-full object-cover"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            ) : (
              <img
                src={item.src as string}
                alt={item.alt || ''}
                class="absolute inset-0 w-full h-full object-cover"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            )
          )}
        </div>
      ))
    ) : (
      <!-- Fallback placeholder when no media provided -->
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] bg-cover bg-center opacity-30"></div>
    )}

    <!-- Gradient overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-bears-bg/80 via-bears-bg/40 to-transparent"></div>

    <!-- Bottom gradient for HeroCategories area -->
    <div class="absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t from-bears-bg via-bears-bg/60 to-transparent pointer-events-none"></div>

    <!-- Moving gradient bulge for selected category (positioned relative to media container) -->
    <!-- <div
      class="hidden lg:block absolute bg-bears-bg/90 pointer-events-none transition-all duration-700 ease-out z-10"
      :style="`left: ${categoryLeft}px; width: ${categoryWidth}px; height: ${categoryHeight}px; bottom: ${categoryBottom}px; clip-path: polygon(10% 0, 90% 0, 100% 100%, 0% 100%);`"
      x-data="{ activeIndex: 0, categoryLeft: 0, categoryWidth: 300, categoryHeight: 200, categoryBottom: 0 }"
      x-init="categoryLeft = 0; categoryWidth = 300; categoryHeight = 200; categoryBottom = 0;"
      @update-active-index.window="activeIndex = $event.detail.index"
      @update-category-position.window="categoryLeft = $event.detail.left - (window.innerWidth * 0.03); categoryWidth = $event.detail.width; categoryHeight = $event.detail.height; categoryBottom = $event.detail.bottom"
    ></div> -->

    <!-- shownText display (top right corner) -->
    <div
      x-show="getCurrentShownText()"
      x-text="getCurrentShownText()"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 translate-y-2"
      class="absolute top-4 right-4 sm:top-8 sm:right-8 lg:top-12 lg:right-12 bg-black/50 backdrop-blur-sm px-4 py-2 text-white text-sm sm:text-base lg:text-lg z-20"
    ></div>

    <!-- Dot Indicators -->
    {hasMultipleSlides && showDots && (
      <div class="absolute bottom-4 sm:bottom-6 lg:bottom-8 left-1/2 -translate-x-1/2 z-20 flex gap-2 sm:gap-3">
        {media.map((_, index) => (
          <button
            @click={`goToSlide(${index})`}
            :class={`currentSlide === ${index} ? 'bg-white scale-110' : 'bg-white/40 hover:bg-white/60'`}
            class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full transition-all duration-200 cursor-pointer"
            aria-label={`Go to slide ${index + 1}`}
          />
        ))}
      </div>
    )}
  </div>

  <!-- Navigation Arrows (outside media layer to avoid z-index blocking) -->
  {hasMultipleSlides && showArrows && (
    <>
      <CarouselArrow
        direction="prev"
        onClick="prevSlide()"
        variant="absolute"
        position="left"
        inverted={true}
      />
      <CarouselArrow
        direction="next"
        onClick="nextSlide()"
        variant="absolute"
        position="right"
        inverted={true}
      />
    </>
  )}

  <!-- Content Container -->
  <div class="relative z-10 h-full">
    <div
      class="container mx-auto px-4 sm:px-8 lg:px-16 h-full flex flex-col md:flex-col justify-end md:justify-between pb-8 sm:pb-12 lg:py-20 transition-all duration-300 ease-out"
    >
      <!-- Logo - visible on all breakpoints -->
      <div class="max-w-md flex-shrink-0 pt-30 sm:pt-20 lg:pt-24">
        <h1 class="text-[3.5rem] sm:text-[5.5rem] lg:text-9xl font-bold text-bears-accent drop-shadow-lg">BEARS</h1>
      </div>

      <!-- Hero Categories - three columns on desktop -->
      <div
        x-ref="categoriesContainer"
        class="w-screen relative left-1/2 right-1/2 -translate-x-1/2 mt-auto lg:mt-auto pb-4 lg:pb-20 px-4 sm:px-6 lg:px-16"
        x-data="{ activeIndex: 0 }"
        @mouseenter="$dispatch('update-active-index', { index: activeIndex })"
      >
        <div class="w-[40%] lg:w-[80%] mx-[10vw] lg:mx-auto flex flex-col lg:flex-row lg:justify-around gap-8 lg:gap-12 relative z-10">
          <div class="category-item flex-1" x-ref="cat0" @mouseenter="activeIndex = 0; $dispatch('update-active-index', { index: 0 }); const rect0 = $refs.cat0.getBoundingClientRect(); const contRect0 = $refs.categoriesContainer.getBoundingClientRect(); $dispatch('update-category-position', { left: rect0.left - contRect0.left, width: rect0.width, height: rect0.height, bottom: contRect0.bottom - rect0.bottom })">
            <HeroCategory
              title="How to Join"
              description="Becoming a member of Bears e.V."
              href="/about-us"
            />
          </div>
          <div class="category-item flex-1" x-ref="cat1" @mouseenter="activeIndex = 1; $dispatch('update-active-index', { index: 1 }); const rect1 = $refs.cat1.getBoundingClientRect(); const contRect1 = $refs.categoriesContainer.getBoundingClientRect(); $dispatch('update-category-position', { left: rect1.left - contRect1.left, width: rect1.width, height: rect1.height, bottom: contRect1.bottom - rect1.bottom })">
            <HeroCategory
              title="Our Projects"
              description="Explore what we are working on"
              href="/projects"
            />
          </div>
          <div class="category-item flex-1" x-ref="cat2" @mouseenter="activeIndex = 2; $dispatch('update-active-index', { index: 2 }); const rect2 = $refs.cat2.getBoundingClientRect(); const contRect2 = $refs.categoriesContainer.getBoundingClientRect(); $dispatch('update-category-position', { left: rect2.left - contRect2.left, width: rect2.width, height: rect2.height, bottom: contRect2.bottom - rect2.bottom })">
            <HeroCategory
              title="Events"
              description="Upcoming workshops and meetups"
              href="/events"
            />
          </div>
        </div>
      </div>

      <!-- Spacer - hidden on mobile, visible on desktop -->
      <div class="hidden md:block"></div>
    </div>
  </div>
</section>
