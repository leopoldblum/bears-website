---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPageContent } from "@utils/contentQueries";
import { getLocale, localizeUrl } from "@utils/i18n";

export const prerender = true;

const locale = getLocale(Astro.url);
const content = await getPageContent('404/not-found', locale);

const navContent = await getPageContent('nav-links/header', locale);
const navLinks = navContent?.data.navLinks ?? [
  { href: "/projects", label: "Projects" },
  { href: "/sponsors", label: "Sponsors" },
  { href: "/events", label: "Events" },
  { href: "/about-us", label: "About Us" },
  { href: "/contact", label: "Contact" },
];
---

<BaseLayout title="404 - Page Not Found">
  <div
    class="min-h-[calc(100svh-3.5rem)] flex items-center justify-center px-4 sm:px-6"
    x-data="{ show: false }"
    x-init="setTimeout(() => show = true, 50)"
  >
    <div
      class="text-center py-16 sm:py-20 -translate-y-20 sm:-translate-y-24"
      x-show="show"
      x-transition:enter="transition ease-out duration-500"
      x-transition:enter-start="opacity-0 translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-cloak
    >
      <div class="astronaut-float mb-6" aria-hidden="true">
        <svg class="w-16 h-16 sm:w-20 sm:h-20 mx-auto" viewBox="0 0 100 100" fill="none">
          <!-- helmet -->
          <circle cx="50" cy="36" r="18" fill="white" opacity="0.9"/>
          <!-- visor -->
          <ellipse cx="50" cy="37" rx="12" ry="10" fill="#1a1a2e" opacity="0.85"/>
          <ellipse cx="50" cy="36" rx="10" ry="8" fill="#2a2a4a">
            <animate attributeName="opacity" values="0.6;0.9;0.6" dur="3s" repeatCount="indefinite"/>
          </ellipse>
          <!-- visor glint -->
          <ellipse cx="45" cy="33" rx="3" ry="2" fill="white" opacity="0.25"/>
          <!-- body -->
          <rect x="36" y="52" width="28" height="24" rx="8" fill="white" opacity="0.85"/>
          <!-- backpack -->
          <rect x="30" y="54" width="8" height="18" rx="3" fill="white" opacity="0.6"/>
          <!-- left arm -->
          <rect x="22" y="54" width="16" height="7" rx="3.5" fill="white" opacity="0.8" transform="rotate(-20 30 57)"/>
          <!-- right arm -->
          <rect x="62" y="54" width="16" height="7" rx="3.5" fill="white" opacity="0.8" transform="rotate(25 70 57)"/>
          <!-- left leg -->
          <rect x="39" y="73" width="8" height="14" rx="4" fill="white" opacity="0.8" transform="rotate(10 43 80)"/>
          <!-- right leg -->
          <rect x="53" y="73" width="8" height="14" rx="4" fill="white" opacity="0.8" transform="rotate(-8 57 80)"/>
          <!-- tether (cut) -->
          <path d="M30 62 Q15 55 8 48" stroke="white" stroke-width="1.5" opacity="0.3" stroke-linecap="round" stroke-dasharray="3 3"/>
        </svg>
      </div>

      <h1
        class="text-8xl sm:text-9xl font-bold text-bears-accent leading-none tracking-tight"
      >
        404
      </h1>

      <p
        class="text-xl sm:text-2xl font-semibold text-bears-text-onDark mt-6"
      >
        {content?.data.title ?? "Houston, we have a problem."}
      </p>

      <p class="text-sm sm:text-base text-bears-text-onDark/50 mt-3 max-w-sm mx-auto">
        {content?.data.description ?? "The page you're looking for has drifted into deep space."}
      </p>

      <nav class="flex items-center justify-center gap-4 sm:gap-6 mt-10 sm:mt-12">
        {navLinks.map((link: { href: string; label: string }) => (
          <a
            href={localizeUrl(link.href, locale)}
            class="text-sm text-bears-text-onDark/70 hover:text-bears-accent transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="mt-10 sm:mt-12">
        <a
          href={localizeUrl(content?.data.buttonHref ?? "/", locale)}
          class="inline-flex items-center justify-center gap-2 bg-bears-accent text-bears-text-onDark rounded-full px-6 py-2.5 text-sm font-medium shadow-[0_2px_8px_rgba(0,0,0,0.25)] hover:bg-bears-accent/90 hover:shadow-[0_4px_12px_rgba(0,0,0,0.3),0_0_20px_rgba(197,14,31,0.25)] hover:scale-105 active:bg-bears-accent-muted active:scale-100 transition-all duration-300 ease-out cursor-pointer"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
            ></path>
          </svg>
          {content?.data.buttonText ?? "Go Home"}
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .astronaut-float {
    animation: float 6s ease-in-out infinite, spin 20s linear infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @keyframes spin {
    from { rotate: 0deg; }
    to { rotate: 360deg; }
  }
</style>
