---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page Not Found">
  <div
    class="min-h-screen flex items-center justify-center px-4 sm:px-6"
    x-data="{ show: false }"
    x-init="setTimeout(() => show = true, 50)"
  >
    <div
      class="text-center py-16 sm:py-20"
      x-show="show"
      x-transition:enter="transition ease-out duration-500"
      x-transition:enter-start="opacity-0 translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-cloak
    >
      <h1
        class="text-8xl sm:text-9xl font-bold text-bears-accent leading-none tracking-tight"
      >
        404
      </h1>

      <p
        class="text-xl sm:text-2xl font-semibold text-bears-text-onDark mt-6"
      >
        Page not found
      </p>

      <p class="text-sm sm:text-base text-bears-text-onDark/50 mt-3 max-w-sm mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <nav class="flex items-center justify-center gap-4 sm:gap-6 mt-10 sm:mt-12">
        <a
          href="/projects"
          class="text-sm text-bears-text-onDark/70 hover:text-bears-accent transition-colors"
        >
          Projects
        </a>
        <a
          href="/events"
          class="text-sm text-bears-text-onDark/70 hover:text-bears-accent transition-colors"
        >
          Events
        </a>
        <a
          href="/sponsors"
          class="text-sm text-bears-text-onDark/70 hover:text-bears-accent transition-colors"
        >
          Sponsors
        </a>
        <a
          href="/about-us"
          class="text-sm text-bears-text-onDark/70 hover:text-bears-accent transition-colors"
        >
          About Us
        </a>
      </nav>

      <div class="mt-10 sm:mt-12">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-bears-accent text-bears-text-onDark rounded-full px-6 py-2.5 text-sm font-medium shadow-[0_2px_8px_rgba(0,0,0,0.25)] hover:bg-bears-accent/90 hover:shadow-[0_4px_12px_rgba(0,0,0,0.3),0_0_20px_rgba(197,14,31,0.25)] hover:scale-105 active:bg-bears-accent-muted active:scale-100 transition-all duration-300 ease-out cursor-pointer"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
            ></path>
          </svg>
          Go Home
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
