---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeroImage from "@components/reusable/PageHeroImage.astro";
import sponsorHeroImage from "@assets/hero/sponsors/project-5.jpg";
---

<BaseLayout title="Sponsors">
  <PageHeroImage
    image={sponsorHeroImage}
    alt="Partnership and collaboration opportunities with BEARS"
    title="Sponsors"
    subtitle="Thank you to our partners who make our aerospace projects possible"
  />

  <div class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <p class="text-sm sm:text-base text-bears-text-onDark">Sponsors page content - To be defined</p>
  </div>
</BaseLayout>
