---
import PostLayout from "@layouts/PostLayout.astro";
import { type CollectionEntry } from "astro:content";
import { loadCoverImage } from "@utils/imageLoader";
import { getPublishedEvents } from "@utils/contentQueries";


export async function getStaticPaths() {
  const allEvents = await getPublishedEvents();

  return allEvents.map(entry => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'events'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Load cover image
const coverImageData = await loadCoverImage(
  entry.data.coverImage,
  'event',
  { itemTitle: entry.data.title, itemSlug: entry.slug }
);

// Extract data for template use
const { title, date, categoryEvent } = entry.data;
---

<PostLayout
  title={title}
  date={date}
  coverImage={coverImageData}
  category={categoryEvent}
  type="event"
>
  <Content />
</PostLayout>
