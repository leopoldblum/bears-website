---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPageContent } from "@utils/contentQueries";
import { getLocale } from "@utils/i18n";

export const prerender = true;

const locale = getLocale(Astro.url);
const entry = await getPageContent('datenschutz/datenschutz', locale);
const title = entry?.data.title ?? "Datenschutz";
const subtitle = entry?.data.subtitle;
const { Content } = entry ? await entry.render() : { Content: null };
---

<BaseLayout title={title}>
  <div class="datenschutz-container">
    <div class="datenschutz-inner">
      <header class="datenschutz-header">
        <h1 id="datenschutz" class="datenschutz-title scroll-mt-20">{title}</h1>
        {subtitle && <p class="datenschutz-subtitle">{subtitle}</p>}
        <div class="datenschutz-divider"></div>
      </header>

      {Content && (
        <div class="prose-content">
          <Content />
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .datenschutz-container {
    width: 100%;
    padding: 4rem 1rem;
  }

  .datenschutz-inner {
    max-width: 80ch;
    margin: 0 auto;
  }

  .datenschutz-header {
    margin-bottom: 2.5rem;
  }

  .datenschutz-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-bears-text-onDark);
    margin: 0 0 0.75rem 0;
  }

  .datenschutz-subtitle {
    font-size: 1.0625rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.6;
    margin: 0 0 1.5rem 0;
  }

  .datenschutz-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
  }

  /* Prose Content — matches PostLayout prose styling */
  .prose-content {
    color: var(--color-bears-text-onDark);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .prose-content :global(h2) {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-bears-text-onDark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-content :global(h3) {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-bears-text-onDark);
    margin-top: 2rem;
    margin-bottom: 0.875rem;
  }

  .prose-content :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
  }

  .prose-content :global(a) {
    color: var(--color-bears-accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .prose-content :global(a:hover) {
    opacity: 0.8;
    text-decoration: underline;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.75rem;
  }

  .prose-content :global(li) {
    margin-bottom: 0.625rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    line-height: 1.7;
  }

  .prose-content :global(ul > li) {
    list-style-type: disc;
  }

  .prose-content :global(ul > li::marker),
  .prose-content :global(ol > li::marker) {
    color: var(--color-bears-accent);
  }

  .prose-content :global(ol > li) {
    list-style-type: decimal;
  }

  .prose-content :global(strong) {
    font-weight: 600;
    color: var(--color-bears-text-onDark);
  }

  .prose-content :global(hr) {
    margin: 2.5rem 0;
    border: none;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
  }

  @media (min-width: 640px) {
    .datenschutz-container {
      padding: 5rem 1.5rem;
    }

    .datenschutz-header {
      margin-bottom: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .datenschutz-container {
      padding: 6rem 2rem;
    }

    .prose-content {
      font-size: 1.125rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prose-content :global(a) {
      transition: none;
    }
  }
</style>
