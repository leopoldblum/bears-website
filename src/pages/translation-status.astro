---
import BaseLayout from "@layouts/BaseLayout.astro";

export const prerender = true;

const ADMIN_BUILD = process.env.ADMIN_BUILD === 'true';

const enumerate = (glob: Record<string, unknown>, prefix: string) =>
  new Set(Object.keys(glob).map((p) => p.slice(prefix.length).replace(/\.mdx?$/, '')));

const bilingualSurfaces = [
  {
    name: 'Events',
    contentPath: 'events',
    en: enumerate(import.meta.glob('/src/content/events/en/*.mdx'), '/src/content/events/en/'),
    de: enumerate(import.meta.glob('/src/content/events/de/*.mdx'), '/src/content/events/de/'),
  },
  {
    name: 'Projects',
    contentPath: 'projects',
    en: enumerate(import.meta.glob('/src/content/projects/en/*.mdx'), '/src/content/projects/en/'),
    de: enumerate(import.meta.glob('/src/content/projects/de/*.mdx'), '/src/content/projects/de/'),
  },
  {
    name: 'Page text',
    contentPath: 'page-text',
    en: enumerate(import.meta.glob('/src/content/page-text/en/**/*.mdx'), '/src/content/page-text/en/'),
    de: enumerate(import.meta.glob('/src/content/page-text/de/**/*.mdx'), '/src/content/page-text/de/'),
  },
];

const report = bilingualSurfaces.map((s) => ({
  name: s.name,
  contentPath: s.contentPath,
  missingInDe: [...s.en].filter((f) => !s.de.has(f)).sort(),
  missingInEn: [...s.de].filter((f) => !s.en.has(f)).sort(),
  total: s.en.size + s.de.size,
}));

const totalMismatches = report.reduce(
  (sum, r) => sum + r.missingInDe.length + r.missingInEn.length,
  0,
);
const allInSync = totalMismatches === 0;

const generatedAt = new Date().toISOString();
---

<BaseLayout title="Translation status">
  <main class="mx-auto max-w-4xl px-4 sm:px-6 py-12 sm:py-16">
    {!ADMIN_BUILD ? (
      <section class="rounded-2xl border border-bears-text-onDark/10 bg-bears-bg-surface p-8 text-center">
        <p class="text-lg text-bears-text-onDark/70">
          This page is only available on the admin site.
        </p>
        <p class="mt-2 text-sm text-bears-text-onDark/50">
          Visit <a href="https://admin.bears-space.de/translation-status" class="text-bears-accent underline hover:no-underline">admin.bears-space.de/translation-status</a>.
        </p>
      </section>
    ) : (
      <>
        <header class="mb-10 sm:mb-14">
          <div class="flex items-center gap-3">
            <span
              class:list={[
                'inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm font-medium',
                allInSync
                  ? 'bg-emerald-500/15 text-emerald-300'
                  : 'bg-amber-500/15 text-amber-300',
              ]}
            >
              {allInSync ? '✅ In sync' : `⚠️ ${totalMismatches} mismatch${totalMismatches === 1 ? '' : 'es'}`}
            </span>
          </div>
          <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-bears-text-onDark">
            Translation status
          </h1>
          <p class="mt-3 text-sm text-bears-text-onDark/60">
            Shows which bilingual content files exist in only one locale. Auto-generated at admin build time —
            this snapshot was captured <time datetime={generatedAt}>{generatedAt}</time>. The page refreshes automatically on every editor commit (lag: ~1–2 minutes).
          </p>
          <p class="mt-2 text-sm text-bears-text-onDark/60">
            Edit content at <a href="/keystatic" class="text-bears-accent underline hover:no-underline">/keystatic</a>.
          </p>
        </header>

        {allInSync ? (
          <section class="rounded-2xl border border-emerald-500/20 bg-emerald-500/5 p-8">
            <p class="text-emerald-300 font-medium">
              ✅ All English and German files are paired up.
            </p>
            <p class="mt-2 text-sm text-bears-text-onDark/60">
              Nothing to do here. New content added in one locale should always be mirrored in the other.
            </p>
          </section>
        ) : (
          <div class="space-y-6">
            {report.map((r) => {
              const inSync = r.missingInDe.length === 0 && r.missingInEn.length === 0;
              return (
                <section
                  class:list={[
                    'rounded-2xl border p-6',
                    inSync
                      ? 'border-bears-text-onDark/10 bg-bears-bg-surface'
                      : 'border-amber-500/20 bg-amber-500/5',
                  ]}
                >
                  <header class="flex items-center justify-between gap-4 mb-4">
                    <h2 class="text-xl font-semibold text-bears-text-onDark">{r.name}</h2>
                    <span class="text-sm text-bears-text-onDark/50">
                      {inSync
                        ? '✅ in sync'
                        : `⚠️ ${r.missingInDe.length + r.missingInEn.length} missing`}
                    </span>
                  </header>

                  {inSync ? (
                    <p class="text-sm text-bears-text-onDark/50">
                      All {r.total} files are paired between en/ and de/.
                    </p>
                  ) : (
                    <div class="space-y-4">
                      {r.missingInDe.length > 0 && (
                        <div>
                          <h3 class="text-sm font-semibold text-bears-text-onDark/80 mb-2">
                            Missing German translations ({r.missingInDe.length})
                          </h3>
                          <ul class="space-y-1">
                            {r.missingInDe.map((slug) => (
                              <li class="flex items-center gap-2 text-sm text-bears-text-onDark/70 font-mono">
                                <span class="text-amber-400">→</span>
                                <span>src/content/{r.contentPath}/de/{slug}.mdx</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}

                      {r.missingInEn.length > 0 && (
                        <div>
                          <h3 class="text-sm font-semibold text-bears-text-onDark/80 mb-2">
                            Missing English versions ({r.missingInEn.length})
                          </h3>
                          <ul class="space-y-1">
                            {r.missingInEn.map((slug) => (
                              <li class="flex items-center gap-2 text-sm text-bears-text-onDark/70 font-mono">
                                <span class="text-amber-400">→</span>
                                <span>src/content/{r.contentPath}/en/{slug}.mdx</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                    </div>
                  )}
                </section>
              );
            })}
          </div>
        )}
      </>
    )}
  </main>
</BaseLayout>
