---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import NewsGridElement from "../components/NewsGridElement.astro";
import type { ImageMetadata } from 'astro';

// Filter and sort projects
const allProjects = await getCollection("posts", ({ id, data }) => {
  return id.startsWith('projects/') && (import.meta.env.DEV || !data.isDraft);
});

const sortedProjects = allProjects.sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

// Import images
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/projects/*.{jpg,jpeg,png,webp}");

const projectsWithImages = await Promise.all(
  sortedProjects.map(async (project) => {
    // Start with null, NewsGridElement will use default
    let imageData: ImageMetadata | null = null;
    let imageLoadFailed = false;

    // Try to load custom image if specified
    if (project.data.coverImageType === "CUSTOM" && project.data.coverImage) {
      const imagePath = `/src/assets/projects/${project.data.coverImage}`;

      if (images[imagePath]) {
        try {
          const imageModule = await images[imagePath]();
          imageData = imageModule.default;
        } catch (error) {
          imageLoadFailed = true;
        }
      } else {
        imageLoadFailed = true;
      }
    }

    // Development warnings
    if (import.meta.env.DEV) {
      if (project.data.coverImageType === "DEFAULT") {
        console.warn(
          `⚠️  Project "${project.data.title}" (${project.slug}) is using DEFAULT cover image`
        );
      } else if (imageLoadFailed) {
        console.warn(
          `⚠️  Project "${project.data.title}" (${project.slug}) - image "${project.data.coverImage}" failed to load, using default`
        );
      }
    }

    return { ...project.data, slug: project.slug, coverImage: imageData };
  })
);
---

<BaseLayout title="Projects">
  <div class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 md:px-8">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 sm:mb-8 md:mb-12 text-bears-accent">
      Projects
    </h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {projectsWithImages.map((project) => (
        <NewsGridElement
          imageData={project.coverImage}
          imageAlt={project.title}
          date={project.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          title={project.title}
          description={project.description}
          href={`/projects/${project.slug.replace('projects/', '')}`}
          postType="projects"
        />
      ))}
    </div>
  </div>
</BaseLayout>
