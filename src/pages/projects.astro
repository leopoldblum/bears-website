---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostShowcase from "@posts-catalog/PostShowcase.astro";
import FilterMenu from "@posts-catalog/FilterMenu.astro";
import SortMenu from "@posts-catalog/SortMenu.astro";
import Pagination from "@posts-catalog/Pagination.astro";
import PageHeroImage from "@reusable/PageHeroImage.astro";
import ProjectCategories from "@components/projects/ProjectCategories.astro";
import { loadCollectionImages } from "@utils/imageLoader";
import { getPublishedProjects, getPageContent } from "@utils/contentQueries";
import { CategoryProjectEnum } from "@types";
import { getCategoryLabel } from "@utils/categoryLabels";

import CrosslinkBanner from "@reusable/CrosslinkBanner.astro";
import { projectsHeroImages } from "@utils/imageGlobs";
import { loadAllImagesFromDirectory } from "@utils/imageLoader";

const pageContent = await getPageContent('projects/projects-title');
const categoriesIntro = await getPageContent('projects/categories-intro');
// Fetch category descriptions for the overview section
const categoryContentIds = [
  { key: 'experimental-rocketry', id: 'projects/category-experimental-rocketry' },
  { key: 'science-and-experiments', id: 'projects/category-science-and-experiments' },
  { key: 'robotics', id: 'projects/category-robotics' },
];
const categoryDescriptions = await Promise.all(
  categoryContentIds.map(async ({ key, id }) => {
    const content = await getPageContent(id);
    return {
      key,
      title: content?.data.title ?? key,
      description: content?.data.description ?? '',
    };
  })
);
const loadedHeroImages = await loadAllImagesFromDirectory(projectsHeroImages);
const projectHeroImage = loadedHeroImages[0];

// Get all published projects (filtered and sorted)
const sortedProjects = await getPublishedProjects();

// Load images for projects
const projectsWithLoadedImages = await loadCollectionImages(sortedProjects, 'project');

// Map to format expected by PostShowcase
const projectsWithImages = projectsWithLoadedImages.map((project) => ({
  ...project.data,
  slug: project.slug,
  coverImage: project.loadedImage,
}));

// Get category options from enum and build custom labels map
const projectCategories = CategoryProjectEnum.options;

const categoryLabelsMap = Object.fromEntries(
  projectCategories.map(cat => [cat, getCategoryLabel(cat)])
);

// Prepare data for Alpine.js (embedded directly in x-data to avoid race conditions)
const projectsData = JSON.stringify(projectsWithImages.map((p, i) => ({
  index: i,
  category: p.categoryProject,
  isCompleted: p.isProjectCompleted === true,
  dateTimestamp: p.date.getTime()
})));
---

<BaseLayout title={pageContent?.data.title ?? "Projects"}>
  <PageHeroImage
    image={projectHeroImage}
    alt="BEARS student working on satellite project"
    title={pageContent?.data.title ?? "Projects"}
    subtitle={pageContent?.data.subtitle ?? ""}
  />

  <div
    class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 lg:px-8"
    x-data={`{
      filterMenuOpen: false,
      sortMenuOpen: false,
      activeCategory: [],
      completionStatus: [],
      sortOrder: 'newest',
      currentPage: 1,
      itemsPerPage: window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3,
      projectsData: ${projectsData},
      visibleIndices: [],
      _transitioning: false,
      _pendingIndices: null,

      init() {
        const params = new URLSearchParams(window.location.search);

        // Parse and apply category filter
        const urlCategory = params.get('category');
        if (urlCategory) {
          const categories = urlCategory.split(',').filter(Boolean);
          this.activeCategory.push(...categories);
        }

        // Parse and apply status filter (completed/ongoing)
        const urlStatus = params.get('status');
        if (urlStatus) {
          const statuses = urlStatus.split(',').filter(Boolean);
          this.completionStatus.push(...statuses);
        }

        // Parse sort order
        if (params.get('sort') === 'oldest') {
          this.sortOrder = 'oldest';
        }

        // Parse page number (after filters so totalPages is correct)
        const urlPage = parseInt(params.get('page'), 10);
        if (urlPage && urlPage > 0) {
          this.currentPage = Math.min(urlPage, this.totalPages || 1);
        }

        // Update itemsPerPage on window resize
        window.addEventListener('resize', () => {
          const newItemsPerPage = window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3;
          if (newItemsPerPage !== this.itemsPerPage) {
            this.itemsPerPage = newItemsPerPage;
            // Adjust current page if needed
            if (this.currentPage > this.totalPages) {
              this.currentPage = this.totalPages || 1;
            }
          }
        });

        // Initialize display buffer and watch for changes
        this.visibleIndices = [...this.paginatedIndices];
        this.$watch('paginatedIndices', (newVal) => {
          const newStr = JSON.stringify(newVal);
          const oldStr = JSON.stringify(this.visibleIndices);
          if (newStr !== oldStr) {
            this._animateGrid([...newVal]);
          }
        });
      },

      get hasActiveFilters() {
        return this.activeCategory.length > 0 || this.completionStatus.length > 0;
      },
      clearFilters() {
        this.activeCategory = [];
        this.completionStatus = [];
        this.currentPage = 1;
      },
      toggleFilter(array, value) {
        const idx = array.indexOf(value);
        if (idx === -1) {
          array.push(value);
        } else {
          array.splice(idx, 1);
        }
        this.currentPage = 1;
      },
      get filteredIndices() {
        const filtered = this.projectsData.reduce((acc, project) => {
          const categoryMatch = this.activeCategory.length === 0 || this.activeCategory.includes(project.category);
          const statusMatch = this.completionStatus.length === 0 ||
                             (this.completionStatus.includes('completed') && project.isCompleted) ||
                             (this.completionStatus.includes('ongoing') && !project.isCompleted);
          if (categoryMatch && statusMatch) {
            acc.push(project.index);
          }
          return acc;
        }, []);

        // Sort by date based on sortOrder
        filtered.sort((a, b) => {
          const dateA = this.projectsData[a].dateTimestamp;
          const dateB = this.projectsData[b].dateTimestamp;
          return this.sortOrder === 'newest' ? dateB - dateA : dateA - dateB;
        });

        return filtered;
      },
      get totalPages() {
        return Math.ceil(this.filteredIndices.length / this.itemsPerPage);
      },
      get paginatedIndices() {
        const start = (this.currentPage - 1) * this.itemsPerPage;
        const end = start + this.itemsPerPage;
        return this.filteredIndices.slice(start, end);
      },
      goToPage(page) {
        if (page < 1 || page > this.totalPages) return;
        this.currentPage = page;
      },

      async _animateGrid(newIndices) {
        if (this._transitioning) {
          this._pendingIndices = [...newIndices];
          return;
        }
        this._transitioning = true;
        const grid = this.$refs.grid;

        if (!grid || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          this.visibleIndices = [...newIndices];
          this._transitioning = false;
          return;
        }

        // Exit: fade out grid
        grid.style.transition = 'opacity 150ms ease-out, transform 150ms ease-out';
        grid.style.opacity = '0';
        grid.style.transform = 'translateY(6px)';
        await new Promise(r => setTimeout(r, 160));

        // Swap: update display buffer while grid is invisible
        this.visibleIndices = [...newIndices];
        await this.$nextTick();

        // Re-trigger card entrance animations with dynamic stagger
        const visibleCards = grid.querySelectorAll(':scope > div:not(.hidden) .showcase-card');
        visibleCards.forEach((card) => {
          card.style.animation = 'none';
          card.style.animationDelay = '';
        });
        void grid.offsetHeight;
        visibleCards.forEach((card, i) => {
          card.style.animation = '';
          card.style.animationDelay = i * 50 + 'ms';
        });

        // Enter: snap grid visible, cards animate individually
        grid.style.transition = 'none';
        grid.style.opacity = '1';
        grid.style.transform = '';

        // Cleanup after card animations complete
        const maxDelay = visibleCards.length * 50;
        setTimeout(() => {
          visibleCards.forEach((card) => { card.style.animationDelay = ''; });
          grid.style.transition = '';
          this._transitioning = false;

          if (this._pendingIndices) {
            const pending = this._pendingIndices;
            this._pendingIndices = null;
            this._animateGrid(pending);
          }
        }, maxDelay + 450);
      }
    }`}
  >
    <!-- Category Overview -->
    <ProjectCategories
      categories={categoryDescriptions}
      subtitle={categoriesIntro?.data.subtitle}
      description={categoriesIntro?.data.description}
    >
      <SortMenu />
      <FilterMenu
        filterGroups={[
          {
            label: 'Category',
            stateVariable: 'activeCategory',
            categories: projectCategories,
            categoryLabels: categoryLabelsMap
          },
          {
            label: 'Status',
            stateVariable: 'completionStatus',
            categories: ['completed', 'ongoing'],
            categoryLabels: { completed: 'Completed', ongoing: 'Ongoing' }
          }
        ]}
      />
    </ProjectCategories>

    <!-- Result count -->
    <p
      x-show="filteredIndices.length > 0"
      class="text-sm text-bears-text-onDark/40 text-right mb-4"
      x-text="`Showing ${(currentPage - 1) * itemsPerPage + 1}\u2013${Math.min(currentPage * itemsPerPage, filteredIndices.length)} of ${filteredIndices.length} projects`"
    ></p>

    <!-- No results state -->
    <div
      x-show="filteredIndices.length === 0"
      x-cloak
      class="flex flex-col items-center justify-center py-24 text-center"
    >
      <svg class="w-12 h-12 text-bears-text-onDark/20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
      <p class="text-bears-text-onDark/50 text-lg mb-1">No projects match your filters</p>
      <p class="text-bears-text-onDark/30 text-sm mb-6">Try adjusting or clearing your filters</p>
      <button
        type="button"
        @click="clearFilters()"
        class="text-sm text-bears-accent hover:text-bears-accent/80 transition-colors cursor-pointer"
      >
        Clear all filters
      </button>
    </div>

    <!-- Projects Grid -->
    <div
      x-ref="grid"
      x-show="filteredIndices.length > 0"
      class="projects-grid grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8 min-h-252 lg:min-h-168 content-start"
    >
      {projectsWithImages.map((project, index) => (
        <div
          :class={`{ 'hidden': !visibleIndices.includes(${index}) }`}
          :style={`'order: ' + (visibleIndices.indexOf(${index}) !== -1 ? visibleIndices.indexOf(${index}) : 9999)`}
        >
          <PostShowcase
            coverImage={project.coverImage}
            imageAlt={project.title}
            date={project.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            title={project.title}
            description={project.description}
            href={`/projects/${project.slug}`}
            isCompleted={project.isProjectCompleted}
            category={getCategoryLabel(project.categoryProject)}
          />
        </div>
      ))}
    </div>

    <!-- Pagination Controls -->
    <Pagination />

    <CrosslinkBanner
      text="Want to see what's happening?"
      linkText="Check out our events"
      href="/events"
    />
  </div>
</BaseLayout>
