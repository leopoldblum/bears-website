---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostShowcase from "../components/PostShowcase.astro";
import { loadCollectionImages } from "../utils/imageLoader";
import { getPublishedProjects } from "../utils/contentQueries";

// Get all published projects (filtered and sorted)
const sortedProjects = await getPublishedProjects();

// Load images for projects
const projectsWithLoadedImages = await loadCollectionImages(sortedProjects as any, 'project');

// Map to format expected by PostShowcase
const projectsWithImages = projectsWithLoadedImages.map((project: any) => ({
  ...project.data,
  slug: project.slug,
  coverImage: project.loadedImage,
}));
---

<BaseLayout title="Projects">
  <div class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 sm:mb-8 lg:mb-12 text-bears-accent">
      Projects
    </h1>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      {projectsWithImages.map((project) => (
        <PostShowcase
          coverImage={project.coverImage}
          imageAlt={project.title}
          date={project.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          title={project.title}
          description={project.description}
          href={`/projects/${project.slug}`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
