---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostShowcase from "@posts-catalog/PostShowcase.astro";
import FilterMenu from "@posts-catalog/FilterMenu.astro";
import SortMenu from "@posts-catalog/SortMenu.astro";

import PageHeroImage from "@reusable/PageHeroImage.astro";
import ProjectCategories from "@components/projects/ProjectCategories.astro";
import { loadCollectionImages } from "@utils/imageLoader";
import { getPublishedProjects, getPageContent } from "@utils/contentQueries";
import { CategoryProjectEnum } from "@types";
import { getCategoryLabel } from "@utils/categoryLabels";

import CrosslinkBanner from "@reusable/CrosslinkBanner.astro";
import { projectsHeroImages } from "@utils/imageGlobs";
import { loadAllImagesFromDirectory } from "@utils/imageLoader";

const pageContent = await getPageContent('projects/projects-title');
const categoriesIntro = await getPageContent('projects/categories-intro');
const emptyState = await getPageContent('projects/projects-empty-state');
const crosslink = await getPageContent('projects/projects-crosslink');
// Fetch category descriptions for the overview section
const categoryContentIds = [
  { key: 'experimental-rocketry', id: 'projects/category-experimental-rocketry' },
  { key: 'science-and-experiments', id: 'projects/category-science-and-experiments' },
  { key: 'robotics', id: 'projects/category-robotics' },
];
const categoryDescriptions = await Promise.all(
  categoryContentIds.map(async ({ key, id }) => {
    const content = await getPageContent(id);
    return {
      key,
      title: content?.data.title ?? key,
      description: content?.data.description ?? '',
    };
  })
);
const loadedHeroImages = await loadAllImagesFromDirectory(projectsHeroImages);
const projectHeroImage = loadedHeroImages[0];

// Get all published projects (filtered and sorted)
const sortedProjects = await getPublishedProjects();

// Load images for projects
const projectsWithLoadedImages = await loadCollectionImages(sortedProjects, 'project');

// Map to format expected by PostShowcase
const projectsWithImages = projectsWithLoadedImages.map((project) => ({
  ...project.data,
  slug: project.slug,
  coverImage: project.loadedImage,
}));

// Get category options from enum and build custom labels map
const projectCategories = CategoryProjectEnum.options;

const categoryLabelsMap = Object.fromEntries(
  projectCategories.map(cat => [cat, getCategoryLabel(cat)])
);

// Prepare data for Alpine.js (embedded directly in x-data to avoid race conditions)
const projectsData = JSON.stringify(projectsWithImages.map((p, i) => ({
  index: i,
  category: p.categoryProject,
  isCompleted: p.isProjectCompleted === true,
  dateTimestamp: p.date.getTime()
})));
---

<BaseLayout title={pageContent?.data.title ?? "Projects"} description={pageContent?.data.seoDescription}>
  <PageHeroImage
    image={projectHeroImage}
    alt="BEARS student working on satellite project"
    title={pageContent?.data.title ?? "Projects"}
    subtitle={pageContent?.data.subtitle ?? ""}
  />

  <div
    id="what-we-build"
    class="container mx-auto px-4 pt-6 sm:px-6 sm:pt-8 lg:px-8 scroll-mt-20"
    x-data={`{
      filterMenuOpen: false,
      sortMenuOpen: false,
      activeCategory: [],
      completionStatus: [],
      sortOrder: 'newest',
      gridColumns: window.innerWidth >= 1280 ? 3 : window.innerWidth >= 1024 ? 2 : 1,
      itemsPerPage: window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3,
      visibleCount: window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3,
      projectsData: ${projectsData},
      visibleIndices: [],
      _fading: false,
      _fadeGen: 0,

      init() {
        const params = new URLSearchParams(window.location.search);

        // Parse and apply category filter
        const urlCategory = params.get('category');
        if (urlCategory) {
          const categories = urlCategory.split(',').filter(Boolean);
          this.activeCategory.push(...categories);
        }

        // Parse and apply status filter (completed/ongoing)
        const urlStatus = params.get('status');
        if (urlStatus) {
          const statuses = urlStatus.split(',').filter(Boolean);
          this.completionStatus.push(...statuses);
        }

        // Parse sort order
        if (params.get('sort') === 'oldest') {
          this.sortOrder = 'oldest';
        }

        // Update itemsPerPage and gridColumns on window resize
        window.addEventListener('resize', () => {
          const newItemsPerPage = window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3;
          const newGridColumns = window.innerWidth >= 1280 ? 3 : window.innerWidth >= 1024 ? 2 : 1;
          if (newItemsPerPage !== this.itemsPerPage || newGridColumns !== this.gridColumns) {
            this.itemsPerPage = newItemsPerPage;
            this.gridColumns = newGridColumns;
            const minVisible = this.getMinVisibleCount();
            if (this.visibleCount < minVisible) {
              this.visibleCount = minVisible;
              this.visibleIndices = [...this.displayedIndices];
            }
          }
        });

        // Ensure all important items are visible and rows are filled
        this.visibleCount = this.getMinVisibleCount();
        // Initialize display buffer
        this.visibleIndices = [...this.displayedIndices];

        // Watch for filter/sort changes
        this.$watch('filteredIndices', () => {
          this.visibleCount = this.getMinVisibleCount();
          this._animateGrid([...this.displayedIndices]);
        });
      },

      get hasActiveFilters() {
        return this.activeCategory.length > 0 || this.completionStatus.length > 0;
      },
      clearFilters() {
        this.activeCategory = [];
        this.completionStatus = [];
        this.visibleCount = this.getMinVisibleCount();
      },
      toggleFilter(array, value) {
        const idx = array.indexOf(value);
        if (idx === -1) {
          array.push(value);
        } else {
          array.splice(idx, 1);
        }
        this.visibleCount = this.getMinVisibleCount();
      },
      getMinVisibleCount() {
        const ongoingCount = this.filteredIndices.filter(i => !this.projectsData[i].isCompleted).length;
        const minCount = Math.max(this.itemsPerPage, ongoingCount);
        return Math.ceil(minCount / this.gridColumns) * this.gridColumns;
      },
      get filteredIndices() {
        const filtered = this.projectsData.reduce((acc, project) => {
          const categoryMatch = this.activeCategory.length === 0 || this.activeCategory.includes(project.category);
          const statusMatch = this.completionStatus.length === 0 ||
                             (this.completionStatus.includes('completed') && project.isCompleted) ||
                             (this.completionStatus.includes('ongoing') && !project.isCompleted);
          if (categoryMatch && statusMatch) {
            acc.push(project.index);
          }
          return acc;
        }, []);

        // Sort: ongoing first, then by date within each group
        filtered.sort((a, b) => {
          const projA = this.projectsData[a];
          const projB = this.projectsData[b];
          if (projA.isCompleted !== projB.isCompleted) {
            return projA.isCompleted ? 1 : -1;
          }
          return this.sortOrder === 'newest'
            ? projB.dateTimestamp - projA.dateTimestamp
            : projA.dateTimestamp - projB.dateTimestamp;
        });

        return filtered;
      },
      get displayedIndices() {
        return this.filteredIndices.slice(0, this.visibleCount);
      },
      get hasMore() {
        return this.visibleCount < this.filteredIndices.length;
      },
      get remainingCount() {
        return this.filteredIndices.length - Math.min(this.visibleCount, this.filteredIndices.length);
      },

      showMore() {
        const grid = this.$refs.grid;
        if (!grid) return;
        const prevHeight = grid.offsetHeight;
        grid.style.height = prevHeight + 'px';
        grid.style.overflow = 'hidden';

        const prevSet = new Set(this.visibleIndices);
        this.visibleCount = Math.min(this.visibleCount + this.itemsPerPage, this.filteredIndices.length);
        this.visibleIndices = [...this.displayedIndices];

        this.$nextTick(() => {
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            grid.style.height = '';
            grid.style.overflow = '';
            return;
          }

          grid.style.height = '';
          const newHeight = grid.offsetHeight;
          grid.style.height = prevHeight + 'px';
          void grid.offsetHeight;
          grid.style.transition = 'height 300ms ease-out';
          grid.style.height = newHeight + 'px';

          const newCards = [];
          grid.querySelectorAll(':scope > div:not(.hidden)').forEach(wrapper => {
            if (!prevSet.has(Number(wrapper.dataset.index))) {
              const card = wrapper.querySelector('.showcase-card');
              if (card) newCards.push(card);
            }
          });
          newCards.sort((a, b) => (parseInt(a.parentElement.style.order) || 0) - (parseInt(b.parentElement.style.order) || 0));
          newCards.forEach(card => { card.style.animation = 'none'; });
          void grid.offsetHeight;
          newCards.forEach((card, i) => {
            card.style.animation = '';
            card.style.animationDelay = i * 30 + 'ms';
          });

          setTimeout(() => {
            newCards.forEach(c => { c.style.animationDelay = ''; });
            grid.style.height = '';
            grid.style.overflow = '';
            grid.style.transition = '';
          }, Math.max(310, newCards.length * 30 + 300));
        });
      },

      _animateGrid(newIndices) {
        const grid = this.$refs.grid;

        if (!grid || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          this.visibleIndices = [...newIndices];
          this._fading = false;
          return;
        }

        const gen = ++this._fadeGen;
        this._fading = true;
        const prevHeight = grid.offsetHeight;

        // Phase 1: Fade grid out
        grid.style.transition = 'opacity 150ms ease-out';
        grid.style.opacity = '0';

        let fadedOut = false;
        const afterFadeOut = () => {
          if (fadedOut || gen !== this._fadeGen) return;
          fadedOut = true;

          // Lock at previous height during content swap
          grid.style.height = prevHeight + 'px';
          grid.style.overflow = 'hidden';
          this.visibleIndices = [...newIndices];

          this.$nextTick(() => {
            if (gen !== this._fadeGen) return;

            // Measure new natural height (invisible at opacity 0)
            grid.style.height = '';
            const newHeight = grid.offsetHeight;
            const heightChanged = Math.abs(prevHeight - newHeight) > 1;

            if (heightChanged) {
              grid.style.height = prevHeight + 'px';
              void grid.offsetHeight;
            }

            // Phase 2: Fade in + height animation (matched durations)
            grid.style.transition = heightChanged
              ? 'opacity 250ms ease-in, height 250ms ease-out'
              : 'opacity 200ms ease-in';
            grid.style.opacity = '1';
            if (heightChanged) {
              grid.style.height = newHeight + 'px';
            }

            setTimeout(() => {
              if (gen !== this._fadeGen) return;
              grid.style.transition = '';
              grid.style.opacity = '';
              grid.style.height = '';
              grid.style.overflow = '';
              this._fading = false;
            }, 300);
          });
        };
        grid.addEventListener('transitionend', afterFadeOut, { once: true });
        setTimeout(afterFadeOut, 200);
      }
    }`}
  >
    <!-- Category Overview -->
    <ProjectCategories
      categories={categoryDescriptions}
      subtitle={categoriesIntro?.data.subtitle}
      description={categoriesIntro?.data.description}
    >
      <SortMenu />
      <FilterMenu
        filterGroups={[
          {
            label: 'Category',
            stateVariable: 'activeCategory',
            categories: projectCategories,
            categoryLabels: categoryLabelsMap
          },
          {
            label: 'Status',
            stateVariable: 'completionStatus',
            categories: ['completed', 'ongoing'],
            categoryLabels: { completed: 'Completed', ongoing: 'Ongoing' }
          }
        ]}
      />
      <p
        slot="result-count"
        :class="{ 'invisible': filteredIndices.length === 0 }"
        class="text-sm text-bears-text-onDark/40"
        x-text="`Showing ${Math.min(visibleCount, filteredIndices.length)} of ${filteredIndices.length} projects`"
      ></p>
    </ProjectCategories>

    <!-- No results state -->
    <div
      x-show="filteredIndices.length === 0"
      x-cloak
      class="flex flex-col items-center justify-center min-h-80 text-center"
    >
      <svg class="w-12 h-12 text-bears-text-onDark/20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
      <p class="text-bears-text-onDark/50 text-lg mb-1">{emptyState?.data.title ?? "No projects match your filters"}</p>
      <p class="text-bears-text-onDark/30 text-sm mb-6">{emptyState?.data.description ?? "Try adjusting or clearing your filters"}</p>
      <button
        type="button"
        @click="clearFilters()"
        class="text-sm text-bears-accent hover:text-bears-accent/80 transition-colors cursor-pointer"
      >
        Clear all filters
      </button>
    </div>

    <!-- Projects Grid -->
    <div
      x-ref="grid"
      x-show="filteredIndices.length > 0"
      data-pagefind-ignore
      class="projects-grid grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8 content-start min-h-80"
    >
      {projectsWithImages.map((project, index) => (
        <div
          data-index={index}
          :class={`{ 'hidden': !visibleIndices.includes(${index}) }`}
          :style={`'order: ' + (visibleIndices.indexOf(${index}) !== -1 ? visibleIndices.indexOf(${index}) : 9999)`}
        >
          <PostShowcase
            coverImage={project.coverImage}
            imageAlt={project.title}
            date={project.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            title={project.title}
            description={project.description}
            href={`/projects/${project.slug}`}
            isCompleted={project.isProjectCompleted}
            category={getCategoryLabel(project.categoryProject)}
          />
        </div>
      ))}
    </div>

    <!-- Show More button -->
    <div
      x-cloak
      class="grid w-full overflow-hidden"
      :style="hasMore && !_fading
        ? 'transition: opacity 300ms ease-in, grid-template-rows 300ms ease-out, margin 300ms ease-out'
        : 'transition: opacity 100ms ease-out, grid-template-rows 100ms ease-out, margin 100ms ease-out'"
      :class="hasMore && !_fading
        ? 'grid-rows-[1fr] mt-8 sm:mt-10 lg:mt-12 opacity-100'
        : 'grid-rows-[0fr] mt-0 opacity-0'"
    >
      <div class="overflow-hidden flex justify-center">
        <button
          @click="showMore()"
          type="button"
          class="group flex items-center justify-center gap-2.5 px-6 py-3 rounded-lg border border-white/15 text-sm text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark transition-all duration-200 cursor-pointer"
        >
          <span>Show more</span>
          <span
            class="text-bears-text-onDark/40"
            x-text="`(${remainingCount} remaining)`"
          ></span>
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>
    </div>

    <CrosslinkBanner
      text={crosslink?.data.title ?? "Want to see what's happening?"}
      linkText={crosslink?.data.buttonText ?? "Check out our events"}
      href={crosslink?.data.buttonHref ?? "/events"}
    />
  </div>
</BaseLayout>
