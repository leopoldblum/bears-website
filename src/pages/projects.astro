---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import PostShowcase from "../components/PostShowcase.astro";
import { loadCollectionImages } from "../utils/imageLoader";

// Filter and sort projects
const allProjects = await getCollection("posts", ({ id, data }) => {
  return id.startsWith('projects/') && (import.meta.env.DEV || !data.isDraft);
});

const sortedProjects = allProjects.sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

// Load images for projects
const projectsWithLoadedImages = await loadCollectionImages(sortedProjects, 'project');

// Map to format expected by PostShowcase
const projectsWithImages = projectsWithLoadedImages.map((project) => ({
  ...project.data,
  slug: project.slug,
  coverImage: project.loadedImage,
}));
---

<BaseLayout title="Projects">
  <div class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 sm:mb-8 lg:mb-12 text-bears-accent">
      Projects
    </h1>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      {projectsWithImages.map((project) => (
        <PostShowcase
          coverImage={project.coverImage}
          imageAlt={project.title}
          date={project.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          title={project.title}
          description={project.description}
          href={`/projects/${project.slug.replace('projects/', '')}`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
