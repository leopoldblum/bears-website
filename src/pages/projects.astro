---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import NewsGridElement from "../components/NewsGridElement.astro";

// Filter and sort projects
const allProjects = await getCollection("posts", ({ id, data }) => {
  return id.startsWith('projects/') && (import.meta.env.DEV || !data.isDraft);
});

const sortedProjects = allProjects.sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

// Import and optimize images
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/projects/*.{jpg,jpeg,png,webp}");

const projectsWithImages = await Promise.all(
  sortedProjects.map(async (project) => {
    let optimizedImage;
    if (project.data.coverImage) {
      const imagePath = `/src/assets/projects/${project.data.coverImage}`;
      if (images[imagePath]) {
        const imageModule = await images[imagePath]();
        const optimized = await getImage({ src: imageModule.default, format: "webp" });
        optimizedImage = optimized.src;
      }
    }
    return { ...project.data, slug: project.slug, coverImage: optimizedImage };
  })
);
---

<BaseLayout title="Projects">
  <div class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 md:px-8">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 sm:mb-8 md:mb-12 text-bears-accent">
      Projects
    </h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {projectsWithImages.map((project) => (
        <NewsGridElement
          imageUrl={project.coverImage || "https://via.placeholder.com/600x400"}
          imageAlt={project.title}
          date={project.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          title={project.title}
          description={project.description}
          href={`/projects/${project.slug.replace('projects/', '')}`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
