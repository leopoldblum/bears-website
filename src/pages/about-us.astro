---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeroImage from "@reusable/PageHeroImage.astro";
import OurMission from "@components/about/OurMission.astro";
import FacesOfBears from "@components/about/FacesOfBears.astro";
import FindUs from "@components/about/FindUs.astro";
import { aboutHeroImages } from "@utils/imageGlobs";
import { loadAllImagesFromDirectory } from "@utils/imageLoader";
import { getPageContent } from "@utils/contentQueries";

const pageContent = await getPageContent('sub-pages/about-us');
const loadedHeroImages = await loadAllImagesFromDirectory(aboutHeroImages);
const aboutHeroImage = loadedHeroImages[0];
---

<BaseLayout title={pageContent?.data.title ?? "About Us"}>
  <PageHeroImage
    image={aboutHeroImage}
    alt="BEARS team working together on aerospace projects"
    title={pageContent?.data.title ?? "Who are we?"}
    subtitle={pageContent?.data.subtitle ?? ""}
  />

  <OurMission />

  <FacesOfBears />

  <FindUs />
</BaseLayout>
