---
import BaseLayout from "@layouts/BaseLayout.astro";
import LandingHero from "@landing/LandingHero.astro";
import WhatIsBears from "@landing/WhatIsBears.astro";
import MeetTheTeam from "@landing/MeetTheTeam.astro";
import BecomeSponsor from "@landing/BecomeSponsor.astro";
import LatestNews from "@landing/LatestNews.astro";
import Testimonials from "@landing/Testimonials.astro"

// HeroCTA data - displayed at the bottom of the hero section
const heroCTAs = [
  {
    title: "How to Join",
    description: "Becoming a member of Bears e.V.",
    href: "/about-us",
  },
  {
    title: "Our Projects",
    description: "Explore what we are working on",
    href: "/projects",
  },
  {
    title: "Events",
    description: "Upcoming workshops and meetups",
    href: "/events",
  },
];
---

<BaseLayout title="Home">
  <LandingHero ctas={heroCTAs} />
  <WhatIsBears />
  <MeetTheTeam />
  <BecomeSponsor />
  <LatestNews />
  <Testimonials />
</BaseLayout>
