---
import LandingPage from "@landing/LandingPage.astro";
import AdminDashboard from "@components/admin/AdminDashboard.astro";
import { getLocale } from "@utils/i18n";

export const prerender = true;

const ADMIN_BUILD = import.meta.env.ADMIN_BUILD === true;
const locale = getLocale(Astro.url);
---

{ADMIN_BUILD ? <AdminDashboard /> : <LandingPage locale={locale} />}
