---
import BaseLayout from "@layouts/BaseLayout.astro";
import LandingHero from "@landing/LandingHero.astro";
import WhatIsBears from "@landing/WhatIsBears.astro";
import MeetTheTeam from "@landing/MeetTheTeam.astro";
import BecomeSponsor from "@landing/BecomeSponsor.astro";
import LatestNews from "@landing/LatestNews.astro";
import Testimonials from "@landing/Testimonials.astro"
import { getPageContent } from "@utils/contentQueries";

// Fetch hero CTAs from content collection
const heroContent = await getPageContent('landing/hero');
const heroCTAs = heroContent?.data.ctas ?? [];
const heroTagline = heroContent?.data.subtitle;
---

<BaseLayout title="Home">
  <LandingHero ctas={heroCTAs} tagline={heroTagline} />
  <WhatIsBears />
  <MeetTheTeam />
  <BecomeSponsor />
  <LatestNews />
  <Testimonials />
</BaseLayout>
