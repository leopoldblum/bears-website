---
import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import LandingHero from "@landing/LandingHero.astro";
import WhatIsBears from "@landing/WhatIsBears.astro";
import MeetTheTeam from "@landing/MeetTheTeam.astro";
import BecomeSponsor from "@landing/BecomeSponsor.astro";
import LatestNews from "@landing/LatestNews.astro";
import Testimonials from "@landing/Testimonials.astro"
import { getPageContent } from "@utils/contentQueries";
import { getLocale, localizeUrl } from "@utils/i18n";

export const prerender = true;

const locale = getLocale(Astro.url);

// Fetch hero CTAs from content collection
const heroContent = await getPageContent('hero', locale);
const heroCTAs = (heroContent?.data.ctas ?? []).map(cta => ({
  ...cta,
  href: localizeUrl(cta.href, locale),
}));

const visibility = (await getEntry('landing-section-visibility', 'settings'))!.data;
---

<BaseLayout title={locale === 'de' ? 'Startseite' : 'Home'} description={heroContent?.data.seoDescription}>
  {visibility.showHero && <LandingHero ctas={heroCTAs} locale={locale} />}
  {visibility.showWhatIsBears && <WhatIsBears locale={locale} />}
  {visibility.showMeetTheTeam && <MeetTheTeam locale={locale} />}
  {visibility.showBecomeSponsor && <BecomeSponsor locale={locale} />}
  {visibility.showLatestNews && <LatestNews locale={locale} />}
  {visibility.showTestimonials && <Testimonials locale={locale} />}
</BaseLayout>
