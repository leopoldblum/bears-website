---
// Media Page - Displays all media organized by category in accordion format
// Categories are configured via the page-text content collection (media-title.mdx)

import BaseLayout from "@layouts/BaseLayout.astro";
import MediaAccordion from "../components/reusable/MediaAccordion.astro";
import PageHeroImage from "../components/reusable/PageHeroImage.astro";
import { loadAllImagesFromDirectory } from "@utils/imageLoader";
import type { ImageMetadata } from "astro";
import {
  mediaHeroImages,
  eventImages,
  projectImages,
  testimonialImages,
  whatIsBearsImages,
  ourMissionImages,
  peopleImages,
  allHeroImages,
} from "@utils/imageGlobs";
import type { ImageGlob } from "@utils/imageGlobs";
import { getPageContent } from "@utils/contentQueries";
import { getLocale, mediaUiStrings } from "@utils/i18n";

const locale = getLocale(Astro.url);
const pageContent = await getPageContent('media-categories', locale);
const loadedHeroImages = await loadAllImagesFromDirectory(mediaHeroImages);
const heroImage = loadedHeroImages[0];

// Static mapping from content id → image glob
// To add a new media category, add a glob to imageGlobs.ts and map it here
const globById: Record<string, ImageGlob> = {
  'about-us': ourMissionImages,
  'events': eventImages,
  'people': peopleImages,
  'hero': allHeroImages,
  'projects': projectImages,
  'testimonials': testimonialImages,
  'what-is-bears': whatIsBearsImages,
};

// Read categories from content file (order and visibility controlled by content creators)
const contentCategories = pageContent?.data.mediaCategories ?? [];

// First pass: load all non-"all" categories
const loadedCategories = await Promise.all(
  contentCategories
    .filter((cat: { id: string }) => cat.id !== 'all' && globById[cat.id])
    .map(async (cat: { id: string; label: string }) => {
      const images = await loadAllImagesFromDirectory(globById[cat.id]);
      return { id: cat.id, label: cat.label, images };
    }),
);

// Filter out empty categories
const categoriesWithImages = loadedCategories.filter((cat) => cat.images.length > 0);

// Second pass: build the "all" entry if requested
const allEntry = contentCategories.find((cat: { id: string }) => cat.id === 'all');
const allImages = allEntry
  ? categoriesWithImages.flatMap((cat) => cat.images)
  : [];

// Build final display list in content-defined order
const displayCategories: { label: string; images: ImageMetadata[] }[] = [];
for (const cat of contentCategories) {
  if (cat.id === 'all') {
    if (allImages.length > 0) {
      displayCategories.push({ label: allEntry!.label, images: allImages });
    }
  } else {
    const loaded = categoriesWithImages.find((c) => c.id === cat.id);
    if (loaded) {
      displayCategories.push({ label: loaded.label, images: loaded.images });
    }
  }
}
---

<BaseLayout title={pageContent?.data.title ?? "Media"} description={pageContent?.data.seoDescription}>
  <PageHeroImage
    image={heroImage}
    alt="BEARS event showcasing student astronautics activities"
    title={pageContent?.data.title ?? "Media"}
    subtitle={pageContent?.data.subtitle ?? ""}
  />
  <div class="container mx-auto px-4 py-6 sm:py-8 lg:py-12 sm:px-8 lg:px-16">
    {/* Media Categories Accordion */}
    <div class="flex flex-col gap-6 sm:gap-20">
      {
        displayCategories.map((category) => (
          <MediaAccordion
            title={category.label}
            images={category.images}
            cols={4}
            gap="md"
            locale={locale}
          />
        ))
      }
    </div>

    {/* Empty State */}
    {
      displayCategories.length === 0 && (
        <div class="text-center py-16 sm:py-20">
          <svg
            class="w-16 h-16 mx-auto mb-4 text-bears-text-onDark/30"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
          <p class="text-lg text-bears-text-onDark/60">
            {mediaUiStrings[locale]['no-media']}
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>
