---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostShowcase from "@posts-catalog/PostShowcase.astro";
import FilterMenu from "@posts-catalog/FilterMenu.astro";
import SortMenu from "@posts-catalog/SortMenu.astro";

import PageHeroImage from "@reusable/PageHeroImage.astro";
import EventsIntro from "@components/events/EventsIntro.astro";
import { loadCollectionImages } from "@utils/imageLoader";
import { getPublishedEvents, getPageContent } from "@utils/contentQueries";
import { CategoryEventEnum } from "@types";
import { getCategoryLabel } from "@utils/categoryLabels";
import CrosslinkBanner from "@reusable/CrosslinkBanner.astro";
import { eventsHeroImages } from "@utils/imageGlobs";
import { loadAllImagesFromDirectory } from "@utils/imageLoader";

const pageContent = await getPageContent('events/events-title');
const eventsIntro = await getPageContent('events/events-intro');
const loadedHeroImages = await loadAllImagesFromDirectory(eventsHeroImages);
const eventHeroImage = loadedHeroImages[0];

// Get all published events (filtered and sorted)
const sortedEvents = await getPublishedEvents();

// Load images for events
const eventsWithLoadedImages = await loadCollectionImages(sortedEvents, 'event');

// Map to format expected by PostShowcase
const eventsWithImages = eventsWithLoadedImages.map((event) => ({
  ...event.data,
  slug: event.slug,
  coverImage: event.loadedImage,
}));

// Lightweight events array for the "Next Up" callout (Alpine.js picks the right one client-side)
const eventsForCallout = eventsWithImages.map(e => ({
  title: e.title,
  date: e.date.getTime(),
  slug: e.slug,
}));

// Get category options from enum and build labels map
const eventCategories = CategoryEventEnum.options;
const categoryLabelsMap = Object.fromEntries(
  eventCategories.map(cat => [cat, getCategoryLabel(cat)])
);

// Prepare data for Alpine.js (embedded directly in x-data to avoid race conditions)
const eventsData = JSON.stringify(eventsWithImages.map((e, i) => ({
  index: i,
  category: e.categoryEvent,
  dateTimestamp: e.date.getTime()
})));
---

<BaseLayout title={pageContent?.data.title ?? "Events"}>
  <PageHeroImage
    image={eventHeroImage}
    alt="BEARS members collaborating at a workshop event"
    title={pageContent?.data.title ?? "Events"}
    subtitle={pageContent?.data.subtitle ?? ""}
  />

  <div
    class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 lg:px-8"
    x-data={`{
      filterMenuOpen: false,
      sortMenuOpen: false,
      activeCategory: [],
      dateFilter: [],
      sortOrder: 'newest',
      now: new Date().setHours(0,0,0,0),
      gridColumns: window.innerWidth >= 1280 ? 3 : window.innerWidth >= 1024 ? 2 : 1,
      itemsPerPage: window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3,
      visibleCount: window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3,
      eventsData: ${eventsData},
      visibleIndices: [],
      _transitioning: false,
      _pendingIndices: null,
      _lastFilteredKey: '',

      init() {
        const params = new URLSearchParams(window.location.search);

        // Parse and apply category filter
        const urlCategory = params.get('category');
        if (urlCategory) {
          const categories = urlCategory.split(',').filter(Boolean);
          this.activeCategory.push(...categories);
        }

        // Parse and apply date filter
        const urlDate = params.get('date');
        if (urlDate) {
          const dates = urlDate.split(',').filter(Boolean);
          this.dateFilter.push(...dates);
        }

        // Parse sort order
        if (params.get('sort') === 'oldest') {
          this.sortOrder = 'oldest';
        }

        // Update itemsPerPage and gridColumns on window resize
        window.addEventListener('resize', () => {
          const newItemsPerPage = window.innerWidth >= 1280 ? 6 : window.innerWidth >= 1024 ? 4 : 3;
          const newGridColumns = window.innerWidth >= 1280 ? 3 : window.innerWidth >= 1024 ? 2 : 1;
          if (newItemsPerPage !== this.itemsPerPage || newGridColumns !== this.gridColumns) {
            this.itemsPerPage = newItemsPerPage;
            this.gridColumns = newGridColumns;
            const minVisible = this.getMinVisibleCount();
            if (this.visibleCount < minVisible) {
              this.visibleCount = minVisible;
              this.visibleIndices = [...this.displayedIndices];
            }
          }
        });

        // Ensure all important items are visible and rows are filled
        this.visibleCount = this.getMinVisibleCount();
        // Initialize display buffer
        this.visibleIndices = [...this.displayedIndices];
        this._lastFilteredKey = JSON.stringify(this.filteredIndices);

        // Watch for filter/sort changes (reset view with full animation)
        this.$watch('filteredIndices', (newVal) => {
          const newKey = JSON.stringify(newVal);
          if (newKey !== this._lastFilteredKey) {
            this._lastFilteredKey = newKey;
            this.visibleCount = this.getMinVisibleCount();
            this._animateGrid([...this.displayedIndices]);
          }
        });
      },

      get hasActiveFilters() {
        return this.activeCategory.length > 0 || this.dateFilter.length > 0;
      },
      clearFilters() {
        this.activeCategory = [];
        this.dateFilter = [];
        this.visibleCount = this.getMinVisibleCount();
      },
      toggleFilter(array, value) {
        const idx = array.indexOf(value);
        if (idx === -1) {
          array.push(value);
        } else {
          array.splice(idx, 1);
        }
        this.visibleCount = this.getMinVisibleCount();
      },
      getMinVisibleCount() {
        const upcomingCount = this.filteredIndices.filter(i => this.eventsData[i].dateTimestamp >= this.now).length;
        const minCount = Math.max(this.itemsPerPage, upcomingCount);
        return Math.ceil(minCount / this.gridColumns) * this.gridColumns;
      },
      get filteredIndices() {
        const filtered = this.eventsData.reduce((acc, event) => {
          const categoryMatch = this.activeCategory.length === 0 || this.activeCategory.includes(event.category);
          const dateMatch = this.dateFilter.length === 0 ||
                           (this.dateFilter.includes('upcoming') && event.dateTimestamp >= this.now) ||
                           (this.dateFilter.includes('past') && event.dateTimestamp < this.now);
          if (categoryMatch && dateMatch) {
            acc.push(event.index);
          }
          return acc;
        }, []);

        // Sort: upcoming first, then by date within each group
        filtered.sort((a, b) => {
          const eventA = this.eventsData[a];
          const eventB = this.eventsData[b];
          const aIsUpcoming = eventA.dateTimestamp >= this.now;
          const bIsUpcoming = eventB.dateTimestamp >= this.now;
          if (aIsUpcoming !== bIsUpcoming) {
            return aIsUpcoming ? -1 : 1;
          }
          return this.sortOrder === 'newest'
            ? eventB.dateTimestamp - eventA.dateTimestamp
            : eventA.dateTimestamp - eventB.dateTimestamp;
        });

        return filtered;
      },
      get displayedIndices() {
        return this.filteredIndices.slice(0, this.visibleCount);
      },
      get hasMore() {
        return this.visibleCount < this.filteredIndices.length;
      },
      get remainingCount() {
        return this.filteredIndices.length - Math.min(this.visibleCount, this.filteredIndices.length);
      },

      showMore() {
        const prevSet = new Set(this.visibleIndices);
        this.visibleCount = Math.min(this.visibleCount + this.itemsPerPage, this.filteredIndices.length);
        this.visibleIndices = [...this.displayedIndices];

        this.$nextTick(() => {
          const grid = this.$refs.grid;
          if (!grid || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          const newCards = [];
          grid.querySelectorAll(':scope > div:not(.hidden)').forEach(wrapper => {
            if (!prevSet.has(Number(wrapper.dataset.index))) {
              const card = wrapper.querySelector('.showcase-card');
              if (card) newCards.push(card);
            }
          });
          newCards.sort((a, b) => {
            const orderA = parseInt(a.parentElement.style.order) || 0;
            const orderB = parseInt(b.parentElement.style.order) || 0;
            return orderA - orderB;
          });
          newCards.forEach((card, i) => {
            card.style.animation = 'none';
            void card.offsetHeight;
            card.style.animation = '';
            card.style.animationDelay = i * 50 + 'ms';
          });
          setTimeout(() => {
            newCards.forEach(c => { c.style.animationDelay = ''; });
          }, newCards.length * 50 + 450);
        });
      },

      async _animateGrid(newIndices) {
        if (this._transitioning) {
          this._pendingIndices = [...newIndices];
          return;
        }
        this._transitioning = true;
        const grid = this.$refs.grid;

        if (!grid || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          this.visibleIndices = [...newIndices];
          this._transitioning = false;
          return;
        }

        // Exit: fade out grid (skip if coming from empty state)
        if (this.visibleIndices.length > 0) {
          grid.style.transition = 'opacity 150ms ease-out, transform 150ms ease-out';
          grid.style.opacity = '0';
          grid.style.transform = 'translateY(6px)';
          await new Promise(r => setTimeout(r, 160));
        }

        // Swap: update display buffer while grid is invisible
        this.visibleIndices = [...newIndices];
        await this.$nextTick();

        // Re-trigger card entrance animations with dynamic stagger
        const visibleCards = grid.querySelectorAll(':scope > div:not(.hidden) .showcase-card');
        visibleCards.forEach((card) => {
          card.style.animation = 'none';
          card.style.animationDelay = '';
        });
        void grid.offsetHeight;
        visibleCards.forEach((card, i) => {
          card.style.animation = '';
          card.style.animationDelay = i * 50 + 'ms';
        });

        // Enter: snap grid visible, cards animate individually
        grid.style.transition = 'none';
        grid.style.opacity = '1';
        grid.style.transform = '';

        // Cleanup after card animations complete
        const maxDelay = visibleCards.length * 50;
        setTimeout(() => {
          visibleCards.forEach((card) => { card.style.animationDelay = ''; });
          grid.style.transition = '';
          this._transitioning = false;

          if (this._pendingIndices) {
            const pending = this._pendingIndices;
            this._pendingIndices = null;
            this._animateGrid(pending);
          }
        }, maxDelay + 450);
      }
    }`}
  >
    <EventsIntro
      subtitle={eventsIntro?.data.subtitle}
      description={eventsIntro?.data.description}
      events={eventsForCallout}
    >
      <SortMenu />
      <FilterMenu
        filterGroups={[
          {
            label: 'Category',
            stateVariable: 'activeCategory',
            categories: eventCategories,
            categoryLabels: categoryLabelsMap
          },
          {
            label: 'Date',
            stateVariable: 'dateFilter',
            categories: ['upcoming', 'past'],
            categoryLabels: { upcoming: 'Upcoming', past: 'Past' }
          }
        ]}
      />
    </EventsIntro>

    <!-- Result count -->
    <p
      :class="{ 'invisible': filteredIndices.length === 0 }"
      class="text-sm text-bears-text-onDark/40 text-right mb-4"
      x-text="`Showing ${Math.min(visibleCount, filteredIndices.length)} of ${filteredIndices.length} events`"
    ></p>

    <!-- No results state -->
    <div
      x-show="filteredIndices.length === 0"
      x-cloak
      class="flex flex-col items-center justify-center min-h-80 text-center"
    >
      <svg class="w-12 h-12 text-bears-text-onDark/20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
      <p class="text-bears-text-onDark/50 text-lg mb-1">No events match your filters</p>
      <p class="text-bears-text-onDark/30 text-sm mb-6">Try adjusting or clearing your filters</p>
      <button
        type="button"
        @click="clearFilters()"
        class="text-sm text-bears-accent hover:text-bears-accent/80 transition-colors cursor-pointer"
      >
        Clear all filters
      </button>
    </div>

    <!-- Events Grid -->
    <div
      x-ref="grid"
      x-show="filteredIndices.length > 0"
      class="events-grid grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8 content-start min-h-80"
    >
      {eventsWithImages.map((event, index) => (
        <div
          data-index={index}
          :class={`{ 'hidden': !visibleIndices.includes(${index}) }`}
          :style={`'order: ' + (visibleIndices.indexOf(${index}) !== -1 ? visibleIndices.indexOf(${index}) : 9999)`}
        >
          <PostShowcase
            coverImage={event.coverImage}
            imageAlt={event.title}
            date={event.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            title={event.title}
            description={event.description}
            href={`/events/${event.slug}`}
            isUpcoming={event.date.getTime() >= new Date().setHours(0, 0, 0, 0)}
            category={getCategoryLabel(event.categoryEvent)}
          />
        </div>
      ))}
    </div>

    <!-- Show More button -->
    <div class="w-full mt-8 sm:mt-10 lg:mt-12 flex justify-center">
      <button
        x-show="hasMore"
        @click="showMore()"
        type="button"
        class="group flex items-center justify-center gap-2.5 px-6 py-3 rounded-lg border border-white/15 text-sm text-bears-text-onDark/80 hover:border-bears-accent/50 hover:text-bears-text-onDark transition-all duration-200 cursor-pointer"
      >
        <span>Show more</span>
        <span
          class="text-bears-text-onDark/40"
          x-text="`(${remainingCount} remaining)`"
        ></span>
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>

    <CrosslinkBanner
      text="Curious what we're building?"
      linkText="Explore our projects"
      href="/projects"
    />
  </div>
</BaseLayout>
