---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import NewsGridElement from "../components/NewsGridElement.astro";
import type { ImageMetadata } from 'astro';

// Import component-specific default placeholder image
import defaultEventImage from "../assets/default-images/default-event.jpg";

// Filter and sort events
const allEvents = await getCollection("posts", ({ id, data }) => {
  return id.startsWith('events/') && (import.meta.env.DEV || !data.isDraft);
});

const sortedEvents = allEvents.sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

// Import images
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/events/*.{jpg,jpeg,png,webp}");

const eventsWithImages = await Promise.all(
  sortedEvents.map(async (event) => {
    // Start with default image
    let imageData: ImageMetadata = defaultEventImage;
    let imageLoadFailed = false;

    // Try to load custom image if specified
    if (event.data.coverImageType === "CUSTOM" && event.data.coverImage) {
      const imagePath = `/src/assets/events/${event.data.coverImage}`;

      if (images[imagePath]) {
        try {
          const imageModule = await images[imagePath]();
          imageData = imageModule.default;
        } catch (error) {
          imageLoadFailed = true;
        }
      } else {
        imageLoadFailed = true;
      }
    }

    // Development warnings
    if (import.meta.env.DEV) {
      if (event.data.coverImageType === "DEFAULT") {
        console.warn(
          `⚠️  Event "${event.data.title}" (${event.slug}) is using DEFAULT cover image`
        );
      } else if (imageLoadFailed) {
        console.warn(
          `⚠️  Event "${event.data.title}" (${event.slug}) - image "${event.data.coverImage}" failed to load, using default`
        );
      }
    }

    return { ...event.data, slug: event.slug, coverImage: imageData };
  })
);
---

<BaseLayout title="Events">
  <div class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 md:px-8">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 sm:mb-8 md:mb-12 text-bears-accent">
      Events
    </h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {eventsWithImages.map((event) => (
        <NewsGridElement
          imageData={event.coverImage}
          imageAlt={event.title}
          date={event.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          title={event.title}
          description={event.description}
          href={`/events/${event.slug.replace('events/', '')}`}
          postType="events"
        />
      ))}
    </div>
  </div>
</BaseLayout>
