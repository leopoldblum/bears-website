---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import PostShowcase from "../components/PostShowcase.astro";
import type { ImageMetadata } from 'astro';
import { loadImagesForCollection } from "../utils/imageLoader";

// Filter and sort events
const allEvents = await getCollection("posts", ({ id, data }) => {
  return id.startsWith('events/') && (import.meta.env.DEV || !data.isDraft);
});

const sortedEvents = allEvents.sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

// Load images for events
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/events/*.{jpg,jpeg,png,webp}");
const eventsWithLoadedImages = await loadImagesForCollection({
  glob: images,
  collection: sortedEvents,
  baseDir: '/src/assets/events',
  imageField: 'coverImage',
  postType: 'event',
});

// Map to format expected by PostShowcase
const eventsWithImages = eventsWithLoadedImages.map((event) => ({
  ...event.data,
  slug: event.slug,
  coverImage: event.loadedImage,
}));
---

<BaseLayout title="Events">
  <div class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 sm:mb-8 lg:mb-12 text-bears-accent">
      Events
    </h1>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      {eventsWithImages.map((event) => (
        <PostShowcase
          coverImage={event.coverImage}
          imageAlt={event.title}
          date={event.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          title={event.title}
          description={event.description}
          href={`/events/${event.slug.replace('events/', '')}`}
          postType="events"
        />
      ))}
    </div>
  </div>
</BaseLayout>
