---
import PostLayout from "@layouts/PostLayout.astro";
import { type CollectionEntry, getEntry } from "astro:content";
import { loadCoverImage } from "@utils/imageLoader";
import { getPublishedProjects, stripLocaleFromSlug } from "@utils/contentQueries";
import { getLocale } from "@utils/i18n";
import * as mdxComponents from "@mdx";

export const prerender = import.meta.env.ADMIN_BUILD !== true;


export async function getStaticPaths() {
  const allProjects = await getPublishedProjects();

  return allProjects.map(entry => ({
    params: { slug: stripLocaleFromSlug(entry.slug) },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry: defaultEntry } = Astro.props;
const locale = getLocale(Astro.url);

// For non-default locale, try to find the locale-specific entry
let entry = defaultEntry;
if (locale !== 'en') {
  const localeProjects = await getPublishedProjects(locale);
  const bareSlug = stripLocaleFromSlug(defaultEntry.slug);
  const localeEntry = localeProjects.find(e => stripLocaleFromSlug(e.slug) === bareSlug);
  if (localeEntry) entry = localeEntry;
}

const { Content } = await entry.render();

// Load cover image
const coverImageData = await loadCoverImage(
  entry.data.coverImage,
  'project',
  { itemTitle: entry.data.title, itemSlug: entry.slug }
);

// Resolve the optional person reference. Project Lead label on the metadata
// card is sourced from the People collection so the same person record can be
// edited in one place and reflected wherever they're referenced.
const personRef = entry.data.person;
let headOfProject: string | undefined;
if (personRef) {
  const personSlug = typeof personRef === 'string' ? personRef : personRef.id;
  const personEntry = await getEntry('people', personSlug);
  headOfProject = personEntry?.data.name;
}

const { title, date, categoryProject, isProjectCompleted } = entry.data;
---

<PostLayout
  title={title}
  description={entry.data.description}
  slug={entry.slug}
  date={date}
  coverImage={coverImageData}
  category={categoryProject}
  isCompleted={isProjectCompleted}
  headOfProject={headOfProject}
  type="project"
>
  <Content components={mdxComponents} />
</PostLayout>
