---
import PostLayout from "@layouts/PostLayout.astro";
import { type CollectionEntry } from "astro:content";
import { loadCoverImage } from "@utils/imageLoader";
import { getPublishedProjects, stripLocaleFromSlug } from "@utils/contentQueries";
import { getLocale } from "@utils/i18n";


export async function getStaticPaths() {
  const allProjects = await getPublishedProjects();

  return allProjects.map(entry => ({
    params: { slug: stripLocaleFromSlug(entry.slug) },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry: defaultEntry } = Astro.props;
const locale = getLocale(Astro.url);

// For non-default locale, try to find the locale-specific entry
let entry = defaultEntry;
if (locale !== 'en') {
  const localeProjects = await getPublishedProjects(locale);
  const bareSlug = stripLocaleFromSlug(defaultEntry.slug);
  const localeEntry = localeProjects.find(e => stripLocaleFromSlug(e.slug) === bareSlug);
  if (localeEntry) entry = localeEntry;
}

const { Content } = await entry.render();

// Load cover image
const coverImageData = await loadCoverImage(
  entry.data.coverImage,
  'project',
  { itemTitle: entry.data.title, itemSlug: entry.slug }
);

// Extract data for template use
const { title, date, categoryProject, isProjectCompleted, headOfProject } = entry.data;
---

<PostLayout
  title={title}
  description={entry.data.description}
  slug={entry.slug}
  date={date}
  coverImage={coverImageData}
  category={categoryProject}
  isCompleted={isProjectCompleted}
  headOfProject={headOfProject}
  type="project"
>
  <Content />
</PostLayout>
