---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { loadCoverImage } from "../../utils/imageLoader";
import { getPublishedProjects } from "../../utils/contentQueries";


export async function getStaticPaths() {
  const allProjects = await getPublishedProjects();

  return allProjects.map(entry => ({
    params: { slug: entry.slug.replace('projects/', '') },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Load cover image
const coverImageData = await loadCoverImage(
  entry.data.coverImage,
  'project',
  { itemTitle: entry.data.title, itemSlug: entry.slug }
);
---

<BaseLayout title={entry.data.title}>
  <article class="container mx-auto px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <!-- Cover Image -->
    {coverImageData && (
      <div class="mb-6 sm:mb-8 rounded-lg overflow-hidden">
        <Image
          src={coverImageData}
          alt={entry.data.title}
          class="w-full h-48 sm:h-64 lg:h-96 object-cover"
          loading="eager"
          format="webp"
        />
      </div>
    )}

    <!-- Title and Date -->
    <header class="mb-6 sm:mb-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-3 sm:mb-4 text-bears-accent">
        {entry.data.title}
      </h1>
      <time class="text-sm sm:text-base text-bears-text-onDark/80">
        {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>

    <!-- Content -->
    <div class="prose prose-invert prose-lg max-w-none
                prose-headings:text-bears-text-onDark
                prose-p:text-bears-text-onDark/90
                prose-a:text-bears-accent prose-a:no-underline hover:prose-a:underline
                prose-strong:text-bears-text-onDark
                prose-ul:text-bears-text-onDark/90
                prose-ol:text-bears-text-onDark/90">
      <Content />
    </div>
  </article>
</BaseLayout>
