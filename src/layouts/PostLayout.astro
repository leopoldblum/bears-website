---
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ReadingProgress from "@post/ReadingProgress.astro";
import MetadataCard from "@post/MetadataCard.astro";
import { getLocale } from "@utils/i18n";

interface Props {
  title: string;
  description: string;
  slug: string;
  date: Date;
  coverImage?: ImageMetadata;
  category: string;
  isCompleted?: boolean;
  headOfProject?: string;
  type: "event" | "project";
}

const {
  title,
  description,
  slug,
  date,
  coverImage,
  category,
  isCompleted,
  headOfProject,
  type,
} = Astro.props;

const locale = getLocale(Astro.url);
const siteOrigin = Astro.site!.origin;
const pageUrl = `${siteOrigin}/${type === "event" ? "events" : "projects"}/${slug}`;
const imageUrl = coverImage ? `${siteOrigin}${coverImage.src}` : undefined;

const structuredData = type === "event"
  ? {
      "@context": "https://schema.org",
      "@type": "Event",
      name: title,
      description,
      startDate: date.toISOString(),
      url: pageUrl,
      ...(imageUrl && { image: imageUrl }),
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: {
        "@type": "Place",
        name: "TU Berlin",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Berlin",
          addressCountry: "DE",
        },
      },
      organizer: {
        "@type": "Organization",
        name: "BEARS e.V.",
        url: siteOrigin,
      },
    }
  : {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      description,
      datePublished: date.toISOString(),
      url: pageUrl,
      ...(imageUrl && { image: imageUrl }),
      author: {
        "@type": "Organization",
        name: "BEARS e.V.",
        url: siteOrigin,
      },
    };
---

<BaseLayout title={title}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <ReadingProgress />

  <article class="post-container">
    <div class="post-inner">
      <!-- Cover Image -->
      {
        coverImage && (
          <div class="cover-image-wrapper">
            <Image
              src={coverImage}
              alt={title}
              class="cover-image"
              loading="eager"
            />
          </div>
        )
      }

      <!-- Header -->
      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="header-divider"></div>
      </header>

      <!-- Content Layout: Prose + Metadata Sidebar -->
      <div class="content-layout">
        <div class="prose-content">
          <slot />
        </div>
        <aside class="metadata-sidebar">
          <MetadataCard
            title={title}
            category={category}
            date={date}
            isCompleted={isCompleted}
            headOfProject={headOfProject}
            type={type}
            locale={locale}
          />
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-container {
    width: 100%;
    padding: 1.5rem 0.75rem;
  }

  .post-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Cover Image */
  .cover-image-wrapper {
    margin-bottom: 2rem;
    max-width: min(132ch, 100%);
    margin-left: auto;
    margin-right: auto;
  }

  .cover-image {
    display: block;
    max-height: 50vh;
    width: auto;
    height: auto;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  /* Header */
  .post-header {
    margin-bottom: 2rem;
    max-width: min(132ch, 100%);
    margin-left: auto;
    margin-right: auto;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-bears-text-onDark);
    margin: 0 0 1rem 0;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial,
      sans-serif;
  }

  .header-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
    margin-top: 1.5rem;
  }

  /* Content Layout: Two-column on desktop */
  .content-layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: min(132ch, 100%);
    margin-left: auto;
    margin-right: auto;
  }

  /* Metadata Sidebar */
  .metadata-sidebar {
    width: 100%;
    order: -1; /* Show above content on mobile */
  }

  /* Prose Content */
  .prose-content {
    /* Enhanced prose styling with refined typography */
    color: var(--color-bears-text-onDark);
    font-size: 1.0625rem;
    line-height: 1.75;
    width: 100%;
  }

  /* Typography Enhancements */
  .prose-content :global(h2) {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-bears-text-onDark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-content :global(h3) {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-bears-text-onDark);
    margin-top: 2rem;
    margin-bottom: 0.875rem;
  }

  .prose-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-bears-text-onDark);
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .prose-content :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
  }

  .prose-content :global(a:not(.not-prose)) {
    color: var(--color-bears-accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .prose-content :global(a:not(.not-prose):hover) {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Lists */
  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.75rem;
  }

  .prose-content :global(li) {
    margin-bottom: 0.625rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    line-height: 1.7;
  }

  .prose-content :global(ul > li) {
    list-style-type: disc;
  }

  .prose-content :global(ul > li::marker) {
    color: var(--color-bears-accent);
  }

  .prose-content :global(ol > li) {
    list-style-type: decimal;
  }

  .prose-content :global(ol > li::marker) {
    color: var(--color-bears-accent);
  }

  /* Blockquotes */
  .prose-content :global(blockquote) {
    margin: 1.75rem 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--color-bears-accent);
    background-color: rgba(255, 255, 255, 0.03);
    border-radius: 0 6px 6px 0;
  }

  .prose-content :global(blockquote p) {
    color: var(--color-bears-text-onDark);
    opacity: 0.85;
    font-style: italic;
  }

  /* Code */
  .prose-content :global(code) {
    background-color: rgba(255, 255, 255, 0.08);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--color-bears-text-onDark);
    font-family: "Monaco", "Consolas", monospace;
  }

  .prose-content :global(pre) {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Strong/Bold */
  .prose-content :global(strong) {
    font-weight: 600;
    color: var(--color-bears-text-onDark);
  }

  /* Horizontal Rule / Divider */
  .prose-content :global(hr) {
    margin: 2.5rem 0;
    border: none;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
  }

  /* Prevent child elements from causing overflow */
  /* Exclude images inside .not-prose containers */
  .prose-content :global(img:not(.not-prose img)) {
    max-width: 100%;
    height: auto;
  }

  .prose-content :global(pre) {
    max-width: 100%;
  }

  .prose-content :global(table) {
    max-width: 100%;
    overflow-x: auto;
    display: block;
  }

  /* Responsive: Tablet */
  @media (min-width: 640px) {
    .post-container {
      padding: 3rem 1.5rem;
    }

    .cover-image-wrapper {
      margin-bottom: 2.5rem;
    }

    .post-header {
      margin-bottom: 2.5rem;
    }
  }

  /* Responsive: Desktop */
  @media (min-width: 1024px) {
    .post-container {
      padding: 4rem 2rem;
    }

    .cover-image-wrapper {
      margin-bottom: 3rem;
    }

    .post-header {
      margin-bottom: 3rem;
    }

    .content-layout {
      flex-direction: row;
      gap: 3rem;
      align-items: flex-start;
    }

    .prose-content {
      flex: 1;
      min-width: 0; /* Prevent flex child overflow */
      font-size: 1.125rem;
    }

    .metadata-sidebar {
      width: 280px;
      flex-shrink: 0;
      order: 1; /* Show on right side on desktop */
      align-self: stretch; /* Stretch to full height so sticky works inside */
    }
  }

  /* Responsive: Large Desktop */
  @media (min-width: 1280px) {
    .content-layout {
      gap: 4rem;
    }

    .metadata-sidebar {
      width: 300px;
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .prose-content :global(a:not(.not-prose)) {
      transition: none;
    }
  }
</style>
