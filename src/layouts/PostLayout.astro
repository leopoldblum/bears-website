---
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  date: Date;
  coverImage?: ImageMetadata;
}

const { title, date, coverImage } = Astro.props;
---

<BaseLayout title={title}>
  <article class="container mx-auto px-4 sm:px-6 lg:px-60 py-8 sm:py-12 lg:py-16">
    <!-- Cover Image -->
    {coverImage && (
      <div class="mb-6 sm:mb-8 rounded-lg overflow-hidden">
        <Image
          src={coverImage}
          alt={title}
          class="w-full h-48 sm:h-64 lg:h-96 object-cover"
          loading="eager"
          format="webp"
        />
      </div>
    )}

    <!-- Title and Date -->
    <header class="mb-6 sm:mb-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-3 sm:mb-4 text-bears-accent">
        {title}
      </h1>
      <time class="text-sm sm:text-base text-bears-text-onDark/80">
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>

    <!-- Content -->
    <div class="prose prose-invert prose-lg max-w-none text-justify
                prose-headings:text-bears-text-onDark
                prose-p:text-bears-text-onDark/90
                prose-a:text-bears-accent prose-a:no-underline hover:prose-a:underline
                prose-strong:text-bears-text-onDark
                prose-ul:text-bears-text-onDark/90
                prose-ol:text-bears-text-onDark/90">
      <slot />
    </div>
  </article>
</BaseLayout>
