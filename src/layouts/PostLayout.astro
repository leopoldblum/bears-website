---
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ReadingProgress from "../components/post/ReadingProgress.astro";
import MetadataCard from "../components/post/MetadataCard.astro";

interface Props {
  title: string;
  date: Date;
  coverImage?: ImageMetadata;
  category: string;
  tags?: string[];
  isCompleted?: boolean;
  type: 'event' | 'project';
}

const { title, date, coverImage, category, tags = [], isCompleted, type } = Astro.props;
---

<BaseLayout title={title}>
  <ReadingProgress />

  <article class="post-container">
    <div class="post-inner">
      <!-- Cover Image -->
      {coverImage && (
        <div class="cover-image-wrapper">
          <Image
            src={coverImage}
            alt={title}
            class="cover-image"
            loading="eager"
            format="webp"
          />
        </div>
      )}

      <!-- Header -->
      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <time class="post-date">
            {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <div class="header-divider"></div>
      </header>

      <!-- Content Grid: Main + Sidebar -->
      <div class="content-grid">
        <!-- Main Content -->
        <div class="prose-content">
          <slot />
        </div>

        <!-- Sidebar (Desktop) / Top Card (Mobile) -->
        <div class="sidebar-wrapper">
          <div class="sidebar-sticky">
            <MetadataCard
              category={category}
              tags={tags}
              date={date}
              isCompleted={isCompleted}
              type={type}
            />
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-container {
    width: 100%;
    padding: 2rem 1rem;
  }

  .post-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Cover Image */
  .cover-image-wrapper {
    margin-bottom: 2rem;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .cover-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Header */
  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-bears-text-onDark);
    margin: 0 0 1rem 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .post-date {
    font-size: 0.9375rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.7;
    font-weight: 500;
  }

  .header-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
    margin-top: 1.5rem;
  }

  /* Content Grid */
  .content-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  /* Sidebar */
  .sidebar-wrapper {
    order: -1; /* Show metadata card above content on mobile */
  }

  .sidebar-sticky {
    position: relative;
  }

  /* Prose Content */
  .prose-content {
    /* Enhanced prose styling with refined typography */
    color: var(--color-bears-text-onDark);
    font-size: 1.0625rem;
    line-height: 1.75;
    max-width: 75ch;
    padding-left: 1rem;
  }

  /* Typography Enhancements */
  .prose-content :global(h2) {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-bears-text-onDark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-content :global(h3) {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-bears-text-onDark);
    margin-top: 2rem;
    margin-bottom: 0.875rem;
  }

  .prose-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-bears-text-onDark);
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .prose-content :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
  }

  .prose-content :global(a) {
    color: var(--color-bears-accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .prose-content :global(a:hover) {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Lists */
  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.75rem;
  }

  .prose-content :global(li) {
    margin-bottom: 0.625rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    line-height: 1.7;
  }

  .prose-content :global(ul > li) {
    list-style-type: disc;
  }

  .prose-content :global(ul > li::marker) {
    color: var(--color-bears-accent);
  }

  /* Blockquotes */
  .prose-content :global(blockquote) {
    margin: 1.75rem 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--color-bears-accent);
    background-color: rgba(255, 255, 255, 0.03);
    border-radius: 0 6px 6px 0;
  }

  .prose-content :global(blockquote p) {
    color: var(--color-bears-text-onDark);
    opacity: 0.85;
    font-style: italic;
  }

  /* Code */
  .prose-content :global(code) {
    background-color: rgba(255, 255, 255, 0.08);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--color-bears-text-onDark);
    font-family: 'Monaco', 'Consolas', monospace;
  }

  .prose-content :global(pre) {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Strong/Bold */
  .prose-content :global(strong) {
    font-weight: 600;
    color: var(--color-bears-text-onDark);
  }

  /* Responsive: Tablet */
  @media (min-width: 640px) {
    .post-container {
      padding: 3rem 1.5rem;
    }

    .cover-image-wrapper {
      margin-bottom: 2.5rem;
    }

    .post-header {
      margin-bottom: 2.5rem;
    }
  }

  /* Responsive: Desktop */
  @media (min-width: 1024px) {
    .post-container {
      padding: 4rem 2rem;
    }

    .cover-image-wrapper {
      margin-bottom: 3rem;
    }

    .post-header {
      margin-bottom: 3rem;
    }

    .content-grid {
      grid-template-columns: 1fr 320px;
      gap: 2.5rem;
    }

    .sidebar-wrapper {
      order: 0; /* Sidebar on right for desktop */
    }

    .sidebar-sticky {
      position: sticky;
      top: 2rem;
    }

    .prose-content {
      font-size: 1.125rem;
      padding-left: 2rem;
    }
  }

  /* Responsive: Large Desktop */
  @media (min-width: 1280px) {
    .content-grid {
      gap: 3rem;
    }

    .prose-content {
      padding-left: 3rem;
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .prose-content :global(a) {
      transition: none;
    }
  }
</style>
