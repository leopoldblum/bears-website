---
import "@styles/global.css";
import Header from "@layout/Header.astro";
import Footer from "@layout/Footer.astro";
import BackToTopButton from "@layout/BackToTopButton.astro";
import { getPageContent } from "@utils/contentQueries";
import { getLocale, getHreflangUrls } from "@utils/i18n";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const locale = getLocale(Astro.url);

const siteMetadata = await getPageContent("site/metadata", locale);
const socialLinksContent = await getPageContent("site/social-links", locale);

const {
  title,
  description = siteMetadata?.data.description ?? "BEARS e.V. – Berlin Experimental Astronautics Research Student team at TU Berlin.",
  ogImage = "/og-default.jpg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const siteOrigin = canonicalUrl.origin;
const hreflangUrls = getHreflangUrls(Astro.url.pathname, siteOrigin);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "BEARS e.V.",
  url: siteOrigin,
  sameAs: socialLinksContent?.data.socialLinks?.map((link: { url: string }) => link.url) ?? [],
};
---

<!DOCTYPE html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={hreflangUrls.en} />
    <link rel="alternate" hreflang="de" href={hreflangUrls.de} />
    <link rel="alternate" hreflang="x-default" href={hreflangUrls.en} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={`${title} | BEARS`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalUrl.origin).href} />
    <meta property="og:site_name" content="BEARS e.V." />
    <meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | BEARS`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, canonicalUrl.origin).href} />

    <title>{title} | BEARS</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Intercept hash before browser scrolls — we handle it ourselves -->
    <script is:inline>
      if (window.location.hash) {
        window.__scrollTarget = window.location.hash;
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <Header locale={locale} />
    <main class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer locale={locale} />
    <BackToTopButton />
    <script>
      if (window.__scrollTarget) {
        const hash = window.__scrollTarget;
        delete window.__scrollTarget;

        const scrollToTarget = () => {
          try {
            const el = document.querySelector(hash);
            if (el) {
              el.scrollIntoView({ behavior: "smooth" });
              history.replaceState(null, '', window.location.pathname + window.location.search + hash);
            }
          } catch { /* invalid selector */ }
        };

        let done = false;
        const doScroll = () => {
          if (done) return;
          done = true;
          requestAnimationFrame(() => requestAnimationFrame(scrollToTarget));
        };

        document.addEventListener("alpine:initialized", doScroll, { once: true });
        // Fallback for pages without Alpine (imprint, datenschutz)
        window.addEventListener("load", () => setTimeout(doScroll, 100), { once: true });
      }
    </script>
  </body>
</html>