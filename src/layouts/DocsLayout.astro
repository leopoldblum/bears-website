---
import "@styles/global.css";
import DocsSidebar from "@components/docs/DocsSidebar.astro";
import DocsToc from "@components/docs/DocsToc.astro";
import { getEntry } from "astro:content";

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, headings = [] } = Astro.props;

const branding = await getEntry("branding", "site-assets");
const faviconHref = branding?.data.favicon ?? "/favicon.png";
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={faviconHref} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="noindex" />
    <title>{title} | BEARS Docs</title>

    <!-- Intercept hash before browser scrolls — we handle it ourselves -->
    <script is:inline>
      if (window.location.hash) {
        window.__scrollTarget = window.location.hash;
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }
    </script>
  </head>
  <body class="min-h-screen bg-bears-bg text-bears-text-onDark">
    <!-- Minimal docs header -->
    <header class="sticky top-0 z-30 bg-bears-bg/95 backdrop-blur-sm border-b border-white/10">
      <div class="flex items-center justify-between px-4 sm:px-6 h-14">
        <div class="flex items-center gap-3">
          <button
            class="lg:hidden text-bears-text-onDark/70 hover:text-bears-text-onDark cursor-pointer"
            x-data
            x-on:click="$dispatch('toggle-docs-sidebar')"
            aria-label="Toggle sidebar"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <a href="/docs/" class="text-lg font-bold text-bears-accent hover:opacity-80 transition-opacity">
            BEARS Docs
          </a>
        </div>
        <a href="/" class="text-sm text-bears-text-onDark/60 hover:text-bears-text-onDark transition-colors">
          &larr; Back to site
        </a>
      </div>
    </header>

    <div class="flex">
      <DocsSidebar />

      <div class="flex-1 min-w-0 overflow-x-clip">
        <main class="docs-main relative max-w-4xl px-4 sm:px-8 lg:px-12 xl:px-16 py-8 lg:py-12">
          <article class="docs-prose">
            <slot />
          </article>

          <aside class="docs-toc-aside hidden xl:block absolute left-full top-0 bottom-0 pt-8 lg:pt-12 pl-5">
            <DocsToc headings={headings} />
          </aside>
        </main>
      </div>
    </div>

    <script>
      document.querySelectorAll('.docs-prose pre').forEach(pre => {
        if (pre.closest('[data-no-auto-copy]')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'docs-code-block';
        pre.parentNode!.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        const btn = document.createElement('button');
        btn.className = 'docs-copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`;
        btn.addEventListener('click', () => {
          const code = pre.querySelector('code');
          navigator.clipboard.writeText(code?.textContent ?? '');
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`;
          setTimeout(() => {
            btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`;
          }, 1500);
        });
        wrapper.appendChild(btn);
      });
    </script>
    <script>
      if (window.__scrollTarget) {
        const hash = window.__scrollTarget;
        delete window.__scrollTarget;

        const scrollToTarget = () => {
          try {
            const el = document.querySelector(hash);
            if (el) {
              el.scrollIntoView({ behavior: "smooth" });
              history.replaceState(null, '', window.location.pathname + window.location.search + hash);
            }
          } catch { /* invalid selector */ }
        };

        let done = false;
        const doScroll = () => {
          if (done) return;
          done = true;
          requestAnimationFrame(() => requestAnimationFrame(scrollToTarget));
        };

        document.addEventListener("alpine:initialized", doScroll, { once: true });
        window.addEventListener("load", () => setTimeout(doScroll, 100), { once: true });
      }
    </script>
  </body>
</html>

<style>
  /* Docs prose styling — adapted from PostLayout.astro */
  .docs-prose :global(h1) {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-bears-text-onDark);
    margin-bottom: 1.5rem;
  }

  .docs-prose :global(h2) {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-bears-text-onDark);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    scroll-margin-top: 4.5rem;
  }

  .docs-prose :global(h3) {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-bears-text-onDark);
    margin-top: 2rem;
    margin-bottom: 0.625rem;
    scroll-margin-top: 4.5rem;
  }

  .docs-prose :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-bears-text-onDark);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 4.5rem;
  }

  .docs-prose :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    line-height: 1.75;
  }

  .docs-prose :global(a:not(.not-prose)) {
    color: var(--color-bears-accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .docs-prose :global(a:not(.not-prose):hover) {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Lists */
  .docs-prose :global(ul),
  .docs-prose :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.75rem;
  }

  .docs-prose :global(li) {
    margin-bottom: 0.5rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    line-height: 1.7;
  }

  .docs-prose :global(ul > li) {
    list-style-type: disc;
  }

  .docs-prose :global(ul > li::marker) {
    color: var(--color-bears-accent);
  }

  .docs-prose :global(ol > li) {
    list-style-type: decimal;
  }

  .docs-prose :global(ol > li::marker) {
    color: var(--color-bears-accent);
  }

  /* Blockquotes */
  .docs-prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid var(--color-bears-accent);
    background-color: rgba(255, 255, 255, 0.03);
    border-radius: 0 6px 6px 0;
  }

  .docs-prose :global(blockquote p) {
    color: var(--color-bears-text-onDark);
    opacity: 0.85;
    font-style: italic;
  }

  /* Code */
  .docs-prose :global(code) {
    background-color: rgba(255, 255, 255, 0.08);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    color: var(--color-bears-text-onDark);
    font-family: "Monaco", "Consolas", monospace;
  }

  /* Code block wrapper with copy button */
  :global(.docs-code-block) {
    position: relative;
  }

  :global(.docs-copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.375rem;
    border-radius: 6px;
    color: rgba(255, 255, 255, 0.4);
    background: transparent;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease, color 0.15s ease, background-color 0.15s ease;
    z-index: 1;
  }

  :global(.docs-code-block:hover .docs-copy-btn) {
    opacity: 1;
  }

  :global(.docs-copy-btn:hover) {
    color: var(--color-bears-text-onDark);
    background-color: rgba(255, 255, 255, 0.1);
  }

  .docs-prose :global(pre) {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .docs-prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Strong/Bold */
  .docs-prose :global(strong) {
    font-weight: 600;
    color: var(--color-bears-text-onDark);
  }

  /* Horizontal Rule */
  .docs-prose :global(hr) {
    margin: 2.5rem 0;
    border: none;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0.05),
      transparent
    );
  }

  /* Tables */
  .docs-prose :global(table) {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .docs-prose :global(thead) {
    border-bottom: 2px solid rgba(255, 255, 255, 0.15);
  }

  .docs-prose :global(th) {
    text-align: left;
    padding: 0.625rem 0.75rem;
    font-weight: 600;
    color: var(--color-bears-text-onDark);
  }

  .docs-prose :global(td) {
    padding: 0.625rem 0.75rem;
    color: var(--color-bears-text-onDark);
    opacity: 0.9;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Images */
  .docs-prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  /* Images inside Img component wrappers — the wrapper already handles
     spacing and aspect-ratio, so the inner img must not add its own margin
     (which would shift it down relative to the hover:ring). */
  .docs-prose :global(.img-better img) {
    margin: 0;
  }

  /* AI context block — remove pre margin inside custom container */
  .docs-prose :global([data-no-auto-copy] pre) {
    margin: 0;
    border: none;
    border-radius: 0;
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .docs-prose :global(a:not(.not-prose)) {
      transition: none;
    }
  }

  /* Center main content on the full viewport, not just the post-sidebar area.
     On lg+ the sidebar is 16rem wide, so we offset the centering.
     --docs-ml is exposed so the TOC aside can compute its available width. */
  .docs-main {
    --docs-ml: 0px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 1024px) {
    .docs-main {
      --docs-ml: max(0px, calc((100vw - 56rem) / 2 - 16rem));
      margin-left: var(--docs-ml);
      margin-right: auto;
    }
  }

  /* TOC aside — fills from main's right edge to the wrapper's right edge.
     Width = wrapper (100vw − sidebar 16rem) − main width (100%) − main margin-left − 1rem buffer.
     Capped at 16rem so it doesn't sprawl on ultra-wide screens. */
  .docs-toc-aside {
    width: min(16rem, calc(100vw - 16rem - 100% - var(--docs-ml) - 1rem));
  }
</style>
